class ExitManager:
    """Comprehensive exit management: trailing stop, TP/SL, flow-based."""
    def __init__(
        self,
        trailing_pct: float = 3.0,
        momentum_exit_threshold: float = -30.0,
        dynamic_tp_pct: float = 20.0,
        dynamic_sl_pct: float = -12.0
    ):
        self.trailing_pct = trailing_pct
        self.momentum_exit_threshold = momentum_exit_threshold
        self.dynamic_tp_pct = dynamic_tp_pct
        self.dynamic_sl_pct = dynamic_sl_pct
        self._positions: Dict[str, Dict] = {}
        self.peak_volumes: Dict[str, float] = {}

    def register_position(self, mint: str, pos_data: Dict):
        entry_price = pos_data.get("entry_price", 0)
        entry_volume = pos_data.get("volume", 0)
        self._positions[mint] = {
            "entry_price": entry_price,
            "peak_price": entry_price,
            "entry_volume": entry_volume,
            "peak_volume": entry_volume,
            "flow_score": 50,
            "buy_ratio": 0.5,
        }
        if entry_volume > 0:
            self.peak_volumes[mint] = entry_volume

    def update_price(self, mint: str, current_price: float):
        pos = self._positions.get(mint)
        if pos and current_price > pos.get("peak_price", 0):
            pos["peak_price"] = current_price

    def update_volume(self, mint: str, current_volume: float):
        if mint not in self.peak_volumes:
            self.peak_volumes[mint] = current_volume
        elif current_volume > self.peak_volumes[mint]:
            self.peak_volumes[mint] = current_volume
        pos = self._positions.get(mint)
        if pos:
            pos["peak_volume"] = max(pos.get("peak_volume", 0), current_volume)

    def update_flow(self, mint: str, flow_score: float, buy_ratio: float):
        pos = self._positions.get(mint)
        if pos:
            pos["flow_score"] = flow_score
            pos["buy_ratio"] = buy_ratio

    def should_exit(
        self,
        mint: str,
        current_price: float,
        current_flow_score: float,
        buy_ratio: float,
        current_volume: float = 0
    ) -> Tuple[bool, str]:
        pos = self._positions.get(mint)
        if not pos:
            return False, ""

        entry_price = pos.get("entry_price", current_price)
        peak_price = pos.get("peak_price", current_price)
        if entry_price <= 0:
            return False, ""

        profit_pct = (current_price - entry_price) / entry_price * 100

        # 1. Hard stop-loss
        if profit_pct <= self.dynamic_sl_pct:
            return True, f"stop_loss({profit_pct:.1f}%)"

        # 2. Hard take-profit
        if profit_pct >= self.dynamic_tp_pct:
            return True, f"take_profit({profit_pct:.1f}%)"

        # 3. Trailing stop from peak
        if peak_price > entry_price:
            drawdown_from_peak = (current_price - peak_price) / peak_price * 100
            if drawdown_from_peak <= -self.trailing_pct:
                return True, f"trailing_stop(peak={peak_price:.6f}, drawdown={drawdown_from_peak:.1f}%)"

        # 4. Flow momentum exit
        if (current_flow_score <= self.momentum_exit_threshold and
                profit_pct > 0):
            return True, f"flow_exit(score={current_flow_score:.0f})"

        # 5. Buy pressure collapse
        if buy_ratio < 0.3 and profit_pct > 3:
            return True, f"buy_pressure_collapse(ratio={buy_ratio:.2f})"

        # 6. Volume drop from peak
        peak_vol = self.peak_volumes.get(mint, 0)
        if (peak_vol > 0 and current_volume > 0 and
                current_volume < peak_vol * 0.3 and profit_pct > 5):
            return True, f"volume_collapse({current_volume/peak_vol:.0%} of peak)"

        return False, ""

    def remove_position(self, mint: str):
        self._positions.pop(mint, None)
        self.peak_volumes.pop(mint, None)

