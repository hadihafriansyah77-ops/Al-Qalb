def rate_check(uid: int, _cache: Dict = {}, _max=10, _window=60) -> bool:
    """Rate limiter: max 10 requests per 60 seconds per user."""
    now = time.time()
    if uid not in _cache:
        _cache[uid] = deque()
    q = _cache[uid]
    while q and now - q[0] > _window:
        q.popleft()
    if len(q) >= _max:
        return False
    q.append(now)
    return True

