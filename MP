class EventBus:
    """Central event bus. All modules communicate through this."""
    def __init__(self):
        self._handlers: Dict[str, List[Callable]] = defaultdict(list)
        self._history: deque = deque(maxlen=200)

    def subscribe(self, event: str, handler: Callable):
        self._handlers[event].append(handler)

    async def publish(self, event: str, data: dict):
        self._history.append({"event": event, "data": data, "ts": time.time()})
        for handler in self._handlers.get(event, []):
            try:
                if asyncio.iscoroutinefunction(handler):
                    await handler(data)
                else:
                    handler(data)
            except Exception as e:
                log.error(f"EventBus handler error [{event}]: {e}")

    def get_history(self, event: str = None, limit: int = 20) -> List[dict]:
        h = list(self._history)
        if event:
            h = [x for x in h if x["event"] == event]
        return h[-limit:]

event_bus = EventBus()

