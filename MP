# ==============================================================
class SmartTradePlanner:
    """Advanced trade planning: entry/exit analysis targeting 90%+ WR."""
    def __init__(self):
        self._price_history: Dict[str, deque] = defaultdict(lambda: deque(maxlen=50))
        self._vol_history: Dict[str, deque] = defaultdict(lambda: deque(maxlen=50))
        self._buy_history: Dict[str, deque] = defaultdict(lambda: deque(maxlen=50))
        self._sell_history: Dict[str, deque] = defaultdict(lambda: deque(maxlen=50))
        self._entry_count: Dict[str, int] = defaultdict(int)

    def update_history(
        self, mint: str, price: float, volume: float,
        buys: int, sells: int
    ):
        self._price_history[mint].append(price)
        self._vol_history[mint].append(volume)
        self._buy_history[mint].append(buys)
        self._sell_history[mint].append(sells)

    def analyze_entry(
        self, mint: str, data: Dict,
        intel_report: Dict, market_cond: str
    ) -> Tuple[bool, float, str]:
        """Returns: (should_enter, confidence, reason)."""
        # Update history
        self.update_history(
            mint,
            data.get("price_usd", 0),
            data.get("volume_h24", 0),
            data.get("txns_h24_buys", 0),
            data.get("txns_h24_sells", 0)
        )

        prices = list(self._price_history[mint])
        volumes = list(self._vol_history[mint])
        buys_list = list(self._buy_history[mint])
        sells_list = list(self._sell_history[mint])

        reasons = []
        confidence = 0.0

        # 1. RSI not overbought (< 75)
        if len(prices) >= 5:
            rsi = MemeTechIndicators.calculate_rsi(prices)
            if rsi > 80:
                return False, 0, f"RSI_overbought({rsi:.0f})"
            if 30 <= rsi <= 70:
                confidence += 0.15
                reasons.append(f"RSI_ok({rsi:.0f})")

        # 2. Volume spike
        if len(volumes) >= 3:
            spike = MemeTechIndicators.calculate_volume_spike(volumes)
            if spike >= 1.5:
                confidence += 0.2
                reasons.append(f"vol_spike({spike:.1f}x)")
            elif spike < 0.8:
                confidence -= 0.1

        # 3. Buy pressure
        if buys_list and sells_list:
            bp = MemeTechIndicators.calculate_buy_pressure(buys_list, sells_list)
            if bp > 0.6:
                confidence += 0.2
                reasons.append(f"buy_pressure({bp:.0%})")
            elif bp < 0.4:
                return False, 0, f"sell_pressure({bp:.0%})"

        # 4. Market condition
        if market_cond in ("bull", "bull_extreme"):
            confidence += 0.15
            reasons.append(f"market_{market_cond}")
        elif market_cond in ("bear_extreme",):
            return False, 0, "bear_market"

        # 5. Intel signals
        if intel_report.get("smart_money"):
            confidence += 0.15
            reasons.append("smart_money")
        if intel_report.get("whale_sentiment") == "bullish":
            confidence += 0.1
            reasons.append("whale_bullish")

        # 6. Momentum score
        if len(prices) >= 3 and len(volumes) >= 3:
            mom = MemeTechIndicators.calculate_momentum_score(prices, volumes)
            if mom > 0.1:
                confidence += 0.15
                reasons.append(f"momentum({mom:.2f})")

        # 7. Entry limit per mint
        if self._entry_count[mint] >= 3:
            return False, 0, "max_entries_reached"

        # Final decision
        min_confidence = 0.45
        should_enter = confidence >= min_confidence
        reason_str = " | ".join(reasons) if reasons else "no_signals"

        if should_enter:
            self._entry_count[mint] += 1

        return should_enter, confidence, reason_str

    def analyze_exit(
        self, mint: str, current_price: float, entry_price: float,
        hold_minutes: float, flow_score: float
    ) -> Tuple[bool, str]:
        """Returns: (should_exit, reason)."""
        if entry_price <= 0:
            return False, ""

        profit_pct = (current_price - entry_price) / entry_price * 100
        prices = list(self._price_history[mint])

        # Knowledge-base exit rules
        if profit_pct >= 15:
            return True, f"profit_target({profit_pct:.1f}%)"
        if profit_pct <= -8:
            return True, f"stop_loss({profit_pct:.1f}%)"
        if hold_minutes > 240:  # 4 hour max hold
            return True, f"time_limit(4h)"
        if flow_score < 25 and profit_pct > 3:
            return True, f"flow_deteriorating(score={flow_score:.0f})"

        # RSI exit signal
        if len(prices) >= 5:
            rsi = MemeTechIndicators.calculate_rsi(prices)
            if rsi > 85 and profit_pct > 5:
                return True, f"RSI_overbought_exit({rsi:.0f})"

        return False, ""

    def reset_entry_count(self, mint: str):
        self._entry_count.pop(mint, None)


