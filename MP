def _score_memecoin(mc: float, vol: float) -> int:
    """Quick memecoin viability score based on market cap and volume."""
    if mc <= 0 or vol <= 0:
        return 0
    score = 0
    # Market cap scoring (sweet spot: 50k-5M)
    if 10_000 <= mc <= 100_000:
        score += 30
    elif 100_000 <= mc <= 1_000_000:
        score += 40
    elif 1_000_000 <= mc <= 5_000_000:
        score += 25
    elif mc > 5_000_000:
        score += 10
    # Volume/MC ratio scoring
    ratio = vol / mc if mc > 0 else 0
    if ratio >= 5.0:
        score += 30
    elif ratio >= 2.0:
        score += 20
    elif ratio >= 0.5:
        score += 10
    # Volume absolute
    if vol >= 500_000:
        score += 20
    elif vol >= 100_000:
        score += 10
    elif vol >= 10_000:
        score += 5
    return min(score, 100)

