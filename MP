class AdaptiveScorer:
    """Adaptive scoring system that learns from trade outcomes."""
    def __init__(self, lookback: int = 20):
        self.lookback = lookback
        self.history: deque = deque(maxlen=lookback)
        self.market_baseline: Dict = {}
        self.win_rate = 0.5
        self.avg_profit = 0.0
        # Subscribe to trade events
        event_bus.subscribe("trade_closed", self.update_from_trade)

    async def update_from_trade(self, event: dict):
        """Learn from closed trade outcomes."""
        try:
            result = {
                "mint": event.get("mint", ""),
                "profit_pct": event.get("profit_pct", 0),
                "result": event.get("result", ""),
                "reason": event.get("reason", ""),
                "entry_liquidity": event.get("entry_liquidity", 0),
                "entry_volume": event.get("entry_volume", 0),
                "entry_buy_ratio": event.get("entry_buy_ratio", 0.5),
                "ts": time.time(),
            }
            self.history.append(result)
            # Recalculate metrics
            if self.history:
                wins = sum(1 for h in self.history if h["profit_pct"] > 0)
                self.win_rate = wins / len(self.history)
                self.avg_profit = statistics.mean(
                    h["profit_pct"] for h in self.history
                )
        except Exception as e:
            log.debug(f"AdaptiveScorer.update_from_trade error: {e}")

    def update_market_baseline(self, data: Dict):
        """Update market baseline metrics for relative scoring."""
        for key in ["volume_h24", "market_cap", "price_change_h24"]:
            if key in data and data[key] is not None:
                vals = [h.get(key, 0) for h in list(self.history) if key in h]
                if vals:
                    self.market_baseline[key] = statistics.mean(vals)
                else:
                    self.market_baseline[key] = data[key]

    def _calculate_base(self, data: Dict) -> int:
        """Calculate base score from raw token data."""
        score = 0
        mc = data.get("market_cap", 0)
        vol = data.get("volume_h24", 0)
        change = data.get("price_change_h24", 0)
        liquidity = data.get("liquidity_usd", 0)
        buys = data.get("txns_h24_buys", 0)
        sells = data.get("txns_h24_sells", 0)

        # Market cap score
        if 50_000 <= mc <= 500_000:
            score += 25
        elif 500_000 <= mc <= 2_000_000:
            score += 20
        elif mc > 2_000_000:
            score += 10

        # Volume score
        vol_ratio = vol / mc if mc > 0 else 0
        if vol_ratio >= 3:
            score += 25
        elif vol_ratio >= 1:
            score += 15
        elif vol_ratio >= 0.3:
            score += 5

        # Price momentum
        if 10 <= change <= 100:
            score += 20
        elif change > 100:
            score += 10  # might be too late
        elif change < -20:
            score -= 15

        # Buy pressure
        total_txns = buys + sells
        if total_txns > 0:
            buy_ratio = buys / total_txns
            if buy_ratio > 0.65:
                score += 15
            elif buy_ratio > 0.55:
                score += 8

        # Liquidity
        if liquidity >= 50_000:
            score += 15
        elif liquidity >= 10_000:
            score += 8

        return score

    def score(self, data: Dict) -> int:
        """Adaptive score combining base, market-relative, and learned metrics."""
        base = self._calculate_base(data)

        # Relative adjustment from baseline
        vol = data.get("volume_h24", 0)
        baseline_vol = self.market_baseline.get("volume_h24", vol)
        if baseline_vol > 0 and vol > baseline_vol * 1.5:
            base += 10  # above-average volume

        # Apply win rate confidence adjustment
        if self.win_rate < 0.4:
            base = int(base * 0.85)  # be more conservative after losses
        elif self.win_rate > 0.65:
            base = int(base * 1.05)

        # Learned from history: penalize patterns that led to losses
        for h in list(self.history)[-5:]:
            if h["profit_pct"] < -10:
                # Penalize similar market cap range
                h_mc = h.get("market_cap", 0)
                d_mc = data.get("market_cap", 0)
                if h_mc > 0 and abs(d_mc - h_mc) / h_mc < 0.5:
                    base -= 5

        return max(0, min(100, base))

