class MomentumChecker:
    """Checks real-time price momentum with multiple samples."""
    async def check(
        self,
        mint: str,
        interval_sec: int = 5,
        samples: int = 3
    ) -> Dict:
        prices = []
        volumes = []

        async def fetch_one():
            d = await get_token_data(mint)
            if d:
                prices.append(d.get("price_usd", 0))
                volumes.append(d.get("volume_h24", 0))

        await fetch_one()
        for _ in range(samples - 1):
            await asyncio.sleep(interval_sec)
            await fetch_one()

        if len(prices) < 2:
            return {"direction": "neutral", "strength": 0, "prices": prices}

        price_change = (prices[-1] - prices[0]) / (prices[0] or 1) * 100
        vol_trend = (
            (volumes[-1] - volumes[0]) / (volumes[0] or 1) * 100
            if volumes[0] > 0 else 0
        )
        direction = "up" if price_change > 0.5 else "down" if price_change < -0.5 else "neutral"
        strength = abs(price_change) * (1 + max(0, vol_trend / 100))

        return {
            "direction": direction,
            "strength": min(100, strength),
            "price_change_pct": price_change,
            "vol_trend_pct": vol_trend,
            "prices": prices,
            "volumes": volumes,
        }

