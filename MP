class FinancialIntelligence:
    """Core financial brain: tracks outcomes and optimizes strategies."""
    def __init__(self):
        self.crypto_weights = {
            "max_trade_pct": 0.05,
            "take_profit_mult": 2.0,
            "stop_loss_pct": -15.0,
            "min_volume": 50_000,
            "min_liquidity": 10_000,
        }
        self._history: List[Dict] = []
        self._domain_stats: Dict[str, Dict] = {}

    async def record_outcome(
        self, domain: str, action: dict, result: dict
    ):
        """Record a financial action outcome for learning."""
        entry = {
            "domain": domain,
            "action": action,
            "result": result,
            "ts": time.time(),
        }
        self._history.append(entry)
        if domain not in self._domain_stats:
            self._domain_stats[domain] = {
                "count": 0, "wins": 0, "total_profit": 0.0
            }
        stats = self._domain_stats[domain]
        stats["count"] += 1
        profit = result.get("profit_pct", result.get("profit_usd", 0))
        if profit > 0:
            stats["wins"] += 1
        stats["total_profit"] += profit

        # Auto-adjust weights based on outcomes
        if domain == "crypto" and len(self._history) % 10 == 0:
            self._adapt_crypto_weights()

    def _adapt_crypto_weights(self):
        """Adapt trading weights based on recent performance."""
        recent = [h for h in self._history[-20:]
                  if h["domain"] == "crypto"]
        if len(recent) < 5:
            return
        profits = [h["result"].get("profit_pct", 0) for h in recent]
        win_rate = sum(1 for p in profits if p > 0) / len(profits)
        avg_profit = statistics.mean(profits)

        if win_rate < 0.4:
            # Tighten stop loss, lower trade size
            self.crypto_weights["stop_loss_pct"] = max(
