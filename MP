class DataDomain(Enum):
    TIME_SERIES = "time_series"
    TABULAR = "tabular"
    UNSTRUCTURED = "unstructured"

class HypothesisType(Enum):
    CORRELATION = "correlation"
    THRESHOLD = "threshold"
    PATTERN = "pattern"
    CAUSAL = "causal"

class HypothesisStatus(Enum):
    CANDIDATE = "candidate"
    VALIDATED = "validated"
    REJECTED = "rejected"
    ACTIVE = "active"

@dataclass
class UniversalDataFrame:
    data: pd.DataFrame
    domain: DataDomain
    source_name: str
    timestamp_col: Optional[str] = None

    @property
    def n_rows(self) -> int:
        return len(self.data)

    @property
    def n_features(self) -> int:
        return len(self.data.columns)

@dataclass
class Hypothesis:
    id: str
    type: HypothesisType
    antecedent: Dict  # {"feature": ..., "condition": ..., "value": ...}
    consequent: Dict  # {"feature": ..., "direction": "up"|"down", "magnitude": float}
    confidence: float = 0.0
    support: float = 0.0
    fitness: float = 0.0
    status: HypothesisStatus = HypothesisStatus.CANDIDATE
    generation: int = 0
    validated_at: Optional[float] = None
    metadata: Dict = field(default_factory=dict)

class InputAbstractionLayer:
    """Normalizes input data into UniversalDataFrame."""
    def _detect_domain(self, df: pd.DataFrame, source_name: str) -> DataDomain:
        if any(c in source_name.lower() for c in ["price", "ohlc", "series", "time"]):
            return DataDomain.TIME_SERIES
        numeric_ratio = len(df.select_dtypes(include=[np.number]).columns) / max(1, len(df.columns))
        return DataDomain.TIME_SERIES if numeric_ratio > 0.7 else DataDomain.TABULAR

    def _enforce_real_data(self, df: pd.DataFrame, source_name: str):
        if df.empty:
            raise ValueError(f"Empty dataframe from source: {source_name}")
        if len(df) < 5:
            raise ValueError(f"Insufficient data rows: {len(df)} from {source_name}")

    def ingest(
        self, data, source_name: str = "input",
        timestamp_col: str = None
    ) -> UniversalDataFrame:
        if isinstance(data, pd.DataFrame):
            df = data.copy()
        elif isinstance(data, list):
            df = pd.DataFrame(data)
        elif isinstance(data, dict):
            df = pd.DataFrame([data])
        else:
            raise ValueError(f"Unsupported data type: {type(data)}")

        self._enforce_real_data(df, source_name)

        # Convert numeric columns
        for col in df.columns:
            try:
                df[col] = pd.to_numeric(df[col], errors="ignore")
            except Exception:
                pass

        domain = self._detect_domain(df, source_name)
        return UniversalDataFrame(
            data=df, domain=domain,
            source_name=source_name, timestamp_col=timestamp_col
        )

class BacktestingLayer:
    """Backtests hypotheses on historical data windows."""
    def __init__(self, window_size: int = 20, step: int = 5):
        self.window_size = window_size
        self.step = step

    def _eval_condition(
        self, window: pd.DataFrame, feature: str, cond: dict
    ) -> bool:
        if feature not in window.columns:
            return False
        col = window[feature].dropna()
        if col.empty:
            return False
        val = col.iloc[-1]
        op = cond.get("op", "gt")
        threshold = cond.get("value", 0)
        ops = {
            "gt": val > threshold, "lt": val < threshold,
            "gte": val >= threshold, "lte": val <= threshold,
            "eq": abs(val - threshold) < threshold * 0.01,
        }
        return ops.get(op, False)

    def _antecedent_fires(self, window: pd.DataFrame, hyp: Hypothesis) -> bool:
        ant = hyp.antecedent
        feature = ant.get("feature", "")
        return self._eval_condition(window, feature, ant)

    def _consequent_observed(
        self, next_window: pd.DataFrame, hyp: Hypothesis
    ) -> bool:
        cons = hyp.consequent
        feature = cons.get("feature", "")
        direction = cons.get("direction", "up")
        if feature not in next_window.columns:
            return False
        col = next_window[feature].dropna()
        if len(col) < 2:
            return False
        pct_change = (col.iloc[-1] - col.iloc[0]) / (col.iloc[0] or 1)
        magnitude = cons.get("magnitude", 0.01)
        return (pct_change >= magnitude if direction == "up"
                else pct_change <= -magnitude)

    def evaluate(self, hyp: Hypothesis, udf: UniversalDataFrame) -> Hypothesis:
        df = udf.data.select_dtypes(include=[np.number]).fillna(method="ffill")
        if len(df) < self.window_size * 2:
            hyp.fitness = 0.0
            return hyp

        fires = 0
        hits = 0
        n = len(df)
        for i in range(0, n - self.window_size * 2, self.step):
            window = df.iloc[i: i + self.window_size]
            next_w = df.iloc[i + self.window_size: i + self.window_size * 2]
            if self._antecedent_fires(window, hyp):
                fires += 1
                if self._consequent_observed(next_w, hyp):
                    hits += 1

        if fires == 0:
            hyp.fitness = 0.0
            hyp.support = 0.0
            hyp.confidence = 0.0
        else:
            hyp.confidence = hits / fires
            hyp.support = fires / max(1, (n - self.window_size * 2) / self.step)
            # Fitness = harmonic mean of confidence and support
            if hyp.confidence + hyp.support > 0:
                hyp.fitness = (2 * hyp.confidence * hyp.support /
                               (hyp.confidence + hyp.support))
        return hyp

class UHEEEngine:
    """Unified Hypothesis Evolutionary Engine — core self-learning system."""
    def __init__(
        self,
        evolution_cycles: int = EVOLUTION_CYCLES,
        population_size: int = 30,
        mutation_rate: float = 0.2,
        elite_size: int = 5
    ):
        self.evolution_cycles = evolution_cycles
        self.population_size = population_size
        self.mutation_rate = mutation_rate
        self.elite_size = elite_size
        self.cycle_count = 0
        self.history: List[Dict] = []
        self._ial = InputAbstractionLayer()
        self._backtester = BacktestingLayer()
        self._population: List[Hypothesis] = []

    def _generate_hypotheses(
        self, udf: UniversalDataFrame, generation: int = 0
    ) -> List[Hypothesis]:
        hypotheses = []
        numeric_cols = list(udf.data.select_dtypes(include=[np.number]).columns)
        if not numeric_cols:
            return hypotheses

        for i in range(self.population_size):
            ant_feat = random.choice(numeric_cols)
            cons_feat = random.choice(numeric_cols)
            col = udf.data[ant_feat].dropna()
            if col.empty:
                continue

            threshold = float(col.quantile(random.choice([0.25, 0.5, 0.75])))
            hyp = Hypothesis(
                id=f"hyp_{generation}_{i}_{int(time.time())}",
                type=random.choice(list(HypothesisType)),
                antecedent={
                    "feature": ant_feat,
                    "op": random.choice(["gt", "lt", "gte", "lte"]),
                    "value": threshold,
                    "condition": f"{ant_feat} threshold",
                },
                consequent={
                    "feature": cons_feat,
                    "direction": random.choice(["up", "down"]),
                    "magnitude": random.uniform(0.01, 0.1),
                },
                generation=generation,
            )
            hypotheses.append(hyp)
        return hypotheses

    def _mutate(self, hyp: Hypothesis) -> Hypothesis:
        new = copy.deepcopy(hyp)
        new.id = f"mutant_{int(time.time())}_{random.randint(0, 9999)}"
        if random.random() < self.mutation_rate:
            new.antecedent["value"] *= random.uniform(0.8, 1.2)
        if random.random() < self.mutation_rate:
            new.consequent["magnitude"] *= random.uniform(0.8, 1.2)
        if random.random() < self.mutation_rate:
            new.consequent["direction"] = (
                "up" if new.consequent["direction"] == "down" else "down"
            )
        new.generation += 1
        return new

    def run_cycle(self, data, source_name: str = "input") -> Dict:
        """Run one evolutionary cycle."""
        try:
            udf = self._ial.ingest(data, source_name)
        except ValueError as e:
            log.debug(f"UHEE ingest error: {e}")
            return {"status": "error", "error": str(e), "top_hypotheses": []}

        # Generate population
        if not self._population:
            self._population = self._generate_hypotheses(udf, self.cycle_count)
        else:
            # Evolve: mutate elites
            elites = sorted(self._population, key=lambda h: h.fitness,
                            reverse=True)[:self.elite_size]
            new_pop = list(elites)
            while len(new_pop) < self.population_size:
                parent = random.choice(elites)
                new_pop.append(self._mutate(parent))
            self._population = new_pop

        # Evaluate
        for hyp in self._population:
            self._backtester.evaluate(hyp, udf)

        self._population.sort(key=lambda h: h.fitness, reverse=True)
        top = self._population[:5]

        # Promote top hypotheses
        for hyp in top:
            if hyp.fitness >= 0.6:
                hyp.status = HypothesisStatus.VALIDATED
                hyp.validated_at = time.time()

        stats = {
            "best": top[0].fitness if top else 0,
            "mean": statistics.mean(h.fitness for h in self._population),
            "worst": self._population[-1].fitness if self._population else 0,
        }
        self.cycle_count += 1
        result = {
            "status": "ok",
            "cycle": self.cycle_count,
            "top_hypotheses": [asdict(h) for h in top],
            "stats": stats,
            "source": source_name,
        }
        self.history.append(result)
        return result

    async def background_evolution(
        self, data_source_callback, interval: int = 3600
    ):
        """Run evolution cycles in background."""
        while not kill_check():
            try:
                data = await data_source_callback()
                if data is not None:
                    result = self.run_cycle(data, "background")
                    log.info(
                        f"UHEE background cycle {self.cycle_count}: "
                        f"best={result['stats']['best']:.3f}"
                    )
            except Exception as e:
                log.warning(f"UHEE background error: {e}")
            await asyncio.sleep(interval)

