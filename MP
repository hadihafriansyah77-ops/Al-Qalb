class MarketConditionAnalyzer:
    """Analyzes overall market conditions to avoid bad trade zones."""
    def __init__(self, lookback: int = 20):
        self.lookback = lookback
        self._history: deque = deque(maxlen=lookback)

    def update(self, data: Dict):
        self._history.append({
            "price_change": data.get("price_change_h24", 0),
            "volume": data.get("volume_h24", 0),
            "buy_ratio": (
                data.get("txns_h24_buys", 1) /
                max(1, data.get("txns_h24_buys", 1) +
                    data.get("txns_h24_sells", 1))
            ),
            "ts": time.time(),
        })

    def get_condition(self) -> str:
        if not self._history:
            return "neutral"
        recent = list(self._history)[-5:]
        avg_change = statistics.mean(r["price_change"] for r in recent)
        avg_buy_ratio = statistics.mean(r["buy_ratio"] for r in recent)

        if avg_change > 30 and avg_buy_ratio > 0.65:
            return "bull_extreme"
        if avg_change > 10 and avg_buy_ratio > 0.55:
            return "bull"
        if avg_change < -30 and avg_buy_ratio < 0.35:
            return "bear_extreme"
        if avg_change < -10 and avg_buy_ratio < 0.45:
            return "bear"
        return "neutral"

    def no_trade_zone(self) -> bool:
        """Return True if market conditions are too dangerous to trade."""
        cond = self.get_condition()
        return cond in ("bear_extreme",)


