class MemeTechIndicators:
    """Technical indicator suite specific to meme coins."""

    @staticmethod
    def calculate_volume_spike(volumes: List[float], window: int = 5) -> float:
        if len(volumes) < window + 1:
            return 1.0
        recent = volumes[-1]
        baseline = statistics.mean(volumes[-(window + 1):-1])
        return recent / baseline if baseline > 0 else 1.0

    @staticmethod
    def calculate_buy_pressure(
        buys: List[int], sells: List[int], window: int = 5
    ) -> float:
        if not buys or not sells:
            return 0.5
        recent_buys = sum(buys[-window:])
        recent_sells = sum(sells[-window:])
        total = recent_buys + recent_sells
        return recent_buys / total if total > 0 else 0.5

    @staticmethod
    def calculate_rsi(prices: List[float], period: int = 14) -> float:
        if len(prices) < period + 1:
            return 50.0
        deltas = [prices[i+1] - prices[i] for i in range(len(prices)-1)]
        gains = [max(0, d) for d in deltas[-period:]]
        losses = [max(0, -d) for d in deltas[-period:]]
        avg_gain = statistics.mean(gains) if gains else 0
        avg_loss = statistics.mean(losses) if losses else 0
        if avg_loss == 0:
            return 100.0
        rs = avg_gain / avg_loss
        return 100 - (100 / (1 + rs))

    @staticmethod
    def calculate_momentum_score(
        prices: List[float],
        volumes: List[float],
        window: int = 5
    ) -> float:
        if len(prices) < 2:
            return 0.0
        price_mom = (prices[-1] - prices[-min(window, len(prices))]) / \
                    (prices[-min(window, len(prices))] or 1)
        vol_spike = MemeTechIndicators.calculate_volume_spike(volumes, window)
        rsi = MemeTechIndicators.calculate_rsi(prices)
        rsi_score = (rsi - 50) / 50  # normalize -1 to +1
        return (price_mom * 0.4 + (vol_spike - 1) * 0.4 + rsi_score * 0.2)

    @staticmethod
    def social_score(name: str, symbol: str) -> int:
        """Heuristic social signal score from name/symbol."""
        score = 0
        text = (name + symbol).lower()
        bullish_kw = ["moon", "pump", "gem", "degen", "alpha", "ape",
                      "bull", "chad", "based", "wagmi", "pepe", "dog",
                      "cat", "frog", "meme", "rich", "100x", "1000x"]
        bearish_kw = ["rug", "scam", "fake", "dead", "rekt"]
        for kw in bullish_kw:
            if kw in text:
                score += 3
        for kw in bearish_kw:
            if kw in text:
                score -= 15
        return max(-20, min(score, 20))


