# ==============================================================
class MicroMomentumDetector:
    """Detects micro-level price momentum (3-second intervals)."""
    def __init__(self):
        self._cache: Dict[str, Dict] = {}

    async def check(
        self, mint: str, chat_id: int = None
    ) -> Tuple[bool, Dict]:
        """Returns (should_enter, momentum_data)."""
        samples = []
        for i in range(3):
            if i > 0:
                await asyncio.sleep(3)
            data = await get_token_data(mint)
            if data:
                samples.append({
                    "price": data.get("price_usd", 0),
                    "volume": data.get("volume_h24", 0),
                    "buys": data.get("txns_h24_buys", 0),
                    "sells": data.get("txns_h24_sells", 0),
                })

        if len(samples) < 2:
            return True, {"reason": "insufficient_samples"}

        prices = [s["price"] for s in samples if s["price"] > 0]
        volumes = [s["volume"] for s in samples]

        if len(prices) < 2:
            return True, {"reason": "no_price_data"}

        # Price direction
        price_change = (prices[-1] - prices[0]) / (prices[0] or 1) * 100

        # Volume trend
        vol_increasing = len(volumes) >= 2 and volumes[-1] >= volumes[0]

        # Buy pressure
        total_buys = sum(s["buys"] for s in samples)
        total_sells = sum(s["sells"] for s in samples)
        buy_ratio = total_buys / (total_buys + total_sells) if (total_buys + total_sells) > 0 else 0.5

        should_enter = (
            price_change >= -1.0 and  # not in strong drop
            vol_increasing and
            buy_ratio >= 0.45
        )

        info = {
            "price_change_pct": price_change,
            "vol_increasing": vol_increasing,
            "buy_ratio": buy_ratio,
            "samples": len(samples),
        }

        return should_enter, info

