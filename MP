# LAYER 18: ENHANCED TRADE LOGGER
# ==============================================================
class EnhancedTradeLogger:
    """Full trade lifecycle logger with SQLite persistence."""
    def __init__(self, db_path: str = DB_FILE):
        self.db_path = db_path
        self._init_table()

    def _init_table(self):
        with sqlite3.connect(self.db_path) as conn:
            conn.executescript("""
            CREATE TABLE IF NOT EXISTS trade_signals_v2 (
                id TEXT PRIMARY KEY,
                ts REAL, mint TEXT, symbol TEXT, score INTEGER,
                market_cap REAL, volume REAL, price REAL,
                buy_ratio REAL, flow_score REAL,
                market_condition TEXT, result TEXT,
                entry_price REAL, exit_price REAL,
                profit_percent REAL, duration_min REAL,
                reason TEXT, simulated INTEGER DEFAULT 1
            );
            """)

    def log_signal(
        self, mint: str, symbol: str, score: int, data: Dict,
        market_cond: str
    ) -> str:
        sig_id = str(uuid.uuid4())[:12]
        try:
            with sqlite3.connect(self.db_path) as conn:
                conn.execute(
                    "INSERT INTO trade_signals_v2 VALUES "
                    "(?,?,?,?,?,?,?,?,?,?,?,NULL,?,NULL,NULL,NULL,NULL,1)",
                    (sig_id, time.time(), mint, symbol, score,
                     data.get("market_cap", 0),
                     data.get("volume_h24", 0),
                     data.get("price_usd", 0),
                     data.get("txns_h24_buys", 0) /
                     max(1, data.get("txns_h24_buys", 0) +
                         data.get("txns_h24_sells", 0)),
                     50.0, market_cond,
                     data.get("price_usd", 0))
                )
        except Exception as e:
            log.debug(f"log_signal error: {e}")
        return sig_id

    def log_outcome(
        self, mint: str, entry_price: float, exit_price: float,
        duration_min: float, profit_pct: float, result: str,
        reason: str = "", simulated: bool = False
    ):
        try:
            with sqlite3.connect(self.db_path) as conn:
                conn.execute(
                    """UPDATE trade_signals_v2 SET
                    result=?, exit_price=?, profit_percent=?,
                    duration_min=?, reason=?, simulated=?
                    WHERE mint=? AND result IS NULL
                    ORDER BY ts DESC LIMIT 1""",
                    (result, exit_price, profit_pct, duration_min,
                     reason, 1 if simulated else 0, mint)
                )
        except Exception as e:
            log.debug(f"log_outcome error: {e}")

    def get_expected_value(self, min_trades: int = 50) -> Dict:
        """Calculate expected value per trade from historical data."""
        try:
            with sqlite3.connect(self.db_path) as conn:
                rows = conn.execute(
                    """SELECT profit_percent, result FROM trade_signals_v2
                    WHERE result IS NOT NULL AND profit_percent IS NOT NULL
                    ORDER BY ts DESC LIMIT ?""",
                    (max(min_trades, 200),)
                ).fetchall()
            if len(rows) < min_trades:
                return {"status": "insufficient_data", "count": len(rows)}
            profits = [r[0] for r in rows]
            wins = [p for p in profits if p > 0]
            losses = [p for p in profits if p <= 0]
            win_rate = len(wins) / len(profits)
            avg_win = statistics.mean(wins) if wins else 0
            avg_loss = statistics.mean(losses) if losses else 0
            ev = (win_rate * avg_win) + ((1 - win_rate) * avg_loss)
            return {
                "status": "ok",
                "count": len(profits),
                "win_rate": win_rate,
                "avg_win_pct": avg_win,
                "avg_loss_pct": avg_loss,
                "expected_value_pct": ev,
                "profit_factor": abs(avg_win / avg_loss) if avg_loss != 0 else 0,
            }
        except Exception as e:
            return {"status": "error", "error": str(e)}

