class SplitEntryManager:
    """Manages split entry positions for better averaging."""
    def __init__(
        self,
        split_ratio: float = 0.7,
        confirmation_pct: float = 1.0,
        max_entries: int = 3
    ):
        self.split_ratio = split_ratio
        self.confirmation_pct = confirmation_pct
        self.max_entries = max_entries
        self._positions: Dict[str, Dict] = {}

    def first_entry(
        self, mint: str, total_amount: float, entry_price: float
    ) -> float:
        """Calculate first entry amount and record position."""
        amount = total_amount * self.split_ratio
        self._positions[mint] = {
            "total": total_amount,
            "entries": 1,
            "entry_price": entry_price,
            "remaining": total_amount * (1 - self.split_ratio),
        }
        return amount

    def can_add(self, mint: str) -> bool:
        pos = self._positions.get(mint, {})
        return (pos.get("entries", 0) < self.max_entries and
                pos.get("remaining", 0) > 0)

    async def check_second_entry(
        self, mint: str, current_price: float
    ) -> float:
        """Check if second entry is valid and return amount."""
        pos = self._positions.get(mint, {})
        if not pos or not self.can_add(mint):
            return 0.0
        entry_price = pos.get("entry_price", current_price)
        if entry_price > 0:
            gain_pct = (current_price - entry_price) / entry_price * 100
            if gain_pct >= self.confirmation_pct:
                remaining = pos.get("remaining", 0)
                pos["entries"] += 1
                pos["remaining"] = 0
                return remaining
        return 0.0

    def remove(self, mint: str):
        self._positions.pop(mint, None)

class FlowTracker:
    """Tracks token flow patterns for buy/sell pressure analysis."""
    def __init__(
        self,
        window_seconds: int = 30,
        spike_threshold: float = 1.5,
        history_limit: int = 20
    ):
        self.window_seconds = window_seconds
        self.spike_threshold = spike_threshold
        self._data: Dict[str, Dict] = {}

    def _get_or_create(self, mint: str) -> Dict:
        if mint not in self._data:
            self._data[mint] = {
                "volumes": deque(maxlen=20),
                "buys": deque(maxlen=20),
                "sells": deque(maxlen=20),
                "timestamps": deque(maxlen=20),
                "last_update": 0,
            }
        return self._data[mint]

    async def update(self, mint: str):
        data = await get_token_data(mint)
        if not data:
            return
        d = self._get_or_create(mint)
        d["volumes"].append(data.get("volume_h24", 0))
        d["buys"].append(data.get("txns_h24_buys", 0))
        d["sells"].append(data.get("txns_h24_sells", 0))
        d["timestamps"].append(time.time())
        d["last_update"] = time.time()

    def analyze(self, mint: str) -> Dict:
        d = self._data.get(mint, {})
        if not d or not d.get("volumes"):
            return {
                "flow_score": 50,
                "buy_ratio": 0.5,
                "vol_spike": 1.0,
                "trend": "neutral"
            }

        vols = list(d["volumes"])
        buys_list = list(d["buys"])
        sells_list = list(d["sells"])

        # Volume spike detection
        vol_spike = 1.0
        if len(vols) >= 2 and vols[-2] > 0:
            vol_spike = vols[-1] / vols[-2]

        # Buy ratio
        total_buys = sum(buys_list[-5:]) if buys_list else 0
        total_sells = sum(sells_list[-5:]) if sells_list else 0
        total_txns = total_buys + total_sells
        buy_ratio = total_buys / total_txns if total_txns > 0 else 0.5

        # Flow score (0-100)
        score = 50
        if vol_spike >= self.spike_threshold:
            score += 20
        if buy_ratio > 0.65:
            score += 20
        elif buy_ratio < 0.35:
            score -= 20

        # Volume trend
        if len(vols) >= 3:
            recent = statistics.mean(vols[-3:])
            older = statistics.mean(vols[:3]) if len(vols) > 3 else recent
            if older > 0:
                vol_trend = (recent - older) / older
                score += min(15, int(vol_trend * 30))

        trend = "bullish" if score > 65 else "bearish" if score < 35 else "neutral"

        return {
            "flow_score": max(0, min(100, score)),
            "buy_ratio": buy_ratio,
            "vol_spike": vol_spike,
            "trend": trend,
        }

class SmartMoneyDetector:
    """Detects whale / smart money movements in token data."""
    def __init__(self, large_tx_threshold_usd: float = 10_000):
        self.threshold = large_tx_threshold_usd
        self._history: Dict[str, List] = defaultdict(list)

    def _get_or_create(self, mint: str) -> List:
        return self._history[mint]

    async def analyze(self, mint: str, data: Dict) -> Dict:
        result = {
            "signal": "neutral",
            "confidence": 0.0,
            "whale_txns": 0,
            "large_volume": False,
        }
        try:
            vol = data.get("volume_h24", 0)
            mc = data.get("market_cap", 0)
            buys = data.get("txns_h24_buys", 0)
            sells = data.get("txns_h24_sells", 0)

            if vol <= 0 or mc <= 0:
                return result

            # Check for disproportionately large volume
            vol_ratio = vol / mc
            if vol_ratio > 5:
                result["large_volume"] = True

            # Estimate avg tx size
            total_txns = buys + sells
            if total_txns > 0:
                avg_tx_usd = vol / total_txns
                if avg_tx_usd > self.threshold:
                    result["whale_txns"] = int(total_txns * (avg_tx_usd / self.threshold))

            # Buy pressure from whales
            buy_ratio = buys / total_txns if total_txns > 0 else 0.5
            if result["whale_txns"] > 0 and buy_ratio > 0.6:
                result["signal"] = "whale_accumulation"
                result["confidence"] = min(0.9, buy_ratio * vol_ratio / 10)
            elif result["whale_txns"] > 0 and buy_ratio < 0.4:
                result["signal"] = "whale_dumping"
                result["confidence"] = min(0.9, (1 - buy_ratio) * vol_ratio / 10)

            self._history[mint].append({
                "ts": time.time(),
                "signal": result["signal"],
                "vol": vol,
            })
            if len(self._history[mint]) > 50:
                self._history[mint] = self._history[mint][-50:]

        except Exception as e:
            log.debug(f"SmartMoneyDetector error: {e}")
        return result


