        now = time.time()
        recent_errors = [e for e in self._errors if now - e["ts"] < 3600]
        recent_ai = [a for a in self._ai_usage if now - a["ts"] < 3600]
        avg_ai_time = (statistics.mean(a["response_time"] for a in recent_ai)
                       if recent_ai else 0)
