        self._browser_tasks.append({
            "url": url, "success": success,
            "duration": duration, "ts": time.time()
        })
        self._url_reliability[url].append(success)
        if len(self._url_reliability[url]) > 20:
            self._url_reliability[url] = self._url_reliability[url][-20:]

    async def record_error(self, module: str, error_msg: str):
        self._errors.append({
