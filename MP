class EarlyConfirmationDetector:
    """Detects early confirmation signals before entering a position."""
    def __init__(self):
        self._data: Dict[str, Dict] = {}

    def update(self, mint: str, volume: float, buy_pressure: float):
        if mint not in self._data:
            self._data[mint] = {
                "volumes": deque(maxlen=10),
                "buy_pressures": deque(maxlen=10),
                "first_seen": time.time(),
            }
        self._data[mint]["volumes"].append(volume)
        self._data[mint]["buy_pressures"].append(buy_pressure)

    def analyze(self, mint: str) -> Dict:
        d = self._data.get(mint, {})
        if not d or not d.get("volumes"):
            return {"confirmed": False, "reason": "no_data"}

        vols = list(d["volumes"])
        buys = list(d["buy_pressures"])
        age_min = (time.time() - d.get("first_seen", time.time())) / 60

        # Need at least 2 data points
        if len(vols) < 2:
            return {"confirmed": False, "reason": "insufficient_data"}

        # Volume must be increasing
        vol_increasing = vols[-1] > vols[-2] if len(vols) >= 2 else False

        # Buy pressure > 0.55
        avg_buy = statistics.mean(buys[-3:]) if len(buys) >= 3 else buys[-1]
        strong_buy = avg_buy > 0.55

        # Not too old (within 4 hours of first signal)
        not_stale = age_min < 240

        confirmed = vol_increasing and strong_buy and not_stale
        reason = ("ok" if confirmed else
                  f"vol_up={vol_increasing} buy={avg_buy:.2f} age={age_min:.1f}m")

        return {
            "confirmed": confirmed,
            "reason": reason,
            "vol_trend": "up" if vol_increasing else "down",
            "avg_buy_pressure": avg_buy,
            "age_min": age_min,
        }

