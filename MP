class EnhancedRiskManager:
    """Risk management with kill switch, daily loss limits, position limits."""
    def __init__(
        self,
        max_open_positions: int = 3,
        daily_loss_limit: float = -8.0,
        consecutive_loss_limit: int = 5,
        db_path: str = DB_FILE
    ):
        self.max_open_positions = max_open_positions
        self.daily_loss_limit = daily_loss_limit
        self.consecutive_loss_limit = consecutive_loss_limit
        self.db_path = db_path
        self._daily_loss_pct = 0.0
        self._consecutive_losses = 0
        self._kill_switch_active = False
        self._init_table()

    def _init_table(self):
        with sqlite3.connect(self.db_path) as conn:
            conn.execute("""
            CREATE TABLE IF NOT EXISTS risk_state (
                key TEXT PRIMARY KEY, value REAL, date TEXT
            )""")

    def _get_today(self) -> str:
        return datetime.now().strftime("%Y-%m-%d")

    def record_loss(self, loss_pct: float):
        if loss_pct >= 0:
            self._consecutive_losses = 0
            return
        self._consecutive_losses += 1
        self._daily_loss_pct += loss_pct
        today = self._get_today()
        try:
            with sqlite3.connect(self.db_path) as conn:
                conn.execute(
                    "INSERT OR REPLACE INTO risk_state VALUES (?,?,?)",
                    ("daily_loss", self._daily_loss_pct, today)
                )
                conn.execute(
                    "INSERT OR REPLACE INTO risk_state VALUES (?,?,?)",
                    ("consecutive_losses", self._consecutive_losses, today)
                )
        except Exception:
            pass

    def is_kill_switch_active(self) -> bool:
        if self._kill_switch_active:
            return True
        if self._daily_loss_pct <= self.daily_loss_limit:
            self._kill_switch_active = True
            log.warning(f"Risk kill switch: daily loss {self._daily_loss_pct:.1f}%")
            return True
        if self._consecutive_losses >= self.consecutive_loss_limit:
            self._kill_switch_active = True
            log.warning(f"Risk kill switch: {self._consecutive_losses} consecutive losses")
            return True
        return False

    def can_open_new_position(self, current_positions: int) -> bool:
        return (not self.is_kill_switch_active() and
                current_positions < self.max_open_positions)

    def reset_daily(self):
        self._daily_loss_pct = 0.0
        self._consecutive_losses = 0
        self._kill_switch_active = False

