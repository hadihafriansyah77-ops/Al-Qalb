class AdaptiveValidator:
    """Multi-factor validator that adapts thresholds based on performance."""
    def __init__(self, min_score: int = 60):
        self.min_score = min_score
        self._recent_validations: deque = deque(maxlen=50)
        self._recent_outcomes: deque = deque(maxlen=50)

    async def validate(
        self, data: Dict, intel_report: Dict, mint: str
    ) -> Tuple[bool, int, str, Dict]:
        """Returns: (valid, score, message, details)"""
        details = {}
        score = adaptive_scorer.score(data)
        details["adaptive_score"] = score

        # Liquidity check
        liquidity = data.get("liquidity_usd", 0)
        if liquidity < 5_000:
            return False, score, "insufficient_liquidity", details

        # Volume check
        volume = data.get("volume_h24", 0)
        if volume < 1_000:
            return False, score, "insufficient_volume", details

        # Age check (skip if too old or too new)
        # (provided by scan_meme_coins context)

        # Intel report checks
        whale_sentiment = intel_report.get("whale_sentiment", "neutral")
        if whale_sentiment == "bearish":
            score -= 15
            details["whale_penalty"] = -15

        smart_money = intel_report.get("smart_money", False)
        if smart_money:
            score += 10
            details["smart_money_bonus"] = 10

        # Adjust threshold based on recent performance
        effective_min = self.min_score
        if len(self._recent_outcomes) >= 10:
            recent_wins = sum(1 for o in list(self._recent_outcomes)[-10:]
                              if o > 0)
            win_rate = recent_wins / 10
            if win_rate < 0.4:
                effective_min = int(self.min_score * 1.1)  # raise bar
            elif win_rate > 0.7:
                effective_min = int(self.min_score * 0.95)  # lower bar

        valid = score >= effective_min
        msg = "ok" if valid else f"score_too_low({score}<{effective_min})"
        self._recent_validations.append({"mint": mint, "score": score,
                                         "valid": valid, "ts": time.time()})
        return valid, score, msg, details

    def record_outcome(self, profit_pct: float):
        self._recent_outcomes.append(profit_pct)

