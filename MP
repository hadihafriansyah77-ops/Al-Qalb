class RealTimeMonitor:
    """Monitors active positions and sends periodic status alerts."""
    def __init__(self, auto_trader: 'AutoTrader', chat_id: int):
        self.trader = auto_trader
        self.chat_id = chat_id
        self._last_alert = 0

    async def run(self):
        while self.trader.active and not kill_check():
            await asyncio.sleep(60)  # every 60s
            try:
                await self.send_status_alert()
            except Exception as e:
                log.debug(f"RealTimeMonitor error: {e}")

    async def send_status_alert(self):
        now = time.time()
        if now - self._last_alert < 300:  # max every 5 min
            return
        self._last_alert = now

        positions = self.trader.positions
        if not positions:
            return

        msg = "📊 POSITION MONITOR\n\n"
        for mint, pos in list(positions.items()):
            data = await get_token_data(mint)
            if not data:
                continue
            entry = pos.get("entry_price", 0)
            current = data.get("price_usd", 0)
            if entry > 0 and current > 0:
                pnl = (current - entry) / entry * 100
                age = (now - pos.get("ts", now)) / 3600
                emoji = "🟢" if pnl > 0 else "🔴"
                msg += (f"{emoji} {mint[:12]}...\n"
                        f"   Entry: {entry:.8f} | Now: {current:.8f}\n"
                        f"   PnL: {pnl:+.1f}% | Age: {age:.1f}h\n\n")

        if len(msg) > 50:
            try:
                await bot.send_message(self.chat_id, msg, parse_mode=None)
            except Exception:
                pass

class EmergencySafeguard:
    """Emergency stop for catastrophic loss scenarios."""
    def __init__(
        self,
        auto_trader: 'AutoTrader',
        max_daily_loss_pct: float = -8.0,
        max_consecutive_losses: int = 5
    ):
        self.trader = auto_trader
        self.max_daily_loss = max_daily_loss_pct
        self.max_consecutive_losses = max_consecutive_losses
        self._daily_loss = 0.0
        self._consecutive = 0
        self._triggered = False
        self._results: deque = deque(maxlen=20)

    async def check_and_emergency_stop(self, chat_id: int) -> bool:
        if self._triggered:
            return True
        if self._daily_loss <= self.max_daily_loss:
            self._triggered = True
            self.trader.stop()
            try:
                await bot.send_message(
                    chat_id,
                    f"🚨 EMERGENCY STOP\n"
                    f"Daily loss: {self._daily_loss:.1f}% "
                    f"(limit: {self.max_daily_loss}%)\n"
                    f"All trading halted."
                )
            except Exception:
                pass
            audit_log("emergency_stop", f"daily_loss={self._daily_loss:.1f}%")
            return True
        if self._consecutive >= self.max_consecutive_losses:
            self._triggered = True
            self.trader.stop()
            try:
                await bot.send_message(
                    chat_id,
                    f"🚨 EMERGENCY STOP\n"
                    f"{self._consecutive} consecutive losses.\n"
                    f"All trading halted."
                )
            except Exception:
                pass
            return True
        return False

    def record_trade_result(self, profit_pct: float) -> bool:
        """Record result and return True if emergency triggered."""
        self._results.append(profit_pct)
        if profit_pct < 0:
            self._consecutive += 1
            self._daily_loss += profit_pct
        else:
            self._consecutive = 0
        return (self._daily_loss <= self.max_daily_loss or
                self._consecutive >= self.max_consecutive_losses)

