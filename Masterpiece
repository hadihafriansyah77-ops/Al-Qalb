def full_benchmark_tier5():
    print("=" * 70)
    print("  QUANTUM NEURAL DNA — TIER 5 AUTOPOIETIC BENCHMARK")
    print("=" * 70)

    LATENT_DIM = 512
    DNA_SIZE = 256
    N_HEADS = 8
    EPOCHS = 20
    N_SAMPLES = 500

    X, y = load_mnist_subset(N_SAMPLES)
    if X.shape[1] > LATENT_DIM:
        X_reduced = X[:, :LATENT_DIM]
    else:
        X_reduced = np.pad(X, ((0, 0), (0, LATENT_DIM - X.shape[1])))

    # --- Build Tier 5 stack ---
    dna = Tier5AutopoieticDNA(dna_size=DNA_SIZE, latent_dim=LATENT_DIM, n_heads=N_HEADS)
    mm  = ThreeLevelMemoryManager(l1_size_mb=50, l2_size_mb=200)
    causal_engine = CausalReasoningEngine(dna)
    governor = AutopoieticGovernor(dna, mm, causal_engine)
    model = DNA_MLP(dna, input_dim=LATENT_DIM, hidden_dim=LATENT_DIM, output_dim=10)
    trainer = ESTrainer(dna, sigma=0.1, lr=0.05, pop_size=10)

    # Seed causal state
    causal_engine.last_state = X_reduced[:1]

    # [7] Start autonomous daemon
    governor.start_autonomous(interval_seconds=2.0)

    total_dna_params = dna.dna.size
    generated_params = (LATENT_DIM * LATENT_DIM) + (LATENT_DIM * 10)
    compression_ratio = generated_params / total_dna_params

    print(f"\n📊 Tier 5 Configuration:")
    print(f"   DNA: {DNA_SIZE} × {LATENT_DIM} = {total_dna_params:,} params")
    print(f"   n_heads: {N_HEADS} (multi-rank synthesis)")
    print(f"   Generated: ~{generated_params:,} params")
    print(f"   Compression Ratio: {compression_ratio:.1f}:1")
    print(f"   Gene Sparsity: {SPARSITY_GENES*100:.0f}% active")
    print(f"   Weight Sparsity: {SPARSITY_WEIGHTS*100:.0f}% zero")
    print(f"   Quantization: {QUANTIZATION_BITS}-bit")
    print("-" * 70)

    best_acc = 0.0
    for epoch in range(EPOCHS):
        start = time.time()
        loss = trainer.train_step(model, X_reduced, y)
        metrics = governor.optimize()

        # Feed causal engine with current state
        idx = np.random.randint(0, N_SAMPLES)
        causal_engine.observe_intervention(
            action="train_epoch",
            state_before=X_reduced[:1],
            state_after=X_reduced[idx:idx+1],
            outcome="training"
        )

        if epoch % 5 == 0 or epoch == EPOCHS - 1:
            logits = model.forward(X_reduced)
            acc = float(np.mean(np.argmax(logits, axis=1) == y))
            best_acc = max(best_acc, acc)
            print(f"Epoch {epoch:2d} | Loss: {loss:.4f} | Acc: {acc:.4f} | "
                  f"RAM: {metrics['ram_gb']:.3f}GB | "
                  f"n_heads={dna.n_heads} | dna_size={dna.dna_size} | "
                  f"Time: {time.time()-start:.2f}s")

    # Final metrics
    logits = model.forward(X_reduced)
    final_acc = float(np.mean(np.argmax(logits, axis=1) == y))
    final_ram = governor.monitor()["ram_gb"]

    print(f"\n{'='*70}")
    print(f"✅ Final Accuracy:      {final_acc:.4f}   (best: {best_acc:.4f})")
    print(f"💾 Final RAM Usage:     {final_ram:.4f} GB")
    print(f"📦 Compression Ratio:   {compression_ratio:.0f}:1")
    print(f"🧬 Final n_heads:       {dna.n_heads}")
    print(f"🔬 Final dna_size:      {dna.dna_size}")
    print(f"📊 Causal genes tracked:{len(causal_engine.causal_graph)}")
    print(f"🌱 Specialists spawned: {len(dna.get_specialists())}")
    print(f"🔄 Mutation log lines:  {len(dna._mutation_log)}")

    simulated_405b_ram = 810
    projected_ram = simulated_405b_ram / compression_ratio
    print(f"🚀 Projection 405B equivalent: {projected_ram:.1f} GB RAM")

    # Demo counterfactual query on top causal genes
    top_genes = causal_engine._get_top_causal_genes(3)
    if top_genes:
        gene_ids = [g for g, _ in top_genes]
        print(f"\n🔬 Demo Counterfactual Query for genes {gene_ids}:")
        causal_engine.counterfactual_query(gene_ids, X_reduced[:1])

    # Demo child DNA synthesis
    print("\n🧬 Demo Recursive DNA Synthesis:")
    child = dna.synthesize_child_dna(X_reduced[:1], specialization="mnist_specialist")
    print(f"   Child DNA: size={child.dna_size}, heads={child.n_heads}")

    # Stop daemon
    governor.stop_autonomous()
    print(f"{'='*70}\n")

    return dna, governor, causal_engine, final_acc, compression_ratio


