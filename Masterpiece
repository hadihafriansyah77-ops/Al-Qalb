    else:
        X_reduced = np.pad(X, ((0,0), (0, LATENT_DIM - X.shape[1])))
    
    dna = QuantumSparseDNA(dna_size=DNA_SIZE, latent_dim=LATENT_DIM)
    mm = ThreeLevelMemoryManager(l1_size_mb=50, l2_size_mb=200)
    model = DNA_MLP(dna, input_dim=LATENT_DIM, hidden_dim=LATENT_DIM, output_dim=10)
    trainer = ESTrainer(dna, sigma=0.1, lr=0.05, pop_size=10)
    governor = MetaGovernor(dna, mm)
    
    total_dna_params = dna.dna.size
    generated_params = (LATENT_DIM * LATENT_DIM) + (LATENT_DIM * 10)
    compression_ratio = generated_params / total_dna_params
    
    print(f"\n📊 Konfigurasi:")
    print(f"   DNA: {DNA_SIZE} x {LATENT_DIM} = {total_dna_params} params")
    print(f"   Generated: ~{generated_params} params")
    print(f"   Compression Ratio: {compression_ratio:.2f}:1")
    print(f"   Gene Sparsity: {SPARSITY_GENES*100:.0f}% aktif")
    print(f"   Weight Sparsity: {SPARSITY_WEIGHTS*100:.0f}% zero")
    print(f"   Quantization: {QUANTIZATION_BITS}-bit")
    print("-" * 70)
    
    for epoch in range(EPOCHS):
        start = time.time()
        loss = trainer.train_step(model, X_reduced, y)
        metrics = governor.optimize()
        
        if epoch % 5 == 0:
            logits = model.forward(X_reduced)
            acc = np.mean(np.argmax(logits, axis=1) == y)
            print(f"Epoch {epoch:2d} | Loss: {loss:.4f} | Acc: {acc:.4f} | RAM: {metrics['ram_gb']:.3f}GB | Time: {time.time()-start:.2f}s")
    
    logits = model.forward(X_reduced)
    final_acc = np.mean(np.argmax(logits, axis=1) == y)
    final_ram = governor.monitor()["ram_gb"]
    
    print(f"\n✅ Final Accuracy: {final_acc:.4f}")
    print(f"💾 Final RAM Usage: {final_ram:.3f} GB")
    print(f"📦 Compression Ratio: {compression_ratio:.0f}:1")
    
    # Simulasi proyeksi ke 405B
    simulated_405b_ram = 810  # GB (FP16)
    projected_ram = simulated_405b_ram / compression_ratio
    print(f"🚀 Proyeksi 405B equivalent: {projected_ram:.1f} GB RAM")
    
    return dna, final_acc, compression_ratio

