def load_mnist_subset(n_samples: int = 1000):
    url = ("https://github.com/mnielsen/neural-networks-and-deep-learning"
           "/raw/master/data/mnist.pkl.gz")
    filename = "mnist.pkl.gz"
    if not os.path.exists(filename):
        print(f"📥 Downloading MNIST...")
        urllib.request.urlretrieve(url, filename)
    with gzip.open(filename, 'rb') as f:
        train_set, _, _ = pickle.load(f, encoding='latin1')
    X, y = train_set[0][:n_samples], train_set[1][:n_samples]
    return X.astype(np.float32), y.astype(np.int32)


