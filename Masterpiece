class EventBus:
    def __init__(self):
        self._handlers: Dict[str, List[Callable]] = {}
        self._history: deque = deque(maxlen=2000)

    def subscribe(self, event: str, handler: Callable):
        if event not in self._handlers:
            self._handlers[event] = []
        if handler not in self._handlers[event]:
            self._handlers[event].append(handler)

    def publish(self, event: str, data: dict):
        self._history.append({"event": event, "data": data, "ts": time.time()})
        for handler in self._handlers.get(event, []):
            try:
                handler(data)
            except Exception as e:
                print(f"[EventBus ERROR] [{event}]: {e}")

    def get_history(self, event: str = None, limit: int = 50) -> List[dict]:
        h = list(self._history)
        if event:
            h = [x for x in h if x["event"] == event]
        return h[-limit:]

event_bus = EventBus()


