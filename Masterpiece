        event_bus.publish("child_dna_spawned", {
            "child_id": child_id, "dna_size": child_size,
            "n_heads": child_heads, "specialization": specialization
        })

        # Persist child to disk
        child_path = os.path.join(SPECIALIST_DIR, f"{child_id}.npy")
        np.save(child_path, child.dna)

        return child

    def get_specialists(self) -> Dict[str, 'Tier5AutopoieticDNA']:
        return self._specialists

    # ----------------------------------------------------------
    # [5] AUTOPOIETIC MUTATION — architecture self-modifies
    # ----------------------------------------------------------
    def autopoietic_mutate(self, win_rate: float, volatility: float,
                           avg_loss: float):
        """
        Self-modifying architecture. Called by AutopoieticGovernor.
        Mutates n_heads, dna_size, sparsity without human input.
        """
        changed = False

        # Rule 1: Low win-rate + high volatility → more heads (richer representation)
        if win_rate < WIN_RATE_THRESHOLD and volatility > VOLATILITY_THRESHOLD:
            new_heads = min(MAX_N_HEADS, self.n_heads + 4)
            if new_heads != self.n_heads:
                old = self.n_heads
                self.n_heads = new_heads
                self.head_dim = self.latent_dim // self.n_heads
                self._log_mutation(f"📈 n_heads: {old} → {self.n_heads} (volatile market detected)")
                changed = True

        # Rule 2: Very low win-rate → expand gene pool
        if win_rate < 0.35:
            new_size = min(MAX_DNA_SIZE, int(self.dna_size * 1.25))
            if new_size != self.dna_size:
                extra = new_size - self.dna_size
                extra_genes = np.random.randn(extra, self.latent_dim).astype(np.float16) * 0.01
                self.dna = np.vstack([self.dna, extra_genes])
                old = self.dna_size
                self.dna_size = new_size
                self._log_mutation(f"🧬 dna_size expanded: {old} → {self.dna_size} (exploration mode)")
                changed = True

        # Rule 3: High win-rate → compress (exploit, reduce noise)
        if win_rate > 0.70 and self.dna_size > MIN_DNA_SIZE * 2:
            new_size = max(MIN_DNA_SIZE, int(self.dna_size * 0.85))
            if new_size != self.dna_size:
                old = self.dna_size
                self.dna = self.dna[:new_size]
                self.dna_size = new_size
                self._log_mutation(f"🗜️  dna_size compressed: {old} → {self.dna_size} (exploit mode)")
                changed = True

        # Rule 4: Large average loss → tighten gene sparsity (more selective)
        if avg_loss > 0.8:
            new_sp = min(0.05, self.current_sparsity_genes * 1.3)
            if abs(new_sp - self.current_sparsity_genes) > 0.001:
                old = self.current_sparsity_genes
                self.current_sparsity_genes = new_sp
                self._log_mutation(f"🔬 gene_sparsity: {old:.4f} → {new_sp:.4f} (precision mode)")
                changed = True

        # Rule 5: Small average loss → widen sparsity (explore more genes)
        if avg_loss < 0.3 and self.current_sparsity_genes > SPARSITY_GENES:
            new_sp = max(SPARSITY_GENES, self.current_sparsity_genes * 0.9)
            self.current_sparsity_genes = new_sp

        if changed:
            self.clear_cache()
            event_bus.publish("autopoietic_mutation", {
                "n_heads": self.n_heads, "dna_size": self.dna_size,
                "sparsity_genes": self.current_sparsity_genes, "win_rate": win_rate
            })

    def _log_mutation(self, msg: str):
        ts = time.strftime("%H:%M:%S")
