class Tier5AutopoieticDNA:
    """
    The central nervous system. Autopoietic = self-creating, self-modifying.
    Every forward pass emits a causal gene fingerprint.
    Architecture parameters (n_heads, dna_size, sparsity) mutate autonomously.
    """

    def __init__(self, dna_size: int = 512, latent_dim: int = 512, n_heads: int = 8):
        self.dna_size = dna_size
        self.latent_dim = latent_dim
        self.n_heads = n_heads
        self.head_dim = latent_dim // n_heads

        # Core gene pool
        self.dna = np.random.randn(dna_size, latent_dim).astype(np.float16) * 0.01

        # Meta-Combiner: learns inter-feature relationships (Tier 3+)
        self.combiner = np.random.randn(latent_dim, latent_dim).astype(np.float16) * 0.01

        # Meta-DNA: encodes mutation rules (Tier 4)
        self.meta_dna = np.random.randn(64, latent_dim).astype(np.float16) * 0.01

        # Dynamic architecture parameters (autopoietic)
        self.current_sparsity_genes = SPARSITY_GENES
        self.current_sparsity_weights = SPARSITY_WEIGHTS

        # Performance tracking for autopoiesis
        self._perf_history: deque = deque(maxlen=200)
        self._mutation_log: List[str] = []
        self._step_count = 0

        # Cache
        self.weight_cache: OrderedDict = OrderedDict()
        self.cache_limit = 30
        self.alpha = 1.0
        self.beta = 0.0

        # Causal fingerprint log: {decision_id -> gene_indices}
        self._causal_fingerprints: deque = deque(maxlen=5000)

        # Specialist archive
        self._specialists: Dict[str, 'Tier5AutopoieticDNA'] = {}

    # ----------------------------------------------------------
    # [1] MULTI-HEAD WEIGHT SYNTHESIS (Tier 3+ / Multi-Rank)
    # ----------------------------------------------------------
    def _multihead_synthesize(self, active_genes: np.ndarray) -> np.ndarray:
        """
        Produces a weight matrix of rank up to n_heads.
        Capacity is n_heads times higher than rank-1 outer product.
        Each head attends to a different subspace of the gene pool.
        """
        K, D = active_genes.shape
        effective_heads = min(self.n_heads, K)
        head_dim = D // effective_heads

        w = np.zeros((D, D), dtype=np.float32)

        for h in range(effective_heads):
            start = h * head_dim
            end = start + head_dim if h < effective_heads - 1 else D

            # Head h: mean projection of a unique gene subset
            chunk_size = max(1, K // effective_heads)
            g_start = h * chunk_size
            g_end = min((h + 1) * chunk_size, K)
            head_genes = active_genes[g_start:g_end].astype(np.float32)

            a = head_genes.mean(axis=0)               # [D]
            b = active_genes[(h + 1) % K].astype(np.float32)  # cross-gene view

            # Outer product in head subspace only → low overhead
            a_sub = a[start:end]
            b_sub = b[start:end]
            sub_outer = np.outer(a_sub, b_sub)        # [head_dim × head_dim]

            # Place in full matrix (block diagonal structure → sparse naturally)
            sub_h = end - start
            w[start:end, start:end] += sub_outer[:sub_h, :sub_h]

        # Apply Meta-Combiner: learns cross-head interactions
        w = w @ self.combiner.astype(np.float32)

        # Weight sparsity
        threshold = np.percentile(np.abs(w), self.current_sparsity_weights * 100)
        w[np.abs(w) < threshold] = 0.0

        # 2-bit quantization simulation
        w = np.round(w * 3) / 3.0

        norm = np.linalg.norm(w) + 1e-8
        w = w / norm
        return (self.alpha * w + self.beta).astype(np.float16)

    # ----------------------------------------------------------
    # Gene selection (Quantum-Inspired, same as base)
    # ----------------------------------------------------------
    def _get_input_embedding(self, input_vec: np.ndarray) -> np.ndarray:
        if input_vec.ndim == 1:
            input_vec = input_vec.reshape(1, -1)
        if input_vec.shape[1] != self.latent_dim:
            if input_vec.shape[1] > self.latent_dim:
                input_vec = input_vec[:, :self.latent_dim]
            else:
                pad = np.zeros((input_vec.shape[0], self.latent_dim - input_vec.shape[1]))
                input_vec = np.hstack([input_vec, pad])
        return input_vec.astype(np.float16)

    def select_genes_quantum(self, input_vec: np.ndarray,
                             sparsity: float = None) -> np.ndarray:
        sp = sparsity if sparsity is not None else self.current_sparsity_genes
        scores = (input_vec @ self.dna.T).astype(np.float32)
        k = max(1, int(self.dna_size * sp))
        flat = scores[0] if scores.ndim > 1 else scores
        indices = np.argpartition(flat, -k)[-k:]
        return indices

    # ----------------------------------------------------------
    # Forward pass with [3] CAUSAL FINGERPRINT LOGGING
    # ----------------------------------------------------------
    def forward(self, input_vec: np.ndarray, layer_id: int = 0,
                decision_id: str = None) -> Tuple[np.ndarray, np.ndarray]:
        input_emb = self._get_input_embedding(input_vec)
        cache_key = f"L{layer_id}_{hash(input_emb.tobytes()) % 100000}"

        if cache_key in self.weight_cache:
            self.weight_cache.move_to_end(cache_key)
            cached_w, cached_gidx = self.weight_cache[cache_key]
            return cached_w, cached_gidx

        gene_indices = self.select_genes_quantum(input_emb)
        active_genes = self.dna[gene_indices]
        w = self._multihead_synthesize(active_genes)

        # [3] CAUSAL LOGGING — record genetic fingerprint
        fingerprint = {
            "ts": time.time(),
            "layer_id": layer_id,
            "decision_id": decision_id or f"auto_{self._step_count}",
            "gene_indices": gene_indices.tolist(),
            "n_active": len(gene_indices),
            "n_heads": self.n_heads,
            "dna_size": self.dna_size,
        }
        self._causal_fingerprints.append(fingerprint)

        # Async append to causal log file
        try:
            with open(CAUSAL_LOG_FILE, 'a') as f:
                f.write(json.dumps(fingerprint) + "\n")
        except Exception:
            pass

        self.weight_cache[cache_key] = (w, gene_indices)
        if len(self.weight_cache) > self.cache_limit:
            self.weight_cache.popitem(last=False)

        self._step_count += 1
        return w, gene_indices

    def clear_cache(self):
        self.weight_cache.clear()

    # ----------------------------------------------------------
    # [2] RECURSIVE DNA — synthesize_child_dna (Tier 4)
    # ----------------------------------------------------------
    def synthesize_child_dna(self, context: np.ndarray,
                             specialization: str = "generic") -> 'Tier5AutopoieticDNA':
        """
        Synthesise a specialist child DNA from this parent + context signal.
        Child is smaller (more focused), inherits meta_dna lineage.
        """
        child_size = max(MIN_DNA_SIZE, self.dna_size // 2)
        child_heads = max(MIN_N_HEADS, self.n_heads // 2)

        child = Tier5AutopoieticDNA(
            dna_size=child_size,
            latent_dim=self.latent_dim,
            n_heads=child_heads
        )

        # Synthesize child genes from meta-DNA + context signal
        ctx_emb = self._get_input_embedding(context)
        w_meta, _ = self.forward(ctx_emb, layer_id=9999, decision_id="child_synthesis")
        raw_child_genes = self.dna[:child_size].copy() + np.random.randn(child_size, self.latent_dim).astype(np.float16) * 0.01
        child.dna[:raw_child_genes.shape[0]] = raw_child_genes.astype(np.float16)
        child.meta_dna = self.meta_dna.copy()

        child_id = f"specialist_{specialization}_{int(time.time())}"
        self._specialists[child_id] = child

        # [6] SELF-REFLECTION LOG
