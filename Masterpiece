# LAYER 11: EVOLUTIONARY TRAINER (ES)
# ==============================================================
def softmax(x: np.ndarray) -> np.ndarray:
    e = np.exp(x - np.max(x, axis=1, keepdims=True))
    return e / (np.sum(e, axis=1, keepdims=True) + 1e-8)

def cross_entropy_loss(logits: np.ndarray, targets: np.ndarray) -> float:
    probs = softmax(logits)
    n = logits.shape[0]
    return -np.sum(np.log(probs[np.arange(n), targets] + 1e-8)) / n

class ESTrainer:
    def __init__(self, dna: Tier5AutopoieticDNA, sigma: float = 0.1,
                 lr: float = 0.05, pop_size: int = 10):
        self.dna = dna
        self.sigma = sigma
        self.lr = lr
        self.pop_size = pop_size
        self._train_steps = 0

    def train_step(self, model: 'DNA_MLP', X: np.ndarray, y: np.ndarray) -> float:
        noise = np.random.randn(self.pop_size, *self.dna.dna.shape).astype(np.float16)
        rewards = np.zeros(self.pop_size)
        original = self.dna.dna.copy()

        for i in range(self.pop_size):
            self.dna.dna = original + self.sigma * noise[i]
            self.dna.clear_cache()
            logits = model.forward(X)
            loss = cross_entropy_loss(logits, y)
            rewards[i] = -loss

        if np.std(rewards) > 1e-8:
            rewards = (rewards - np.mean(rewards)) / np.std(rewards)

        weighted = np.zeros_like(original, dtype=np.float32)
        for i in range(self.pop_size):
            weighted += rewards[i] * noise[i].astype(np.float32)

        self.dna.dna = (original.astype(np.float32) +
                        self.lr / (self.pop_size * self.sigma) * weighted).astype(np.float16)

        self.dna.clear_cache()
        self._train_steps += 1

        # Compute final loss for event
        final_logits = model.forward(X)
        final_loss = cross_entropy_loss(final_logits, y)

        # Emit epoch_complete event for AutopoieticGovernor
        event_bus.publish("epoch_complete", {
            "loss": final_loss,
            "step": self._train_steps
        })

        return final_loss


