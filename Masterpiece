# LAYER 12: DNA_MLP MODEL
# ==============================================================
class DNA_MLP:
    def __init__(self, dna: Tier5AutopoieticDNA, input_dim: int,
                 hidden_dim: int, output_dim: int):
        self.dna = dna
        self.input_dim = input_dim
        self.hidden_dim = hidden_dim
        self.output_dim = output_dim

    def forward(self, x: np.ndarray) -> np.ndarray:
        w1, g1 = self.dna.forward(x, layer_id=0, decision_id="mlp_l1")
        w1 = w1[:self.hidden_dim, :self.input_dim]
        h = np.maximum(0, x @ w1.T)

        w2, g2 = self.dna.forward(h, layer_id=1, decision_id="mlp_l2")
        w2 = w2[:self.output_dim, :self.hidden_dim]
        return h @ w2.T


