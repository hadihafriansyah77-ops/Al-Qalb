# ★ LAYER 6 — CAUSAL REASONING ENGINE (Tier 5 Core)
#   [3] Causal Logging    — observe_intervention()
#   [4] Counterfactual    — counterfactual_query()
# ==============================================================
class CausalReasoningEngine:
    """
    Models CAUSE → EFFECT relationships between gene activations and outcomes.
    Supports counterfactual simulation: "What if gene #X was inactive?"
    """

    def __init__(self, dna: Tier5AutopoieticDNA):
        self.dna = dna
        # causal_graph[gene_id][outcome] = count
        self.causal_graph: Dict[int, Dict[str, int]] = {}
        self.counterfactual_memory: deque = deque(maxlen=1000)
        self.last_state: Optional[np.ndarray] = None
        self._intervention_log: List[dict] = []

        event_bus.subscribe("trade_closed", self._on_trade)
        event_bus.subscribe("epoch_complete", self._on_epoch)

    def observe_intervention(self, action: str, state_before: np.ndarray,
                             state_after: np.ndarray, outcome: str = "unknown"):
        """
        Records: "When genes {X} were ACTIVE and action {Y} was taken,
        the outcome was {Z}."
        """
        self.last_state = state_after.copy()
        emb_before = self.dna._get_input_embedding(state_before)
        emb_after  = self.dna._get_input_embedding(state_after)

        genes_before = set(self.dna.select_genes_quantum(emb_before).tolist())
        genes_after  = set(self.dna.select_genes_quantum(emb_after).tolist())

        activated = genes_after - genes_before
        deactivated = genes_before - genes_after

        record = {
            "ts": time.time(), "action": action, "outcome": outcome,
            "activated": list(activated), "deactivated": list(deactivated)
        }
        self._intervention_log.append(record)
        self.counterfactual_memory.append(record)

        for g in activated:
            if g not in self.causal_graph:
                self.causal_graph[g] = {}
            key = f"{action}:{outcome}"
            self.causal_graph[g][key] = self.causal_graph[g].get(key, 0) + 1

        # [6] SELF-REFLECTION LOG
        if len(self._intervention_log) % 20 == 0:
            top_genes = self._get_top_causal_genes(5)
            print(f"🔬 [CAUSAL ENGINE] Top causal genes: {top_genes}")

    def counterfactual_query(self, gene_ids: List[int],
                             test_state: Optional[np.ndarray] = None) -> dict:
        """
        [4] COUNTERFACTUAL QUERY:
        'What would the output be if genes {gene_ids} were INACTIVE?'

        Returns dict: {gene_id: delta_output, 'summary': str}
        """
        if test_state is None:
            if self.last_state is None:
                return {"error": "No state available for simulation"}
            test_state = self.last_state

        original_dna = self.dna.dna.copy()
        baseline_w, _ = self.dna.forward(test_state, layer_id=0,
                                         decision_id="cf_baseline")
        baseline_output = float(np.linalg.norm(baseline_w))

        results = {}
        for gene_id in gene_ids:
            if gene_id >= self.dna.dna_size:
                continue
            # Intervene: zero-out this gene
            self.dna.dna[gene_id] *= 0
            self.dna.clear_cache()

            cf_w, _ = self.dna.forward(test_state, layer_id=0,
                                       decision_id=f"cf_gene_{gene_id}")
            cf_output = float(np.linalg.norm(cf_w))
            delta = cf_output - baseline_output
            results[gene_id] = {
                "baseline_norm": round(baseline_output, 6),
                "counterfactual_norm": round(cf_output, 6),
                "delta": round(delta, 6),
                "impact_pct": round(abs(delta) / (baseline_output + 1e-8) * 100, 2)
            }

            # Restore
            self.dna.dna = original_dna.copy()
            self.dna.clear_cache()

        # Build human-readable summary
        lines = ["🔬 [COUNTERFACTUAL ANALYSIS]"]
        for gid, info in results.items():
            direction = "↓ DECREASE" if info["delta"] < 0 else "↑ INCREASE"
            lines.append(
                f"  Gene #{gid}: If inactive → output {direction} by "
                f"{info['impact_pct']:.1f}% (Δ={info['delta']:+.4f})"
            )
        summary = "\n".join(lines)
        print(summary)
        results["summary"] = summary

        self.counterfactual_memory.append({"type": "query", "genes": gene_ids,
                                           "results": results, "ts": time.time()})
        return results

    def _get_top_causal_genes(self, n: int = 10) -> List[Tuple[int, int]]:
        totals = {g: sum(v.values()) for g, v in self.causal_graph.items()}
        return sorted(totals.items(), key=lambda x: x[1], reverse=True)[:n]

    def get_effective_genes(self, min_count: int = 3) -> set:
        return {g for g, causes in self.causal_graph.items()
                if sum(causes.values()) >= min_count}

    def explain_decision(self, gene_indices: np.ndarray) -> str:
        """
        Produce a causal explanation for a decision based on gene fingerprint.
        """
        lines = ["📊 [CAUSAL DECISION EXPLANATION]"]
        for rank, gid in enumerate(gene_indices[:5], 1):
            causes = self.causal_graph.get(int(gid), {})
            if causes:
                top_cause = max(causes.items(), key=lambda x: x[1])
                lines.append(f"  #{rank} Gene {gid}: historically linked to "
                             f"'{top_cause[0]}' (n={top_cause[1]})")
            else:
                lines.append(f"  #{rank} Gene {gid}: new / unexplored gene")
        return "\n".join(lines)

    def _on_trade(self, data: dict):
        profit = data.get("profit_pct", 0)
        outcome = "win" if profit > 0 else "loss"
        if self.last_state is not None:
            self.observe_intervention(
                action=data.get("reason", "trade"),
                state_before=self.last_state,
                state_after=self.last_state,
                outcome=outcome
            )

    def _on_epoch(self, data: dict):
        loss = data.get("loss", 1.0)
        outcome = "good" if loss < 0.5 else "bad"
        if self.last_state is not None:
            self.observe_intervention(
                action="epoch_train",
                state_before=self.last_state,
                state_after=self.last_state,
                outcome=outcome
            )


