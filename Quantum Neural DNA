import glob
import hashlib

class OmniscientDNAEngine:
    """
    Mengintegrasikan 260+ Domain Pengetahuan (A-Z10) ke dalam sistem DNA.
    """
    def __init__(self, dna_core: QuantumSparseDNA_Torch, brain: IndexedLocalBrain, json_folder: str = "quantum_dna_knowledge"):
        self.dna = dna_core
        self.brain = brain
        self.json_folder = json_folder
        self.domain_vectors = {}  # Cache vector untuk setiap domain
        self.load_all_knowledge()

    def _text_to_dna_seed(self, text: str) -> np.ndarray:
        """Mengubah teks menjadi vektor deterministik menggunakan DNA sebagai hash."""
        # Gunakan SHA256 dari teks sebagai seed untuk random generator DNA
        hash_obj = hashlib.sha256(text.encode('utf-8'))
        seed = int.from_bytes(hash_obj.digest()[:8], 'big')
        np.random.seed(seed)
        # Hasilkan vektor sepanjang latent_dim DNA
        return np.random.randn(self.dna.latent_dim).astype(np.float16)

    def load_all_knowledge(self):
        """Baca semua file JSON dan masukkan ke Local Brain + DNA Cache."""
        print(f"🧬 [Omniscient Engine] Loading knowledge from {self.json_folder}...")
        
        if not os.path.exists(self.json_folder):
            os.makedirs(self.json_folder)
            print(f"⚠️ Folder {self.json_folder} created. Please add JSON files.")
            return

        total_nodes = 0
        for filepath in glob.glob(os.path.join(self.json_folder, "*.json")):
            try:
                with open(filepath, 'r', encoding='utf-8') as f:
                    data = json.load(f)
                
                domain = data.get("domain", "UNKNOWN")
                root = data.get("root_name", "")
                
                for gen_key, gen_data in data.get("generations", {}).items():
                    # Gabungkan semua teks pengetahuan untuk membuat DNA Seed
                    content_text = f"{root} {gen_data.get('name', '')} {' '.join(gen_data.get('principles', []))}"
                    
                    # Simpan di Local Brain (SQLite) untuk retrieval cepat
                    node_id = f"DNA_{domain}_{gen_key}"
                    self.brain.add_knowledge(
                        id=node_id,
                        topic=f"Domain_{domain}",
                        tags=[domain, gen_key, gen_data.get('name', '')[:20]],
                        statement=content_text[:500], # Potong biar nggak berat
                        e_type="domain_knowledge",
                        conf=0.99
                    )
                    
                    # Generate DNA Vector Seed (Simpan di memory cache)
                    # Ini akan digunakan untuk mensintesis bobot spesifik domain
                    vec = self._text_to_dna_seed(content_text)
                    self.domain_vectors[f"{domain}_{gen_key}"] = vec
                    
                    total_nodes += 1
                    
            except Exception as e:
                print(f"❌ Error loading {filepath}: {e}")

        print(f"✅ [Omniscient Engine] Loaded {total_nodes} knowledge domains into DNA space.")

    def query_domain(self, query_text: str, domain_hint: str = None) -> str:
        """
        Fungsi utama untuk menjawab pertanyaan menggunakan DNA yang tepat.
        Ini adalah simulasi 'mengirim pesan di Termux'.
        """
        # 1. Cari di Local Brain dulu (Fast Recall)
        brain_answer = self.brain.answer_from_brain(query_text)
        if brain_answer:
            base_answer = brain_answer
        else:
            base_answer = "🧠 [Quantum Intuition] "

        # 2. Tentukan Domain DNA yang aktif berdasarkan query (Simulasi Router)
        #    Untuk demo, kita cek apakah ada keyword A-Z di query
        activated_domain = None
        query_upper = query_text.upper()
        for char in "ABCDEFGHIJKLMNOPQRSTUVWXYZ":
            if char in query_upper:
                activated_domain = char
                break
        
        if not activated_domain and domain_hint:
            activated_domain = domain_hint

        # 3. Sintesis Bobot Spesifik Domain (The "Akar ke Puncak" Logic)
        if activated_domain:
            # Cari vektor domain terdekat (misal A1, A2...)
            relevant_vec = None
            for key, vec in self.domain_vectors.items():
                if key.startswith(activated_domain):
                    relevant_vec = vec
                    break
            
            if relevant_vec is not None:
                # Gunakan DNA Torch untuk menghasilkan bobot unik untuk domain ini
                # Layer ID kita set tinggi (9000+) sebagai tanda "Meta-Knowledge"
                tensor_vec = torch.from_numpy(relevant_vec).to(device).unsqueeze(0)
                synthesized_weight, _ = self.dna(tensor_vec, layer_id=9000 + ord(activated_domain))
                
                # Simulasi: Bobot ini menentukan "cara berpikir" tentang domain tersebut
                # Kita ambil informasi dari bobot (misal sparsity pattern) untuk flavor jawaban
                sparsity_level = (synthesized_weight == 0).float().mean().item()
                
                depth_level = "akar" if sparsity_level > 0.8 else "puncak"
                base_answer += f"\n\n🌌 [DNA-{activated_domain} | {depth_level} reasoning] "
                base_answer += f"Domain {activated_domain} teraktivasi. (Sparsity: {sparsity_level:.0%})"
            else:
                base_answer += f"\n\n⚠️ Domain {activated_domain} belum memiliki JSON knowledge. Silakan isi folder."
        else:
            base_answer += "\n\n🌐 [General DNA] Tidak ada domain spesifik terdeteksi."

        return base_answer

