if TOKENIZERS_AVAILABLE:
    class DNA_BPETokenizer:
        def __init__(self, dna: QuantumSparseDNA):
            self.dna = dna
            self.tokenizer = Tokenizer(models.BPE())
            self.tokenizer.pre_tokenizer = pre_tokenizers.Sequence([
                pre_tokenizers.Split(
                    pattern=re.compile(r'(?<=[^a-zA-Z0-9])[a-zA-Z0-9]+(?=[^a-zA-Z0-9])|[\d\.]+|[+\-*/=<>!~@#$%^&*()_+{}|:;"\'<>,.?/\\[\\]]')
                ),
                pre_tokenizers.Whitespace()
            ])
            self.vocab_size = 151646
            self._trained = False

        def train_on_corpus(self, text_files: List[str], dna_threshold: float = 0.7):
            high_quality = []
            for file in text_files:
                with open(file, 'r', encoding='utf-8') as f:
                    for line in f:
                        line = line.strip()
                        if not line:
                            continue
                        emb = self._line_to_embedding(line)
                        quality = self.dna.forward(emb)[0].mean()
                        if quality > dna_threshold:
                            high_quality.append(line)
            trainer = trainers.BpeTrainer(
                vocab_size=self.vocab_size,
                special_tokens=["<|im_start|>", "<|im_end|>", "<|thought|>"]
            )
            self.tokenizer.train_from_iterator(high_quality, trainer)
            self._trained = True
            return self.tokenizer

        def _line_to_embedding(self, text: str) -> np.ndarray:
            h = np.zeros(self.dna.latent_dim, dtype=np.float16)
            for i, ch in enumerate(text[:self.dna.latent_dim]):
                h[i] = ord(ch) / 255.0
            return h

        def encode(self, text: str):
            if not self._trained:
                raise RuntimeError("Tokenizer not trained. Call train_on_corpus first.")
            return self.tokenizer.encode(text).ids

        def decode(self, ids):
            return self.tokenizer.decode(ids)

class RotaryPositionalEmbedding(nn.Module):
    def __init__(self, dim: int, max_seq_len: int = 128000, base: float = 10000.0):
        super().__init__()
        self.dim = dim
        self.base = base
        inv_freq = 1.0 / (base ** (torch.arange(0, dim, 2).float() / dim))
        self.register_buffer("inv_freq", inv_freq)

    def forward(self, x, seq_len):
        t = torch.arange(seq_len, device=x.device).type_as(self.inv_freq)
        freqs = torch.einsum("i,j->ij", t, self.inv_freq)
        emb = torch.cat((freqs, freqs), dim=-1)
        return emb.cos(), emb.sin()

class DNA_GroupedQueryAttention(nn.Module):
    def __init__(self, dna: QuantumSparseDNA_Torch, dim: int, num_heads: int, num_kv_heads: int,
                 memory_manager: ThreeLevelMemoryManagerTorch):
        super().__init__()
        self.dna = dna
        self.dim = dim
        self.num_heads = num_heads
        self.num_kv_heads = num_kv_heads
        self.head_dim = dim // num_heads
        self.mm = memory_manager

    def forward(self, x, cos, sin, layer_id):
        b, s, d = x.shape
        cond = x.mean(dim=(0,1))
        wq, _ = self.dna.forward_torch(cond, layer_id*3)
        wk, _ = self.dna.forward_torch(cond, layer_id*3+1)
        wv, _ = self.dna.forward_torch(cond, layer_id*3+2)
        q = F.linear(x, wq[:d,:d])
        k = F.linear(x, wk[:d,:d])
        v = F.linear(x, wv[:d,:d])
        q = q.view(b, s, self.num_heads, self.head_dim).transpose(1,2)
        k = k.view(b, s, self.num_kv_heads, self.head_dim).transpose(1,2)
        v = v.view(b, s, self.num_kv_heads, self.head_dim).transpose(1,2)
        q = self._apply_rope(q, cos, sin)
        k = self._apply_rope(k, cos, sin)
        k = k.repeat_interleave(self.num_heads // self.num_kv_heads, dim=1)
        v = v.repeat_interleave(self.num_heads // self.num_kv_heads, dim=1)
        attn = torch.matmul(q, k.transpose(-2,-1)) * (self.head_dim ** -0.5)
        attn = F.softmax(attn, dim=-1)
        out = torch.matmul(attn, v).transpose(1,2).contiguous().view(b, s, d)
        return out

    def _apply_rope(self, x, cos, sin):
        x1, x2 = x[..., ::2], x[..., 1::2]
        return torch.cat([x1 * cos - x2 * sin, x1 * sin + x2 * cos], dim=-1)

class DNA_SparseMoE(nn.Module):
    def __init__(self, dna: QuantumSparseDNA_Torch, dim: int, num_fine_experts: int = 128,
                 num_shared: int = 2, top_k: int = 8, memory_manager: ThreeLevelMemoryManagerTorch = None):
        super().__init__()
        self.dna = dna
        self.dim = dim
        self.top_k = top_k
        self.mm = memory_manager
        self.gate = nn.Linear(dim, num_fine_experts)
        hidden = dim * 8 // 3
        self.shared = nn.ModuleList([nn.Sequential(nn.Linear(dim, hidden), nn.SiLU(), nn.Linear(hidden, dim)) for _ in range(num_shared)])

    def forward(self, x):
        out = sum(shared(x) for shared in self.shared)
        # Fine-grained MoE di sini bisa ditambahkan kemudian
        return out


