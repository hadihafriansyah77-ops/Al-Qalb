class OpenRouterTeacher:
    """
    Mengakses model gratis OpenRouter untuk menghasilkan data pelatihan berkualitas tinggi.
    """
    def __init__(self, api_key: str):
        self.client = OpenAI(
            base_url="https://openrouter.ai/api/v1",
            api_key=api_key,
        )
        self.free_model = "openrouter/free"  # Akan diarahkan ke model gratis terbaik yang tersedia
        
    def ask(self, prompt: str, max_tokens: int = 2000, temperature: float = 0.7) -> Optional[str]:
        """Mengirim prompt ke model gratis OpenRouter."""
        try:
            response = self.client.chat.completions.create(
                model=self.free_model,
                messages=[{"role": "user", "content": prompt}],
                max_tokens=max_tokens,
                temperature=temperature,
            )
            return response.choices[0].message.content
        except Exception as e:
            print(f"OpenRouter error: {e}")
            return None

class DistillationDatasetGenerator:
    """
    Menghasilkan dataset berkualitas menggunakan prompt yang dirancang khusus.
    """
    def __init__(self, teacher: OpenRouterTeacher):
        self.teacher = teacher
        
    def generate_reasoning_samples(self, num_samples: int = 100) -> List[Tuple[str, str]]:
        """Menghasilkan data reasoning (input -> output)."""
        samples = []
        prompts = [
            "Berikan pertanyaan matematika yang menantang beserta solusi langkah demi langkahnya.",
            "Jelaskan konsep fisika kuantum tentang superposisi dengan bahasa sederhana dan berikan contoh.",
            "Buatlah argumen logis tentang pentingnya kolonisasi Mars, serta sanggahan terhadap argumen kontra.",
            "Tulis kode Python untuk mengimplementasikan algoritma pencarian jalur A* dengan penjelasan.",
            "Analisis perbedaan antara machine learning, deep learning, dan AI generatif beserta contoh aplikasi.",
        ]
        for i in range(num_samples):
            prompt = random.choice(prompts)
            output = self.teacher.ask(prompt)
            if output:
                samples.append((prompt, output))
            time.sleep(1)  # Jeda agar tidak kena rate limit
        return samples
    
    def generate_conversational_samples(self, num_samples: int = 100) -> List[Tuple[str, str]]:
        """Menghasilkan data percakapan asisten."""
        samples = []
        topics = ["teknologi", "sains", "filsafat", "kesehatan", "bisnis", "pendidikan"]
        for i in range(num_samples):
            topic = random.choice(topics)
            prompt = f"Anda adalah asisten AI yang cerdas. Seorang pengguna bertanya tentang {topic}. Berikan jawaban yang informatif, akurat, dan bermanfaat."
            output = self.teacher.ask(prompt)
            if output:
                samples.append((f"User: {topic}", output))
            time.sleep(1)
        return samples

class DNA_KnowledgeDistiller:
    """
    Melatih Quantum Neural DNA menggunakan dataset hasil sulingan dari model besar.
    """
    def __init__(self, dna: QuantumSparseDNA, memory_manager: ThreeLevelMemoryManager, teacher: OpenRouterTeacher):
        self.dna = dna
        self.mm = memory_manager
        self.teacher = teacher
        self.generator = DistillationDatasetGenerator(teacher)
        self.tokenizer = None
        if TOKENIZERS_AVAILABLE:
            try:
                self.tokenizer = DNA_BPETokenizer(dna)
                # Untuk keperluan ini kita tidak perlu training tokenizer dari korpus,
                # kita bisa menggunakan tokenizer standar BPE atau menggunakan simple tokenizer.
            except:
                pass
        self.brain = local_brain
        
    def collect_knowledge(self, num_reasoning: int = 50, num_conversation: int = 50):
        """Mengumpulkan data dari OpenRouter dan menyimpannya ke LocalBrain."""
        print("🧠 Mengumpulkan pengetahuan dari OpenRouter (Free Model)...")
        reasoning_data = self.generator.generate_reasoning_samples(num_reasoning)
        conv_data = self.generator.generate_conversational_samples(num_conversation)
        
        # Simpan ke LocalBrain
        for i, (q, a) in enumerate(reasoning_data):
            self.brain.add_knowledge(
                id=f"reason_{int(time.time())}_{i}",
                topic="reasoning",
                tags=["openrouter", "distilled"],
                statement=f"Q: {q}\nA: {a}",
                e_type="qa_pair",
                conf=0.9
            )
        for i, (q, a) in enumerate(conv_data):
            self.brain.add_knowledge(
                id=f"conv_{int(time.time())}_{i}",
                topic="conversation",
                tags=["openrouter", "distilled"],
                statement=f"{q}\n{a}",
                e_type="dialogue",
                conf=0.9
            )
        print(f"✅ Tersimpan {len(reasoning_data)} reasoning + {len(conv_data)} conversation samples.")
        return reasoning_data + conv_data
    
    def distill_to_dna(self, epochs: int = 10, samples_per_epoch: int = 10):
        """
        Proses distilasi: DNA belajar memprediksi output dari input menggunakan data guru.
        """
        print("\n🎓 Memulai Distilasi Pengetahuan ke DNA...")
        # Ambil semua data dari LocalBrain
        all_data = []
        for topic in ["reasoning", "conversation"]:
            nodes = self.brain.query_by_topic(topic, limit=1000)
            for node in nodes:
                all_data.append(node[3])  # statement
        if not all_data:
            print("Tidak ada data untuk distilasi. Jalankan collect_knowledge dulu.")
            return
        
        # Buat dataset sederhana: untuk setiap statement, kita pisahkan Q dan A
        # Untuk kemudahan, kita akan melatih DNA sebagai autoencoder pada teks guru.
        # Tapi karena DNA saat ini didesain untuk input numerik, kita perlu tokenisasi.
        # Sebagai langkah awal, kita akan latih DNA pada embedding teks.
        print("Membangun dataset embedding...")
        embeddings = []
        for text in all_data[:100]:  # Batasi dulu
            # Tokenisasi sederhana: karakter ke ASCII lalu pad/truncate ke latent_dim
            emb = np.zeros(self.dna.latent_dim, dtype=np.float16)
            for i, ch in enumerate(text[:self.dna.latent_dim]):
                emb[i] = ord(ch) / 255.0
            embeddings.append(emb)
        embeddings = np.array(embeddings)
        
        # Trainer Evolution Strategy untuk belajar merekonstruksi embedding
        class DNA_AutoEncoder:
            def __init__(self, dna, latent_dim):
                self.dna = dna
                self.latent_dim = latent_dim
            def forward(self, x):
                w1, _ = self.dna.forward(x, 0)
                w1 = w1[:self.latent_dim, :self.latent_dim]
                h = np.maximum(0, x @ w1.T)
                w2, _ = self.dna.forward(h, 1)
                w2 = w2[:self.latent_dim, :self.latent_dim]
                return h @ w2.T
        
        model = DNA_AutoEncoder(self.dna, self.dna.latent_dim)
        trainer = ESTrainer(self.dna, sigma=0.05, lr=0.02, pop_size=8)
        
        for epoch in range(epochs):
            # Pilih batch acak
            idx = np.random.choice(len(embeddings), min(samples_per_epoch, len(embeddings)), replace=False)
            X_batch = embeddings[idx]
            # Target = input (autoencoder)
            # Karena ESTrainer.train_step mengharapkan label klasifikasi, kita modifikasi loss untuk MSE
            # Untuk cepat, kita gunakan training loop sederhana
            noise = np.random.randn(trainer.pop_size, *self.dna.dna.shape).astype(np.float16)
            rewards = np.zeros(trainer.pop_size)
            original = self.dna.dna.copy()
            for i in range(trainer.pop_size):
                self.dna.dna = original + trainer.sigma * noise[i]
                self.dna.clear_cache()
                pred = model.forward(X_batch)
                mse = np.mean((pred - X_batch) ** 2)
                rewards[i] = -mse
            rewards = (rewards - np.mean(rewards)) / (np.std(rewards) + 1e-8)
            grad = np.zeros_like(self.dna.dna)
            for i in range(trainer.pop_size):
                grad += rewards[i] * noise[i]
            self.dna.dna = original + trainer.lr / (trainer.pop_size * trainer.sigma) * grad
            self.dna.clear_cache()
            if epoch % 5 == 0:
                pred = model.forward(X_batch)
                mse = np.mean((pred - X_batch) ** 2)
                print(f"Distillation Epoch {epoch:2d} | MSE: {mse:.6f}")
        print("✅ Distilasi selesai. DNA telah menyerap pengetahuan dari model besar.")
    
    def chat(self, user_input: str) -> str:
        """
        Setelah distilasi, DNA dapat digunakan untuk menjawab pertanyaan.
        """
        # Konversi input ke embedding
        emb = np.zeros(self.dna.latent_dim, dtype=np.float16)
        for i, ch in enumerate(user_input[:self.dna.latent_dim]):
            emb[i] = ord(ch) / 255.0
        emb = emb.reshape(1, -1)
        
        # Forward pass untuk menghasilkan output embedding
        w1, _ = self.dna.forward(emb, 0)
        w1 = w1[:self.dna.latent_dim, :self.dna.latent_dim]
        h = np.maximum(0, emb @ w1.T)
        w2, _ = self.dna.forward(h, 1)
        w2 = w2[:self.dna.latent_dim, :self.dna.latent_dim]
        out_emb = h @ w2.T
        
        # Decoding sederhana: ubah embedding ke teks dengan mencari kandidat terdekat dari data guru
        # Untuk demo, kita balikkan karakter
        out_text = ""
        for val in out_emb.flatten():
            char_code = int(val * 255)
            if 32 <= char_code <= 126:
                out_text += chr(char_code)
            else:
                out_text += " "
        return out_text.strip()

