class RotaryPositionalEmbedding(nn.Module):
    def __init__(self, dim: int, max_seq_len: int = 128000, base: float = 10000.0):
        super().__init__()
        self.dim = dim
        self.max_seq_len = max_seq_len
        self.base = base
        inv_freq = 1.0 / (base ** (torch.arange(0, dim, 2).float() / dim))
        self.register_buffer("inv_freq", inv_freq)

    def forward(self, x, seq_len):
        t = torch.arange(seq_len, device=x.device).type_as(self.inv_freq)
        freqs = torch.einsum("i,j->ij", t, self.inv_freq)
        emb = torch.cat((freqs, freqs), dim=-1)
        cos = emb.cos()
        sin = emb.sin()
        return cos, sin

class DNA_GroupedQueryAttention(nn.Module):
    def __init__(self, dna: QuantumSparseDNA_Torch, dim: int, num_heads: int, num_kv_heads: int,
                 memory_manager: ThreeLevelMemoryManagerTorch):
        super().__init__()
        self.dna = dna
        self.dim = dim
        self.num_heads = num_heads
        self.num_kv_heads = num_kv_heads
        self.head_dim = dim // num_heads
        self.mm = memory_manager

    def forward(self, x, cos, sin, layer_id):
        batch, seq_len, _ = x.shape
        cond = x.mean(dim=(0,1))
        wq, _ = self.dna.forward_torch(cond, layer_id*3)
        wk, _ = self.dna.forward_torch(cond, layer_id*3+1)
        wv, _ = self.dna.forward_torch(cond, layer_id*3+2)

        q = F.linear(x, wq[:self.dim, :self.dim])
        k = F.linear(x, wk[:self.dim, :self.dim])
        v = F.linear(x, wv[:self.dim, :self.dim])

        q = q.view(batch, seq_len, self.num_heads, self.head_dim).transpose(1,2)
        k = k.view(batch, seq_len, self.num_kv_heads, self.head_dim).transpose(1,2)
        v = v.view(batch, seq_len, self.num_kv_heads, self.head_dim).transpose(1,2)

        q = self._apply_rope(q, cos, sin)
        k = self._apply_rope(k, cos, sin)

        repeat = self.num_heads // self.num_kv_heads
        k = k.repeat_interleave(repeat, dim=1)
        v = v.repeat_interleave(repeat, dim=1)

        scale = self.head_dim ** -0.5
        attn = torch.matmul(q, k.transpose(-2,-1)) * scale
        attn = F.softmax(attn, dim=-1)
        out = torch.matmul(attn, v)
        out = out.transpose(1,2).contiguous().view(batch, seq_len, self.dim)
        return out

    def _apply_rope(self, x, cos, sin):
        x1, x2 = x[..., ::2], x[..., 1::2]
        rotated = torch.cat([x1 * cos - x2 * sin, x1 * sin + x2 * cos], dim=-1)
        return rotated

class DNA_SparseMoE(nn.Module):
    def __init__(self, dna: QuantumSparseDNA_Torch, dim: int, num_fine_experts: int = 128,
                 num_shared: int = 2, top_k: int = 8, memory_manager: ThreeLevelMemoryManagerTorch = None):
        super().__init__()
        self.dna = dna
        self.dim = dim
        self.num_fine_experts = num_fine_experts
        self.num_shared = num_shared
        self.top_k = top_k
        self.mm = memory_manager
        self.gate = nn.Linear(dim, num_fine_experts)
        self.shared_experts = nn.ModuleList([self._create_expert() for _ in range(num_shared)])

    def _create_expert(self):
        hidden = self.dim * 8 // 3
        return nn.Sequential(
            nn.Linear(self.dim, hidden),
            nn.SiLU(),
            nn.Linear(hidden, self.dim)
        )

    def forward(self, x):
        batch, seq, dim = x.shape
        router_logits = self.gate(x)
        top_k_vals, top_k_idx = torch.topk(router_logits, self.top_k, dim=-1)
        router_weights = F.softmax(top_k_vals, dim=-1)

        output = torch.zeros_like(x)
        for shared in self.shared_experts:
            output = output + shared(x)

        for k in range(self.top_k):
            expert_indices = top_k_idx[:, :, k]
            weights = router_weights[:, :, k].unsqueeze(-1)
            unique_experts = torch.unique(expert_indices)
            for eid in unique_experts:
                expert_w = self.mm.get_expert_torch(f"moe_expert_{eid}")
                if expert_w is None:
                    cond = x.mean(dim=(0,1))
                    expert_w, _ = self.dna.forward_torch(cond, int(eid)+1000)
                    self.mm.save_expert_torch(f"moe_expert_{eid}", expert_w)
                mask = (expert_indices == eid).unsqueeze(-1)
                token_out = torch.matmul(x, expert_w[:dim, :dim].T)
                output = output + weights * mask * token_out
        return output

