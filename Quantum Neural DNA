        ant = hypothesis.get("antecedent", {})
        feat = ant.get("feature", "price")
        op = ant.get("op", "gt")
        val = ant.get("value", 0)
        op_map = {"gt": ">", "lt": "<", "gte": ">=", "lte": "<="}
