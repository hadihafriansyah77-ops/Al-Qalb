# LAYER 11: DNA_MLP MODEL (NumPy)
# ==============================================================
class DNA_MLP:
    def __init__(self, dna: QuantumSparseDNA, input_dim: int, hidden_dim: int, output_dim: int):
        self.dna = dna
        self.input_dim = input_dim
        self.hidden_dim = hidden_dim
        self.output_dim = output_dim

    def forward(self, x: np.ndarray) -> np.ndarray:
        w1, _ = self.dna.forward(x, 0)
        w1 = w1[:self.hidden_dim, :self.input_dim]
        h = np.maximum(0, x @ w1.T)
        w2, _ = self.dna.forward(h, 1)
        w2 = w2[:self.output_dim, :self.hidden_dim]
        return h @ w2.T

