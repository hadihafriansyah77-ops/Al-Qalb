    def __init__(self):
        self.threshold = {val}
        self.feature = "{feat}"
    def should_buy(self, data: dict) -> bool:
        return data.get(self.feature, 0) {op_map.get(op, '>')} self.threshold
    def should_sell(self, data: dict) -> bool:
        return data.get(self.feature, 0) {op_map.get(op, '>')} self.threshold
'''
