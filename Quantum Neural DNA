                    pattern=re.compile(r'(?<=[^a-zA-Z0-9])[a-zA-Z0-9]+(?=[^a-zA-Z0-9])|[\d\.]+|[+\-*/=<>!~@#$%^&*()_+{}|:;"\'<>,.?/\\[\\]]')
                ),
                pre_tokenizers.Whitespace()
            ])
            self.vocab_size = 151646
            self._trained = False

        def train_on_corpus(self, text_files: List[str], dna_threshold: float = 0.7):
            high_quality_lines = []
            for file in text_files:
                with open(file, 'r', encoding='utf-8') as f:
                    for line in f:
                        line = line.strip()
                        if not line:
                            continue
                        emb = self._line_to_embedding(line)
                        quality = self.dna.forward(emb)[0].mean()
                        if quality > dna_threshold:
                            high_quality_lines.append(line)
            trainer = trainers.BpeTrainer(
                vocab_size=self.vocab_size,
                special_tokens=["<|im_start|>", "<|im_end|>", "<|thought|>"]
            )
            self.tokenizer.train_from_iterator(high_quality_lines, trainer)
            self._trained = True
            return self.tokenizer

        def _line_to_embedding(self, text: str) -> np.ndarray:
            h = np.zeros(self.dna.latent_dim, dtype=np.float16)
            for i, ch in enumerate(text[:self.dna.latent_dim]):
                h[i] = ord(ch) / 255.0
            return h

        def encode(self, text: str):
            if not self._trained:
                raise RuntimeError("Tokenizer not trained. Call train_on_corpus first.")
            return self.tokenizer.encode(text).ids

        def decode(self, ids):
            return self.tokenizer.decode(ids)
