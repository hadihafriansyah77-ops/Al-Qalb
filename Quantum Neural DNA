# LAYER 18: DNA GROUPED QUERY ATTENTION
# ==============================================================================
class DNA_GroupedQueryAttention(nn.Module):
    """GQA dengan bobot Q, K, V dihasilkan oleh Quantum DNA."""
    def __init__(self, dna: QuantumSparseDNA_Torch, dim: int, num_heads: int, num_kv_heads: int, memory_manager: ThreeLevelMemoryManagerTorch):
        super().__init__()
        self.dna = dna
        self.dim = dim
        self.num_heads = num_heads
        self.num_kv_heads = num_kv_heads
        self.head_dim = dim // num_heads
        self.mm = memory_manager
        
    def forward(self, x, cos, sin, layer_id):
        batch, seq_len, _ = x.shape
        
        cond = x.mean(dim=(0,1))
        wq, _ = self.dna(cond, layer_id=layer_id*3)
        wk, _ = self.dna(cond, layer_id=layer_id*3+1)
        wv, _ = self.dna(cond, layer_id=layer_id*3+2)
        
        q = F.linear(x, wq[:self.dim, :self.dim])
        k = F.linear(x, wk[:self.dim, :self.dim])
        v = F.linear(x, wv[:self.dim, :self.dim])
        
        q = q.view(batch, seq_len, self.num_heads, self.head_dim).transpose(1,2)
        k = k.view(batch, seq_len, self.num_kv_heads, self.head_dim).transpose(1,2)
        v = v.view(batch, seq_len, self.num_kv_heads, self.head_dim).transpose(1,2)
        
        q = self._apply_rope(q, cos, sin)
        k = self._apply_rope(k, cos, sin)
        
        repeat = self.num_heads // self.num_kv_heads
        k = k.repeat_interleave(repeat, dim=1)
        v = v.repeat_interleave(repeat, dim=1)
        
        scale = self.head_dim ** -0.5
        attn = torch.matmul(q, k.transpose(-2,-1)) * scale
        attn = F.softmax(attn, dim=-1)
        out = torch.matmul(attn, v)
        out = out.transpose(1,2).contiguous().view(batch, seq_len, self.dim)
        return out
    
    def _apply_rope(self, x, cos, sin):
        x1, x2 = x[..., ::2], x[..., 1::2]
        rotated = torch.cat([x1 * cos - x2 * sin, x1 * sin + x2 * cos], dim=-1)
        return rotated

