# LAYER 5b: QUANTUM-SPARSE NEURAL DNA (PYTORCH VERSION)
# ==============================================================================
class QuantumSparseDNA_Torch(nn.Module):
    """DNA versi PyTorch untuk integrasi dengan model transformer."""
    def __init__(self, dna_size: int = 1024, latent_dim: int = 512, sparsity: float = SPARSITY_GENES):
        super().__init__()
        self.dna = nn.Parameter(torch.randn(dna_size, latent_dim, dtype=torch.float16) * 0.01)
        self.dna_size = dna_size
        self.latent_dim = latent_dim
        self.sparsity = sparsity
        self.alpha = nn.Parameter(torch.ones(1, dtype=torch.float16))
        self.beta = nn.Parameter(torch.zeros(1, dtype=torch.float16))
        self.cache = OrderedDict()
        self.cache_limit = 100

    def forward(self, x: torch.Tensor, layer_id: int = 0) -> Tuple[torch.Tensor, torch.Tensor]:
        """
        x: (batch, dim) atau (dim,)
        Returns: (weight_matrix, gene_indices)
        """
        if x.dim() == 1:
            x = x.unsqueeze(0)
        # Mean pooling over batch
        cond = x.mean(dim=0)  # (dim,)
        cache_key = f"layer_{layer_id}_{hash(cond.cpu().numpy().tobytes()) % 10000}"
        if cache_key in self.cache:
            self.cache.move_to_end(cache_key)
            return self.cache[cache_key], torch.tensor([])
        
        # Gene selection
        scores = cond @ self.dna.T  # (dna_size,)
        k = max(1, int(self.dna_size * self.sparsity))
        _, indices = torch.topk(scores, k)
        active_genes = self.dna[indices]  # (k, latent_dim)
        
        # Synthesize weight matrix
        a = active_genes.mean(dim=0)  # (latent_dim,)
        b = active_genes.flip(0).mean(dim=0)  # (latent_dim,)
        w = torch.outer(a, b)  # (latent_dim, latent_dim)
        
        # Sparsity
        threshold = torch.quantile(torch.abs(w), 0.9)
        w = torch.where(torch.abs(w) < threshold, torch.zeros_like(w), w)
        # 2-bit quantization simulation
        w = torch.round(w * 3) / 3
        # Normalize
        norm = torch.norm(w) + 1e-8
        w = w / norm
        w = self.alpha * w + self.beta
        
        self.cache[cache_key] = w
        if len(self.cache) > self.cache_limit:
            self.cache.popitem(last=False)
        return w, indices

    def clear_cache(self):
        self.cache.clear()

