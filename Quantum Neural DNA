# LAYER 21: GRPO TRAINER
# ==============================================================================
class GRPOTrainer:
    """Group Relative Policy Optimization untuk melatih reasoning model."""
    def __init__(self, model: 'DNA_Qwen_Ultimate', dna_reward_model: DNA_RewardModel, group_size: int = 8, lr: float = 1e-6):
        self.model = model
        self.reward_model = dna_reward_model
        self.group_size = group_size
        self.optimizer = optim.Adam(model.parameters(), lr=lr)
        
    def train_step(self, prompts: List[str], ground_truths: List[str]) -> float:
        all_responses = []
        for prompt in prompts:
            group = []
            for _ in range(self.group_size):
                response = self.model.generate(prompt, max_tokens=512, do_sample=True, temperature=0.8)
                group.append(response)
            all_responses.append(group)
        
        rewards = []
        for i, group in enumerate(all_responses):
            group_rewards = []
            for resp in group:
                reward = self.reward_model.evaluate(prompts[i], resp, ground_truths[i])
                group_rewards.append(reward)
            mean_r = np.mean(group_rewards)
            std_r = np.std(group_rewards) + 1e-8
            group_rewards = (group_rewards - mean_r) / std_r
            rewards.append(group_rewards)
        
        total_loss = torch.tensor(0.0, device=device)
        for i, group in enumerate(all_responses):
            for j, resp in enumerate(group):
                advantage = rewards[i][j]
                log_prob = self.model.log_prob(resp)
                loss = -advantage * log_prob
                total_loss = total_loss + loss
        
        self.optimizer.zero_grad()
        total_loss.backward()
        self.optimizer.step()
        return total_loss.item()

