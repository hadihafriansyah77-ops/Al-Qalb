# LAYER 19: DNA SPARSE MOE
# ==============================================================================
class DNA_SparseMoE(nn.Module):
    """Hybrid Sparse MoE dengan Fine-grained Experts + Shared Experts."""
    def __init__(self, dna: QuantumSparseDNA_Torch, dim: int, num_fine_experts: int = 128, num_shared: int = 2, top_k: int = 8, memory_manager: ThreeLevelMemoryManagerTorch = None):
        super().__init__()
        self.dna = dna
        self.dim = dim
        self.num_fine_experts = num_fine_experts
        self.num_shared = num_shared
        self.top_k = top_k
        self.mm = memory_manager if memory_manager else ThreeLevelMemoryManagerTorch()
        self.gate = nn.Linear(dim, num_fine_experts, bias=False)
        self.shared_experts = nn.ModuleList([self._create_expert() for _ in range(num_shared)])
        
    def _create_expert(self):
        hidden = int(self.dim * 8 / 3)
        return nn.Sequential(
            nn.Linear(self.dim, hidden, bias=False),
            nn.SiLU(),
            nn.Linear(hidden, self.dim, bias=False)
        )
    
    def forward(self, x):
        batch, seq, dim = x.shape
        router_logits = self.gate(x)
        top_k_vals, top_k_idx = torch.topk(router_logits, self.top_k, dim=-1)
        router_weights = F.softmax(top_k_vals, dim=-1)
        
        output = torch.zeros_like(x)
        for shared in self.shared_experts:
            output = output + shared(x)
        
        for k in range(self.top_k):
            expert_indices = top_k_idx[:, :, k]
            weights = router_weights[:, :, k].unsqueeze(-1)
            unique_experts = torch.unique(expert_indices)
            for eid in unique_experts:
                expert_w = self.mm.get_expert(f"moe_expert_{eid}")
                if expert_w is None:
                    cond = x.mean(dim=(0,1))
                    expert_w, _ = self.dna(cond, layer_id=int(eid)+1000)
                    self.mm.save_expert_to_ssd(f"moe_expert_{eid}", expert_w)
                mask = (expert_indices == eid).unsqueeze(-1)
                token_out = torch.matmul(x, expert_w[:dim, :dim].T)
                output = output + weights * mask * token_out
        return output

