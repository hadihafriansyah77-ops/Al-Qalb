if TRITON_AVAILABLE:
    @triton.jit
    def dna_dequant_matmul_rmsnorm_kernel(
        x_ptr, x_batch_stride, x_seq_stride, x_dim_stride,
        w_packed_ptr, w_expert_stride,
        scale_ptr, zp_ptr,
        expert_idx_ptr, expert_weight_ptr,
        y_ptr, y_batch_stride, y_seq_stride, y_dim_stride,
        batch, seq_len, dim, top_k,
        eps,
        idx_batch_stride, idx_seq_stride,
        wgt_batch_stride, wgt_seq_stride,
        BLOCK_DIM: tl.constexpr, BLOCK_K: tl.constexpr,
    ):
        pid_batch = tl.program_id(0)
        pid_seq = tl.program_id(1)
        pid_dim = tl.program_id(2)

        offs_dim = pid_dim * BLOCK_DIM + tl.arange(0, BLOCK_DIM)
        mask_dim = offs_dim < dim

        x_offset = pid_batch * x_batch_stride + pid_seq * x_seq_stride
        x_ptr_start = x_ptr + x_offset

        y_offset = pid_batch * y_batch_stride + pid_seq * y_seq_stride
        y_ptr_start = y_ptr + y_offset

        idx_offset = pid_batch * idx_batch_stride + pid_seq * idx_seq_stride
        expert_ids = tl.load(expert_idx_ptr + idx_offset + tl.arange(0, top_k), mask=tl.arange(0, top_k) < top_k)
        expert_weights = tl.load(expert_weight_ptr + idx_offset + tl.arange(0, top_k), mask=tl.arange(0, top_k) < top_k)

        acc = tl.zeros([BLOCK_DIM], dtype=tl.float32)

        for k in range(top_k):
            eid = expert_ids[k]
            wgt = expert_weights[k]
            if eid < 0:
                continue
            scale = tl.load(scale_ptr + eid)
            zp = tl.load(zp_ptr + eid)

            sum_row = tl.zeros([BLOCK_DIM], dtype=tl.float32)
            for k_start in range(0, dim, BLOCK_K):
                offs_k = k_start + tl.arange(0, BLOCK_K)
                mask_k = offs_k < dim
                x_vals = tl.load(x_ptr_start + offs_k[None] * x_dim_stride, mask=mask_k[None], other=0.0)
                x_vals = x_vals.to(tl.float32)

                for i in range(BLOCK_DIM):
                    out_idx = offs_dim[i]
                    if out_idx >= dim:
                        continue
                    packed_row_offset = eid * w_expert_stride + out_idx * ((dim + 3) // 4)
                    for j in range(BLOCK_K):
                        in_idx = offs_k[j]
                        if in_idx >= dim:
                            continue
                        byte_idx = in_idx // 4
                        bit_shift = (in_idx % 4) * 2
                        packed_byte = tl.load(w_packed_ptr + packed_row_offset + byte_idx)
                        quant_val = (packed_byte >> bit_shift) & 0x03
                        w_val = (quant_val.to(tl.float32) / 3.0) * scale + zp
                        sum_row[i] += w_val * x_vals[j]
            acc += sum_row * wgt

        m2 = tl.zeros([BLOCK_DIM], dtype=tl.float32)
        for i in range(BLOCK_DIM):
            if mask_dim[i]:
                m2[i] = acc[i] * acc[i]
        mean_sq = tl.sum(m2) / dim
        rms = tl.sqrt(mean_sq + eps)
        out = acc / rms
        tl.store(y_ptr_start + offs_dim * y_dim_stride, out.to(tl.float16), mask=mask_dim)

    def dna_matmul_rmsnorm(
        x: torch.Tensor,
        packed_weights: torch.Tensor,
        scales: torch.Tensor,
        zero_points: torch.Tensor,
        expert_indices: torch.Tensor,
        expert_weights: torch.Tensor,
        eps: float = 1e-5,
    ) -> torch.Tensor:
        batch, seq_len, dim = x.shape
        top_k = expert_indices.shape[-1]
        y = torch.empty_like(x)

        BLOCK_DIM = 64
        BLOCK_K = 64
        grid = (batch, seq_len, (dim + BLOCK_DIM - 1) // BLOCK_DIM)

        x_batch_stride, x_seq_stride, x_dim_stride = x.stride()
        y_batch_stride, y_seq_stride, y_dim_stride = y.stride()
        idx_batch_stride, idx_seq_stride, _ = expert_indices.stride()
        wgt_batch_stride, wgt_seq_stride, _ = expert_weights.stride()
        w_expert_stride = packed_weights.stride(0)

        dna_dequant_matmul_rmsnorm_kernel[grid](
            x, x_batch_stride, x_seq_stride, x_dim_stride,
            packed_weights, w_expert_stride,
            scales, zero_points,
            expert_indices, expert_weights,
            y, y_batch_stride, y_seq_stride, y_dim_stride,
            batch, seq_len, dim, top_k,
            eps,
            idx_batch_stride, idx_seq_stride,
            wgt_batch_stride, wgt_seq_stride,
            BLOCK_DIM=BLOCK_DIM, BLOCK_K=BLOCK_K,
        )
        return y
