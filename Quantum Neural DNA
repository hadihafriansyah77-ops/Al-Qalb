class IndexedLocalBrain:
    def __init__(self, db_path: str = DB_FILE):
        self.db_path = db_path
        self._init_db()
        event_bus.subscribe("trade_closed", self.learn_from_trade)

    def _init_db(self):
        with sqlite3.connect(self.db_path) as conn:
            conn.execute("""
                CREATE TABLE IF NOT EXISTS knowledge (
                    id TEXT PRIMARY KEY,
                    topic TEXT,
                    tags TEXT,
                    statement TEXT,
                    epistemic_type TEXT,
                    confidence REAL,
                    created_at REAL
                )
            """)
            conn.execute("CREATE INDEX IF NOT EXISTS idx_topic ON knowledge(topic)")
            conn.execute("CREATE INDEX IF NOT EXISTS idx_type ON knowledge(epistemic_type)")

    def add_knowledge(self, id: str, topic: str, tags: List[str], statement: str, 
                      e_type: str, conf: float = 0.7):
        with sqlite3.connect(self.db_path) as conn:
            conn.execute("INSERT OR REPLACE INTO knowledge VALUES (?,?,?,?,?,?,?)",
                        (id, topic, json.dumps(tags), statement, e_type, conf, time.time()))

    def query_by_topic(self, topic: str, limit: int = 5) -> List[tuple]:
        with sqlite3.connect(self.db_path) as conn:
            cur = conn.execute("SELECT * FROM knowledge WHERE topic = ? ORDER BY confidence DESC LIMIT ?", 
                              (topic, limit))
            return cur.fetchall()

    def answer_from_brain(self, query: str) -> Optional[str]:
        nodes = self.query_by_topic(query, limit=3)
        if not nodes:
            return None
        answer = "🧠 [Local Brain]\n\n"
        for node in nodes[:3]:
            answer += f"- [{node[4]}] {node[3][:150]}\n"
        return answer

