            if "buy pressure" in rule_lower and ">" in rule_lower:
                match = re.search(r'(\d+)%', rule)
                if match:
                    required = int(match.group(1))
                    buys = data.get("txns_h24_buys", 0)
                    sells = data.get("txns_h24_sells", 0)
                    total = buys + sells
                    pressure = (buys / total * 100) if total > 0 else 0
                    if pressure < required:
                        return False, f"buy pressure {pressure:.0f}% < {required}%"
            elif "likuiditas" in rule_lower or "liquidity" in rule_lower:
                match = re.search(r'(\d+)k', rule)
                if match:
                    required_liq = float(match.group(1)) * 1000
                    liq = data.get("liquidity_usd", 0)
                    if liq < required_liq:
                        return False, f"liquidity ${liq:.0f} < ${required_liq:.0f}"
            elif "price change" in rule_lower or "perubahan harga" in rule_lower:
                match = re.search(r'(\d+)%', rule)
                if match:
                    max_change = float(match.group(1))
                    change = abs(data.get("price_change_h24", 0))
                    if change > max_change:
                        return False, f"price change {change:.0f}% > {max_change}%"
        return True, ""

