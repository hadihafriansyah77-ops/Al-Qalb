    def get_entry_rules(self) -> List[str]:
        with sqlite3.connect(self.db_path) as conn:
            cur = conn.execute("SELECT content FROM trading_knowledge WHERE category='entry_rules' ORDER BY priority DESC LIMIT 1")
            row = cur.fetchone()
            if row:
                try:
                    content = row[0]
                    parsed = json.loads(content)
                    if isinstance(parsed, list):
                        return parsed
                except:
                    lines = [line.strip() for line in content.split('\n') if line.strip() and (line[0].isdigit() or line.startswith('-'))]
                    return lines
        return []

    def get_exit_rules(self) -> List[str]:
        with sqlite3.connect(self.db_path) as conn:
            cur = conn.execute("SELECT content FROM trading_knowledge WHERE category='exit_rules' ORDER BY priority DESC LIMIT 1")
            row = cur.fetchone()
            if row:
                try:
                    content = row[0]
                    parsed = json.loads(content)
                    if isinstance(parsed, list):
                        return parsed
                except:
                    pass
                lines = [line.strip() for line in content.split('\n') if line.strip() and (line[0].isdigit() or line.startswith('-'))]
                return lines
        return []

    def get_risk_params(self) -> Dict:
        with sqlite3.connect(self.db_path) as conn:
            cur = conn.execute("SELECT content FROM trading_knowledge WHERE category='risk_management' ORDER BY priority DESC LIMIT 1")
            row = cur.fetchone()
            if row:
                try:
                    json_match = re.search(r'\{.*\}', row[0], re.DOTALL)
                    if json_match:
                        return json.loads(json_match.group())
                except:
                    pass
        return {
            "max_position_size_pct": 5,
            "daily_loss_limit_pct": 8,
            "max_consecutive_losses": 3,
