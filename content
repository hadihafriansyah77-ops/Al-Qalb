async def call_openrouter_with_fallback(prompt: str) -> Optional[str]:
    if not OPENROUTER_API_KEY: return None
    priority_models = ["openrouter/elephant-alpha", "openrouter/hunter-alpha", "openrouter/free"]
    headers = {"Authorization": f"Bearer {OPENROUTER_API_KEY}", "Content-Type": "application/json",
               "HTTP-Referer": "http://localhost", "X-Title": "AI Qalb"}
    url = "https://openrouter.ai/api/v1/chat/completions"
    for model in priority_models:
        try:
            payload = {"model": model, "messages": [{"role": "user", "content": prompt}],
                       "max_tokens": 1024, "temperature": 0.7, "route": "fallback"}
            if model == "openrouter/free":
                payload["require_parameters"] = {"type": "free"}
            async with aiohttp.ClientSession() as session:
                async with session.post(url, headers=headers, json=payload, timeout=aiohttp.ClientTimeout(total=60)) as response:
                    if response.status == 200:
                        data = await response.json()
                        return data["choices"][0]["message"]["content"]
                    else:
                        log.warning(f"Model {model} returned status {response.status}")
        except Exception as e:
            log.warning(f"Model {model} error: {e}")
    return None

