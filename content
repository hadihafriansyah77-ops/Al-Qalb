# MOMENTUM CHECKER
# ==============================================================
class MomentumChecker:
    async def check(self, mint: str, interval_sec=5, samples=3) -> Dict:
        async def fetch_one():
            data = await get_token_data(mint)
            if not data:
                return None
            return {"ts": time.time(), "volume": data.get("volume_h24", 0), "buys": data.get("txns_h24_buys", 0), "sells": data.get("txns_h24_sells", 0)}
        points = []
        for _ in range(samples):
            pt = await fetch_one()
            if pt:
                points.append(pt)
            await asyncio.sleep(interval_sec)
        if len(points) < 2:
            return {"volume_trend": "stable", "buy_trend": "stable", "momentum_score": 0}
        vols = [p["volume"] for p in points]
        vol_change = (vols[-1] - vols[0]) / max(vols[0], 1)
        buys = [p["buys"] for p in points]
        sells = [p["sells"] for p in points]
        buy_ratios = [b / (b + s) if (b + s) > 0 else 0.5 for b, s in zip(buys, sells)]
        ratio_change = buy_ratios[-1] - buy_ratios[0]
        momentum_score = (vol_change * 40) + (ratio_change * 60)
        momentum_score = max(-100, min(100, momentum_score))
        volume_trend = "rising" if vol_change > 0.05 else "falling" if vol_change < -0.05 else "stable"
        buy_trend = "rising" if ratio_change > 0.03 else "falling" if ratio_change < -0.03 else "stable"
        return {"volume_trend": volume_trend, "buy_trend": buy_trend, "momentum_score": momentum_score}

