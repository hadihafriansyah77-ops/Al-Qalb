class Executor:
    def __init__(self, config: ConfigManager, logger: logging.Logger, memory_store: MemoryStore):
        self.config = config
        self.logger = logger
        self.memory_store = memory_store
        self.output_dir = Path(config.get("executor.output_dir", "./output"))
        self.output_dir.mkdir(exist_ok=True)
        self.session = None

    async def start(self):
        self.session = aiohttp.ClientSession()

    async def close(self):
        if self.session: await self.session.close()

    async def execute(self, task: Dict) -> Dict:
        ttype = task.get("type")
        params = task.get("params", {})
        try:
            if ttype == "generate_file":
                fname = params.get("filename", f"report_{int(time.time())}.txt")
                path = self.output_dir / fname
                content = params.get("content", "")
                if fname.endswith('.json'):
                    with open(path, 'w') as f: json.dump(content, f, indent=2)
                else: path.write_text(str(content), encoding='utf-8')
                return {"status": "success", "output": str(path)}
            elif ttype == "http_request":
                if not self.session: self.session = aiohttp.ClientSession()
                async with self.session.request(params.get("method", "GET"), params["url"],
                                                headers=params.get("headers", {}), json=params.get("data")) as resp:
                    return {"status": "success", "output": await resp.text()[:500]}
            elif ttype == "update_database":
                if self.memory_store and params.get("operation") == "set_learning":
                    await self.memory_store.set_learning_value(params["key"], params["value"])
                return {"status": "success"}
            elif ttype == "post_to_endpoint":
                return await self.execute({"type": "http_request", "params": {"url": params.get("url", "https://httpbin.org/post"),
                                           "method": "POST", "data": params.get("payload", {})}})
        except Exception as e:
            return {"status": "error", "error": str(e)}
        return {"status": "error", "error": "Unknown task type"}

