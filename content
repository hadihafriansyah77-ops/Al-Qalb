def generate_license_key(user_id: int) -> str:
    return hashlib.sha256(f"{user_id}{time.time()}{secrets.token_hex(8)}".encode()).hexdigest()[:16]

def check_license(user_id: int) -> dict:
    try:
        with sqlite3.connect(LICENSE_FILE) as conn:
            conn.execute("CREATE TABLE IF NOT EXISTS licenses (user_id INTEGER, key TEXT, plan TEXT, expires_at REAL, created_at REAL)")
            row = conn.execute("SELECT plan, expires_at FROM licenses WHERE user_id=? AND expires_at>? ORDER BY expires_at DESC",
                               (user_id, time.time())).fetchone()
        if row:
            return {"active": True, "plan": row[0], "expires_at": row[1]}
    except: pass
    return {"active": False}

def create_license(user_id: int, plan: str, days: int = 30) -> str:
    key = generate_license_key(user_id)
    expires = time.time() + days * 86400
    with sqlite3.connect(LICENSE_FILE) as conn:
        conn.execute("CREATE TABLE IF NOT EXISTS licenses (user_id INTEGER, key TEXT, plan TEXT, expires_at REAL, created_at REAL)")
        conn.execute("INSERT INTO licenses VALUES (?,?,?,?,?)", (user_id, key, plan, expires, time.time()))
    return key

