# SMART TRADE PLANNER
class SmartTradePlanner:
    def __init__(self):
        self.indicators = MemeTechIndicators()
        self.history = {}

    def update_history(self, mint: str, price: float, volume: float, buys: int, sells: int):
        if mint not in self.history:
            self.history[mint] = {"prices": deque(maxlen=50), "volumes": deque(maxlen=50), "buys": deque(maxlen=50), "sells": deque(maxlen=50)}
