# ------------------------- 1. SCORING RELATIF (berbasis median 20 token terakhir) -------------------------
class AdaptiveScorer:
    """Skor 0-100 berdasarkan perbandingan dengan median pasar (20 token terakhir)."""
    
    def __init__(self, lookback=20):
        self.lookback = lookback
        self.recent_tokens = deque(maxlen=lookback)
        self.median_liq = 10000.0
        self.median_vol = 10000.0
        self.median_buy_ratio = 0.5
    
    def update_market_baseline(self, data: Dict):
        liq = data.get("liquidity_usd", 0)
        vol = data.get("volume_h24", 0)
        buys = data.get("txns_h24_buys", 0)
        sells = data.get("txns_h24_sells", 0)
        ratio = buys / (buys + sells) if (buys + sells) > 0 else 0.5
        self.recent_tokens.append((liq, vol, ratio))
        if len(self.recent_tokens) >= 5:
            self.median_liq = statistics.median([t[0] for t in self.recent_tokens])
            self.median_vol = statistics.median([t[1] for t in self.recent_tokens])
            self.median_buy_ratio = statistics.median([t[2] for t in self.recent_tokens])
    
    def score(self, data: Dict) -> int:
        liq = data.get("liquidity_usd", 0)
        vol = data.get("volume_h24", 0)
        buys = data.get("txns_h24_buys", 0)
        sells = data.get("txns_h24_sells", 0)
        ratio = buys / (buys + sells) if (buys + sells) > 0 else 0.5
        change = data.get("price_change_h24", 0)
        mc = data.get("market_cap", 0)
        
        liq_score = min(100, (liq / max(self.median_liq, 1)) * 50) if self.median_liq > 0 else 50
        vol_score = min(100, (vol / max(self.median_vol, 1)) * 50)
        ratio_score = 50 + (ratio - self.median_buy_ratio) * 200
        ratio_score = max(0, min(100, ratio_score))
        
        if 0 < change < 30:
            change_score = 100
        elif 30 <= change < 60:
            change_score = 70
        elif 60 <= change < 100:
            change_score = 40
        elif 100 <= change < 200:
            change_score = 10
        elif change <= 0:
            change_score = 30
        else:
            change_score = 0
        
        if 5000 < mc < 100000:
            mc_score = 100
        elif 100000 <= mc < 500000:
            mc_score = 50
        else:
            mc_score = 20
        
        final = (liq_score * 0.25) + (vol_score * 0.20) + (ratio_score * 0.30) + (change_score * 0.15) + (mc_score * 0.10)
        return int(round(max(0, min(100, final))))


# ------------------------- 2. MOMENTUM CHECKER (3 fetch dalam interval) -------------------------
class MomentumChecker:
    async def check(self, mint: str, interval_sec=5, samples=3) -> Dict:
        async def fetch_one():
            data = await get_token_data(mint)
            if not data: return None
            return {"ts": time.time(), "volume": data.get("volume_h24",0),
                    "buys": data.get("txns_h24_buys",0), "sells": data.get("txns_h24_sells",0)}
        points = []
        for _ in range(samples):
            pt = await fetch_one()
            if pt: points.append(pt)
            await asyncio.sleep(interval_sec)
        if len(points) < 2:
            return {"volume_trend": "stable", "buy_trend": "stable", "momentum_score": 0}
        vols = [p["volume"] for p in points]
        vol_change = (vols[-1] - vols[0]) / max(vols[0], 1)
        if vol_change > 0.05:
            vol_trend = "up"; vol_score = min(50, vol_change * 100)
        elif vol_change < -0.05:
            vol_trend = "down"; vol_score = max(-50, vol_change * 100)
        else:
            vol_trend = "stable"; vol_score = 0
        ratios = []
        for p in points:
            total = p["buys"] + p["sells"]
            ratios.append(p["buys"] / total if total > 0 else 0.5)
        ratio_change = ratios[-1] - ratios[0]
        if ratio_change > 0.03:
            buy_trend = "up"; buy_score = min(50, ratio_change * 200)
        elif ratio_change < -0.03:
            buy_trend = "down"; buy_score = max(-50, ratio_change * 200)
        else:
            buy_trend = "stable"; buy_score = 0
        momentum_score = vol_score + buy_score
        return {"volume_trend": vol_trend, "buy_trend": buy_trend, "momentum_score": momentum_score}


