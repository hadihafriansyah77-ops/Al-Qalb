        buy_ratio = buys / (buys + sells) if (buys + sells) > 0 else 0.5
        self._get_or_create(mint).append((now, volume, buy_ratio))
    def analyze(self, mint: str) -> Dict:
        hist = self._get_or_create(mint)
        if len(hist) < 3:
            return {"acceleration": 0, "is_spiking": False, "is_sustained": False, "flow_score": 0}
        now = time.time()
        window_start = now - self.window_seconds
        recent = [(t, v, r) for t, v, r in hist if t >= window_start]
        if len(recent) < 2:
            return {"acceleration": 0, "is_spiking": False, "is_sustained": False, "flow_score": 0}
        times = [p[0] for p in recent]
        vols = [p[1] for p in recent]
        slope = np.polyfit(times, vols, 1)[0] if max(times)-min(times) > 0 else 0
        acceleration = slope * 10
        median_vol = statistics.median([v for _, v, _ in recent])
        last_vol = recent[-1][1]
        is_spiking = last_vol > median_vol * self.spike_threshold if median_vol > 0 else False
        is_sustained = False
        if is_spiking and len(hist) > 1:
            sustain_start = now - self.sustain_seconds
            high_volumes = [v for t, v, _ in hist if t >= sustain_start and v > median_vol * self.spike_threshold]
            is_sustained = len(high_volumes) >= 2
        flow_score = 0
        if acceleration > 50: flow_score += 40
        elif acceleration > 20: flow_score += 20
        if is_spiking and is_sustained: flow_score += 60
        elif is_spiking: flow_score += 30
        flow_score = max(-100, min(100, flow_score))
        return {"acceleration": acceleration, "is_spiking": is_spiking, "is_sustained": is_sustained, "flow_score": flow_score}


# ------------------------- 8. SMART MONEY DETECTOR -------------------------
class SmartMoneyDetector:
    def __init__(self, large_tx_threshold_usd=10000):
        self.large_tx_threshold = large_tx_threshold_usd
        self.history = {}
    def _get_or_create(self, mint: str):
        if mint not in self.history:
            self.history[mint] = deque(maxlen=20)
        return self.history[mint]
    async def analyze(self, mint: str, data: Dict) -> Dict:
        volume = data.get("volume_h24", 0)
        buys = data.get("txns_h24_buys", 0)
        sells = data.get("txns_h24_sells", 0)
        total_tx = buys + sells
        if total_tx == 0 or volume == 0:
            return {"smart_money_present": False, "whale_dominance": 0, "retail_chaos": False, "signal": "neutral"}
        avg_tx_size = volume / total_tx
        self._get_or_create(mint).append((time.time(), avg_tx_size))
        whale_dominance = min(100, (avg_tx_size / self.large_tx_threshold) * 100)
        smart_money = avg_tx_size > self.large_tx_threshold
        hist = list(self._get_or_create(mint))
        retail_chaos = False
        if len(hist) >= 3:
            recent_avg = hist[-1][1]
            older_avg = hist[0][1]
            avg_increase = (recent_avg - older_avg) / max(older_avg, 1)
            retail_chaos = (total_tx > 100 and recent_avg < self.large_tx_threshold * 0.3 and avg_increase > 0.5)
        if smart_money:
            signal = "whale_accumulation"
        elif retail_chaos:
            signal = "retail_fomo"
        else:
            signal = "neutral"
        return {"smart_money_present": smart_money, "whale_dominance": whale_dominance,
                "retail_chaos": retail_chaos, "signal": signal, "avg_tx_size_usd": avg_tx_size}


# ------------------------- 9. EXIT MANAGER (trailing stop, momentum mati, buy pressure turun) -------------------------
class ExitManager:
    def __init__(self, trailing_pct=10, momentum_exit_threshold=-50, buy_pressure_drop=0.1):
        self.trailing_pct = trailing_pct
        self.momentum_exit_threshold = momentum_exit_threshold
        self.buy_pressure_drop = buy_pressure_drop
        self.positions = {}
    def register_position(self, mint: str, entry_price: float):
        self.positions[mint] = {"ath": entry_price, "entry_price": entry_price, "entry_time": time.time(),
                                "last_flow_score": 0, "last_buy_ratio": 0.5}
    def update_price(self, mint: str, current_price: float):
        if mint in self.positions and current_price > self.positions[mint]["ath"]:
            self.positions[mint]["ath"] = current_price
    def update_flow(self, mint: str, flow_score: int, buy_ratio: float):
        if mint in self.positions:
            self.positions[mint]["last_flow_score"] = flow_score
            self.positions[mint]["last_buy_ratio"] = buy_ratio
    def should_exit(self, mint: str, current_price: float, current_flow_score: int, current_buy_ratio: float) -> Tuple[bool, str]:
        if mint not in self.positions: return False, ""
        pos = self.positions[mint]
        ath = pos["ath"]
        if (ath - current_price) / ath * 100 >= self.trailing_pct:
            return True, f"trailing_stop (ATH {ath:.8f} -> {current_price:.8f})"
        if current_flow_score < self.momentum_exit_threshold and pos["last_flow_score"] > self.momentum_exit_threshold:
            return True, f"momentum_died (flow {pos['last_flow_score']} -> {current_flow_score})"
        if (pos["last_buy_ratio"] - current_buy_ratio) > self.buy_pressure_drop:
            return True, f"buy_pressure_drop ({pos['last_buy_ratio']:.2f} -> {current_buy_ratio:.2f})"
        self.update_flow(mint, current_flow_score, current_buy_ratio)
        return False, ""
    def remove_position(self, mint: str):
        self.positions.pop(mint, None)


# ------------------------- 10. ENHANCED TRADE LOGGER (dengan kondisi pasar, flow, smart money) -------------------------
class EnhancedTradeLogger:
    def __init__(self, db_path=DB_FILE):
        self.db_path = db_path
        self._init_table()
    def _init_table(self):
        with sqlite3.connect(self.db_path) as conn:
            conn.executescript("""
                CREATE TABLE IF NOT EXISTS trade_signals_v2 (
                    id INTEGER PRIMARY KEY AUTOINCREMENT,
                    ts REAL, mint TEXT, symbol TEXT, score INTEGER,
                    liquidity REAL, volume REAL, buy_sell_ratio REAL, price_change REAL,
                    market_condition TEXT, momentum_score INTEGER, flow_score INTEGER,
                    smart_money_signal TEXT, reason TEXT,
                    entry_price REAL, exit_price REAL, profit_percent REAL,
                    result TEXT, duration_min REAL, simulated BOOLEAN
                );
            """)
    def log_signal(self, mint: str, symbol: str, score: int, data: Dict, market_cond: str,
                   momentum_score: int, flow_score: int, smart_money_signal: str, reason: str):
        buys = data.get("txns_h24_buys", 0)
        sells = data.get("txns_h24_sells", 0)
        ratio = buys / (buys + sells) if (buys + sells) > 0 else 0
        with sqlite3.connect(self.db_path) as conn:
            conn.execute("""
                INSERT INTO trade_signals_v2
                (ts, mint, symbol, score, liquidity, volume, buy_sell_ratio, price_change,
                 market_condition, momentum_score, flow_score, smart_money_signal, reason, simulated)
                VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?,?)
            """, (time.time(), mint, symbol, score, data.get("liquidity_usd",0), data.get("volume_h24",0),
                  ratio, data.get("price_change_h24",0), market_cond, momentum_score, flow_score,
                  smart_money_signal, reason, True))
    def log_outcome(self, mint: str, entry_price: float, exit_price: float, duration_min: float,
                    profit_percent: float, result: str, simulated: bool = False):
        with sqlite3.connect(self.db_path) as conn:
            conn.execute("""
                UPDATE trade_signals_v2
                SET entry_price = ?, exit_price = ?, profit_percent = ?, result = ?, duration_min = ?, simulated = ?
                WHERE mint = ? AND ts = (SELECT MAX(ts) FROM trade_signals_v2 WHERE mint = ?)
            """, (entry_price, exit_price, profit_percent, result, duration_min, simulated, mint, mint))
    def get_expected_value(self, min_trades=50) -> Dict:
        with sqlite3.connect(self.db_path) as conn:
            cur = conn.execute("""
                SELECT profit_percent, result FROM trade_signals_v2
                WHERE result IS NOT NULL AND simulated = 0 ORDER BY ts DESC LIMIT 200
            """)
            rows = cur.fetchall()
        if len(rows) < min_trades: return {"ready": False, "total": len(rows)}
        wins = [r[0] for r in rows if r[1] == "WIN"]
        losses = [r[0] for r in rows if r[1] == "LOSS"]
        win_rate = len(wins) / len(rows)
        loss_rate = len(losses) / len(rows)
        avg_win = sum(wins) / len(wins) if wins else 0
        avg_loss = sum(losses) / len(losses) if losses else 0
        ev = (avg_win * win_rate) + (avg_loss * loss_rate)
        return {"ready": True, "total": len(rows), "win_rate": win_rate,
                "avg_win": avg_win, "avg_loss": avg_loss, "expected_value": ev}


# ------------------------- 11. RISK MANAGER dengan max open position -------------------------
class EnhancedRiskManager:
    def __init__(self, db_path=DB_FILE, daily_loss_limit=-5.0, consecutive_loss_limit=3, max_open_positions=3):
        self.db_path = db_path
        self.daily_loss_limit = daily_loss_limit
        self.consecutive_loss_limit = consecutive_loss_limit
        self.max_open_positions = max_open_positions
        self._init_table()
    def _init_table(self):
        with sqlite3.connect(self.db_path) as conn:
            conn.execute("CREATE TABLE IF NOT EXISTS risk_state (key TEXT PRIMARY KEY, value REAL, date TEXT)")
    def _get_today(self): return datetime.now().strftime("%Y-%m-%d")
    def record_loss(self, profit_percent: float):
        today = self._get_today()
        with sqlite3.connect(self.db_path) as conn:
            cur = conn.execute("SELECT value FROM risk_state WHERE key='daily_loss' AND date=?", (today,))
            daily = (cur.fetchone() or (0,))[0] + profit_percent
            conn.execute("INSERT OR REPLACE INTO risk_state VALUES (?,?,?)", ("daily_loss", daily, today))
            cur = conn.execute("SELECT value FROM risk_state WHERE key='consecutive_loss'")
            consec = (cur.fetchone() or (0,))[0] + 1 if profit_percent < 0 else 0
            conn.execute("INSERT OR REPLACE INTO risk_state VALUES (?,?,?)", ("consecutive_loss", consec, today))
    def is_kill_switch_active(self) -> bool:
        today = self._get_today()
        with sqlite3.connect(self.db_path) as conn:
            cur = conn.execute("SELECT value FROM risk_state WHERE key='daily_loss' AND date=?", (today,))
            daily_loss = (cur.fetchone() or (0,))[0]
            cur = conn.execute("SELECT value FROM risk_state WHERE key='consecutive_loss'")
            consec_loss = (cur.fetchone() or (0,))[0]
        return (daily_loss <= self.daily_loss_limit) or (consec_loss >= self.consecutive_loss_limit)
    def can_open_new_position(self, current_positions: int) -> bool:
        return current_positions < self.max_open_positions


# ------------------------- 12. ADAPTIVE VALIDATOR (gabungan semua layer) -------------------------
class AdaptiveValidator:
    def __init__(self, min_score=60):
        self.scorer = AdaptiveScorer()
        self.momentum = MomentumChecker()
        self.ai_rejector = AIRejector()
        self.min_score = min_score
    async def validate(self, data: Dict, intel_report: Dict, mint: str) -> Tuple[bool, int, str, Dict]:
        if not data: return False, 0, "Data kosong", {}
        required = ["liquidity_usd", "volume_h24", "txns_h24_buys", "txns_h24_sells"]
        for r in required:
            if data.get(r, 0) == 0: return False, 0, f"Missing {r}", {}
        self.scorer.update_market_baseline(data)
        score = self.scorer.score(data)
        if score < self.min_score:
            return False, score, f"Score {score} < {self.min_score}", {}
        momentum_info = await self.momentum.check(mint)
        if momentum_info["momentum_score"] < -30:
            return False, score, f"Momentum buruk: {momentum_info}", momentum_info
        reject, ai_reason = await self.ai_rejector.should_reject(intel_report)
        if reject:
            return False, score, f"AI reject: {ai_reason}", momentum_info
        return True, score, f"Lolos semua layer", momentum_info


# ------------------------- 13. SLOW ADJUSTER (MetaGovernor tidak terlalu cepat) -------------------------
class SlowAdjuster:
    def __init__(self, min_trades=100, min_change_winrate=0.05, min_change_ev=2.0):
        self.min_trades = min_trades
        self.min_change_winrate = min_change_winrate
        self.min_change_ev = min_change_ev
        self.last_winrate = None
        self.last_ev = None
    async def maybe_adjust(self, meta_governor, trade_logger: EnhancedTradeLogger):
        stats = trade_logger.get_expected_value(min_trades=self.min_trades)
        if not stats["ready"]: return False
        current_winrate = stats["win_rate"]
        current_ev = stats["expected_value"]
        if self.last_winrate is None:
            self.last_winrate = current_winrate; self.last_ev = current_ev; return False
        winrate_change = current_winrate - self.last_winrate
        ev_change = current_ev - self.last_ev
        if abs(winrate_change) >= self.min_change_winrate or abs(ev_change) >= self.min_change_ev:
            old_threshold = meta_governor.global_config.get("score_threshold", 60)
            if current_winrate < 0.45:
                new_threshold = min(80, old_threshold + 5)
            elif current_winrate > 0.65 and current_ev > 2:
                new_threshold = max(50, old_threshold - 5)
            else:
                new_threshold = old_threshold
            if new_threshold != old_threshold:
                meta_governor.global_config["score_threshold"] = new_threshold
                meta_governor.logger.info(f"SlowAdjuster: threshold {old_threshold} -> {new_threshold} (winrate={current_winrate:.2f}, ev={current_ev:.2f})")
            self.last_winrate = current_winrate; self.last_ev = current_ev
            return True
        return False


