            self.state["mode"] = "aggressive"
            self.state["risk_tolerance"] = min(0.9, self.state["risk_tolerance"] + 0.05)
            self.global_config["trade_size_pct"] = min(0.1, self.global_config["trade_size_pct"] * 1.2)
            self.logger.info("Switching to AGGRESSIVE mode due to good performance")
        else:
            self.state["mode"] = "normal"
        if self.state["mode"] == "cautious":
            self.global_config["min_confidence_for_codegen"] = 0.85
            self.global_config["uhee_evolution_interval"] = 7200
            self.global_config["max_concurrent_tasks"] = 2
