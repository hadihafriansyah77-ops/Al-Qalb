class IntelligenceLayer:
    """Menyatukan FinancialIntelligence, OperationalIntelligence, dan U-HEE untuk mempengaruhi SETIAP langkah bot secara real-time."""
    def __init__(self, financial_intel, op_intel, uhee_engine):
