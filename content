                with open(LOCAL_BRAIN_FILE, 'r', encoding='utf-8') as f:
                    self.knowledge_nodes = json.load(f)
                log.info(f"Local Brain loaded: {len(self.knowledge_nodes)} nodes")
            except Exception as e:
                log.warning(f"Failed to load local brain: {e}")
                self.knowledge_nodes = []
        else:
            self.knowledge_nodes = []
            log.info("Local Brain created (new file)")

    def save_brain(self):
        try:
            with open(LOCAL_BRAIN_FILE, 'w', encoding='utf-8') as f:
                json.dump(self.knowledge_nodes, f, indent=2, ensure_ascii=False)
            log.info(f"Local Brain saved: {len(self.knowledge_nodes)} nodes")
            return True
        except Exception as e:
            log.error(f"Failed to save local brain: {e}")
            return False

    def add_knowledge(self, new_nodes: List[Dict]) -> int:
        existing_ids = {node["id"] for node in self.knowledge_nodes}
        added_count = 0
        updated_count = 0
        for node in new_nodes:
            if node["id"] in existing_ids:
                for i, old_node in enumerate(self.knowledge_nodes):
                    if old_node["id"] == node["id"]:
                        self.knowledge_nodes[i] = node
                        updated_count += 1
                        break
            else:
                self.knowledge_nodes.append(node)
                added_count += 1
        self.save_brain()
        return added_count + updated_count

    def query(self, query_text: str, limit: int = 5, epistemic_filter: List[str] = None) -> List[Dict]:
        query_lower = query_text.lower()
        relevant = []
        for node in self.knowledge_nodes:
            if epistemic_filter and node.get('epistemic_type') not in epistemic_filter:
                continue
            score = 0
            if query_lower in node['statement'].lower():
                score += 10
            for tag in node.get('tags', []):
                if query_lower in tag.lower():
                    score += 5
            if query_lower in node['topic'].lower():
                score += 3
            if query_lower in node.get('subtopic', "").lower():
                score += 2
            ep_type = node.get('epistemic_type', "")
            if ep_type == "decision_rule":
                score += 20
            elif ep_type == "failure_mode":
                score += 15
            elif ep_type == "procedural":
                score += 10
            elif ep_type == "causal":
                score += 5
            if score > 0:
                relevant.append((score, node))
        relevant.sort(key=lambda x: x[0], reverse=True)
        return [node for score, node in relevant[:limit]]

    def get_decision_rule(self, context: str) -> Optional[Dict]:
        rules = self.query(context, limit=3, epistemic_filter=["decision_rule"])
        return rules[0] if rules else None

    def get_procedure(self, task: str) -> Optional[Dict]:
        procedures = self.query(task, limit=3, epistemic_filter=["procedural"])
        return procedures[0] if procedures else None

    def get_failure_mode(self, action: str) -> Optional[Dict]:
        failures = self.query(action, limit=2, epistemic_filter=["failure_mode"])
        return failures[0] if failures else None

    def get_causal(self, phenomenon: str) -> Optional[Dict]:
        causals = self.query(phenomenon, limit=2, epistemic_filter=["causal"])
        return causals[0] if causals else None

    def get_heuristic(self, problem: str) -> Optional[Dict]:
        heuristics = self.query(problem, limit=2, epistemic_filter=["heuristic"])
        return heuristics[0] if heuristics else None

    def answer_from_brain(self, query: str) -> Optional[str]:
        nodes = self.query(query, limit=5)
        if not nodes:
            return None
        answer = "🧠 **[Local Brain]**\n\n"
        for node in nodes:
            answer += f"- [[{node['epistemic_type'].upper()}]] {node['statement']}\n"
        answer += "\n(Sumber: " + ", ".join(set(node['topic'] for node in nodes)) + ")"
        return answer

    def execute_action(self, action: str, params: Dict = None) -> Dict:
        procedure = self.get_procedure(action)
        if not procedure:
            return {"success": False, "error": f"Tidak ada prosedur untuk '{action}' di Local Brain"}
        warning = self.get_failure_mode(action)
        causal = self.get_causal(action)
        output = f"📋 **Prosedur untuk '{action}':**\n{procedure['statement']}"
        if warning:
            output += f"\n\n⚠️ **Peringatan:** {warning['statement']}"
        if causal:
            output += f"\n\n🔗 **Sebab-akibat:** {causal['statement']}"
        return {"success": True, "output": output, "procedure": procedure, "warning": warning, "causal": causal}

    def delete_topic(self, topic: str) -> int:
        original_count = len(self.knowledge_nodes)
        self.knowledge_nodes = [node for node in self.knowledge_nodes if node["topic"].lower() != topic.lower()]
        deleted = original_count - len(self.knowledge_nodes)
        if deleted > 0:
            self.save_brain()
        return deleted

    def reset_brain(self) -> int:
        count = len(self.knowledge_nodes)
        self.knowledge_nodes = []
        self.save_brain()
        return count

    def get_all_topics(self) -> List[str]:
        return list(set(node["topic"] for node in self.knowledge_nodes))

    def get_topic_summary(self, topic: str) -> List[Dict]:
        return [node for node in self.knowledge_nodes if node["topic"].lower() == topic.lower()]

