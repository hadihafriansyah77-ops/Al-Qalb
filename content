class CooldownTracker:
    def __init__(self, cooldown_minutes=15):
        self.cooldown_seconds = cooldown_minutes * 60
        self.last_check = {}

    def can_check(self, mint: str) -> bool:
        now = time.time()
        last = self.last_check.get(mint, 0)
        if now - last >= self.cooldown_seconds:
            self.last_check[mint] = now
            return True
        return False

class SplitEntryManager:
    def __init__(self, split_ratio=0.7, confirmation_pct=1.0, max_entries=3):
        self.split_ratio = split_ratio
        self.confirmation_pct = confirmation_pct
        self.max_entries = max_entries
        self.positions = {}

    def first_entry(self, mint: str, total_sol: float, price: float) -> float:
        amount = total_sol * self.split_ratio
        self.positions[mint] = {"remaining": total_sol - amount, "entries": 1, "avg_price": price}
        return amount

    def can_add(self, mint: str) -> bool:
        if mint not in self.positions: return False
        return self.positions[mint]["entries"] < self.max_entries and self.positions[mint]["remaining"] > 0.0001

class FlowTracker:
    def __init__(self, window_seconds=30, spike_threshold=1.5, sustain_seconds=15):
        self.window_seconds = window_seconds
        self.spike_threshold = spike_threshold
        self.sustain_seconds = sustain_seconds
        self.history = {}

    def _get_or_create(self, mint: str):
        if mint not in self.history: self.history[mint] = deque(maxlen=100)
        return self.history[mint]

    async def update(self, mint: str):
        data = await get_token_data(mint)
        if not data: return
        now = time.time()
        volume = data.get("volume_h24", 0)
        buys = data.get("txns_h24_buys", 0)
        sells = data.get("txns_h24_sells", 0)
        buy_ratio = buys / (buys + sells) if (buys + sells) > 0 else 0.5
        self._get_or_create(mint).append((now, volume, buy_ratio))

    def analyze(self, mint: str) -> Dict:
        hist = self._get_or_create(mint)
        if len(hist) < 3: return {"acceleration": 0, "is_spiking": False, "is_sustained": False, "flow_score": 0}
        now = time.time()
        window_start = now - self.window_seconds
        recent = [(t, v, r) for t, v, r in hist if t >= window_start]
        if len(recent) < 2: return {"acceleration": 0, "is_spiking": False, "is_sustained": False, "flow_score": 0}
        times = [p[0] for p in recent]
        volumes = [p[1] for p in recent]
        ratios = [p[2] for p in recent]
        vol_change = (volumes[-1] - volumes[0]) / max(volumes[0], 1) if volumes[0] > 0 else 0
        ratio_change = ratios[-1] - ratios[0]
        flow_score = (vol_change * 50) + (ratio_change * 50)
        is_spiking = vol_change > self.spike_threshold
        is_sustained = is_spiking and (times[-1] - times[0] >= self.sustain_seconds)
        return {"acceleration": vol_change, "is_spiking": is_spiking, "is_sustained": is_sustained, "flow_score": flow_score}

class SmartMoneyDetector:
    def __init__(self, large_tx_threshold=1000):
        self.large_tx_threshold = large_tx_threshold
        self.history = {}

    def _get_or_create(self, mint: str):
        if mint not in self.history: self.history[mint] = deque(maxlen=50)
        return self.history[mint]

    async def analyze(self, mint: str, data: Dict) -> Dict:
        volume = data.get("volume_h24", 0)
        buys = data.get("txns_h24_buys", 0)
        sells = data.get("txns_h24_sells", 0)
        total_tx = buys + sells
        if total_tx == 0 or volume == 0:
            return {"smart_money_present": False, "whale_dominance": 0, "retail_chaos": False, "signal": "neutral"}
        avg_tx_size = volume / total_tx
        self._get_or_create(mint).append((time.time(), avg_tx_size))
        whale_dominance = min(100, (avg_tx_size / self.large_tx_threshold) * 100)
        smart_money = avg_tx_size > self.large_tx_threshold
        hist = list(self._get_or_create(mint))
        retail_chaos = False
        if len(hist) >= 3:
            recent_avg = hist[-1][1]
            older_avg = hist[0][1]
            avg_increase = (recent_avg - older_avg) / max(older_avg, 1)
            retail_chaos = (total_tx > 100 and recent_avg < self.large_tx_threshold * 0.3 and avg_increase > 0.5)
        if smart_money: signal = "whale_accumulation"
        elif retail_chaos: signal = "retail_fomo"
        else: signal = "neutral"
        return {"smart_money_present": smart_money, "whale_dominance": whale_dominance,
                "retail_chaos": retail_chaos, "signal": signal, "avg_tx_size_usd": avg_tx_size}

class ExitManager:
    def __init__(self, trailing_pct=3, momentum_exit_threshold=-30, buy_pressure_drop=0.15):
        self.trailing_pct = trailing_pct
        self.momentum_exit_threshold = momentum_exit_threshold
        self.buy_pressure_drop = buy_pressure_drop
        self.positions = {}
        self.peak_volumes = {}
        self.ath_prices = {}
        self.last_flow_scores = {}
        self.last_buy_ratios = {}
        self.dynamic_tp_pct = 15.0
        self.dynamic_sl_pct = -8.0

    def register_position(self, mint: str, pos: Dict):
        self.positions[mint] = pos
        self.ath_prices[mint] = pos.get("entry_price", 0)
        self.last_flow_scores[mint] = 0
        self.last_buy_ratios[mint] = 0.5

    def update_price(self, mint: str, price: float):
        if mint in self.ath_prices and price > self.ath_prices[mint]:
            self.ath_prices[mint] = price

    def update_flow(self, mint: str, flow_score: float, buy_ratio: float):
        self.last_flow_scores[mint] = flow_score
        self.last_buy_ratios[mint] = buy_ratio

    def update_volume(self, mint: str, volume: float):
        if mint not in self.peak_volumes or volume > self.peak_volumes[mint]:
            self.peak_volumes[mint] = volume

    def should_exit(self, mint: str, current_price: float, current_flow_score: float,
                    current_buy_ratio: float, current_volume: float) -> Tuple[bool, str]:
        if mint not in self.positions: return False, ""
        pos = self.positions[mint]
        entry = pos.get("entry_price", current_price)
        profit_pct = (current_price - entry) / entry * 100
        ath = self.ath_prices.get(mint, entry)
        if profit_pct >= self.dynamic_tp_pct: return True, f"TP_dynamic_{profit_pct:.1f}%"
        if profit_pct <= self.dynamic_sl_pct: return True, f"SL_dynamic_{profit_pct:.1f}%"
        if (ath - current_price) / ath * 100 >= self.trailing_pct:
            return True, f"trailing_stop_{self.trailing_pct}%"
        if current_volume > 0 and mint in self.peak_volumes and self.peak_volumes[mint] > 0:
            if current_volume < self.peak_volumes[mint] * 0.5:
                return True, f"volume_collapse_{current_volume/self.peak_volumes[mint]:.0%}"
        if (pos.get("last_buy_ratio", 0.5) - current_buy_ratio) > self.buy_pressure_drop:
            return True, f"buy_pressure_drop_{((pos['last_buy_ratio'] - current_buy_ratio)*100):.0f}%"
        self.update_flow(mint, current_flow_score, current_buy_ratio)
        self.update_volume(mint, current_volume)
        return False, ""

    def remove_position(self, mint: str):
        self.positions.pop(mint, None)

