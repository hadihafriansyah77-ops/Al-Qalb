        "sentiment_lexicon": {"positive": ["good", "great"], "negative": ["bad", "poor"]}
    },
    "executor": {"output_dir": "./output", "db_path": "./data/aiw_data.db"},
    "self_update": {"enabled": True, "allowed_params": ["loop_interval", "max_concurrent_tasks", "decision.keyword_threshold"], "safe_mode": True}
}

class ConfigManager:
    def __init__(self, config_path: str = "aiw_config.json"):
        self.config_path = Path(config_path)
        self.config = self.load_config()

    def load_config(self) -> Dict:
        if self.config_path.exists():
            try:
                with open(self.config_path) as f:
                    config = json.load(f)
                merged = copy.deepcopy(DEFAULT_AIW_CONFIG)
                self._deep_update(merged, config)
                return merged
            except:
                return copy.deepcopy(DEFAULT_AIW_CONFIG)
        else:
            self.save_config(DEFAULT_AIW_CONFIG)
            return copy.deepcopy(DEFAULT_AIW_CONFIG)

    def save_config(self, config=None):
        with open(self.config_path, 'w') as f:
            json.dump(config or self.config, f, indent=2)

    def _deep_update(self, orig, updates):
        for k, v in updates.items():
            if isinstance(v, dict) and k in orig and isinstance(orig[k], dict):
                self._deep_update(orig[k], v)
            else:
                orig[k] = v

    def update_config(self, updates: Dict, safe=True) -> bool:
        if safe and self.config.get("self_update", {}).get("enabled"):
            allowed = self.config["self_update"].get("allowed_params", [])
            filtered = {}
            for k, v in updates.items():
                if k in allowed:
                    filtered[k] = v
                else:
                    parts = k.split('.')
                    for a in allowed:
                        if a.startswith(parts[0]):
                            filtered[k] = v
                            break
            updates = filtered
        self._deep_update(self.config, updates)
        self.save_config()
        return True

    def get(self, key: str, default=None):
        keys = key.split('.')
        val = self.config
        for k in keys:
            if isinstance(val, dict):
                val = val.get(k)
            else:
                return default
        return val if val is not None else default

