@bot.message_handler(func=lambda m: m.text and m.text.lower().startswith("kerjakan buka "))
async def handle_kerjakan_buka(m):
    if not is_owner(m):
        return
    text = m.text[14:].strip()
    if not text:
        return await bot.send_message(m.chat.id, "Format: kerjakan buka <url> [screenshot/scrape]")
    await bot.send_message(m.chat.id, "🌐 Menjalankan browser task...")
    url = None
    try:
        async with async_playwright() as p:
            browser = await p.chromium.launch(headless=True, args=['--no-sandbox'])
            page = await browser.new_page()
            url_match = re.search(r"https?://[^\s]+", text)
            if not url_match:
                await browser.close()
                return await bot.send_message(m.chat.id, "URL tidak ditemukan.")
            url = url_match.group()
            await page.goto(url, timeout=30000)
            await HumanBehavior.random_delay("page_load")
            if "screenshot" in text.lower():
                path = f"/tmp/ss_{int(time.time())}.png"
                await page.screenshot(path=path, full_page=True)
                with open(path, "rb") as f:
                    await bot.send_photo(m.chat.id, f, caption=f"Screenshot {url}")
                os.unlink(path)
            elif "scrape" in text.lower():
                content = await page.content()
                soup = BeautifulSoup(content, 'lxml')
                text_content = soup.get_text(separator='\n', strip=True)[:4000]
                await bot.send_message(m.chat.id, f"📄 Scraped from {url}:\n\n{text_content}")
            await browser.close()
    except Exception as e:
        await bot.send_message(m.chat.id, f"❌ Browser error: {e}")

