# COOLDOWN TRACKER
class CooldownTracker:
    def __init__(self, cooldown_minutes=15):
        self.cooldown_seconds = cooldown_minutes * 60
        self.last_check = {}

    def can_check(self, mint: str) -> bool:
        now = time.time()
        last = self.last_check.get(mint, 0)
        if now - last >= self.cooldown_seconds:
            self.last_check[mint] = now
            return True
        return False

# SPLIT ENTRY MANAGER
class SplitEntryManager:
    def __init__(self, split_ratio=0.7, confirmation_pct=1.0, confirmation_seconds=60):
        self.split_ratio = split_ratio
        self.confirmation_pct = confirmation_pct
        self.confirmation_seconds = confirmation_seconds
        self.pending = {}

    def first_entry(self, mint: str, total_amount: float, entry_price: float):
        first_amt = total_amount * self.split_ratio
        remaining = total_amount - first_amt
        self.pending[mint] = {"first_entry_price": entry_price, "remaining_amount": remaining, "timestamp": time.time()}
        return first_amt

    async def check_second_entry(self, mint: str, current_price: float) -> float:
        if mint not in self.pending:
            return 0.0
        pending = self.pending[mint]
        elapsed = time.time() - pending["timestamp"]
        if elapsed > self.confirmation_seconds:
            del self.pending[mint]
            return 0.0
        gain_pct = (current_price - pending["first_entry_price"]) / pending["first_entry_price"] * 100
        if gain_pct >= self.confirmation_pct:
            amount = pending["remaining_amount"]
            del self.pending[mint]
            return amount
        return 0.0

# MARKET CONDITION ANALYZER
class MarketConditionAnalyzer:
    def __init__(self, lookback=20):
        self.volumes = deque(maxlen=lookback)
        self.price_changes = deque(maxlen=lookback)

    def update(self, data: Dict):
        vol = data.get("volume_h24", 0)
        change = abs(data.get("price_change_h24", 0))
        if vol > 0:
            self.volumes.append(vol)
            self.price_changes.append(change)

    def get_condition(self) -> str:
        if len(self.volumes) < 10:
            return "unknown"
        median_vol = statistics.median(self.volumes)
        median_change = statistics.median(self.price_changes)
        latest_vol = self.volumes[-1] if self.volumes else 0
        latest_change = self.price_changes[-1] if self.price_changes else 0
        if latest_vol < median_vol * 0.5:
            return "sunyi"
        elif latest_change > median_change * 3:
            return "chaotic"
        elif latest_vol > median_vol * 1.5 and latest_change < median_change * 1.2:
            return "bullish"
        else:
            return "normal"

    def no_trade_zone(self) -> bool:
        cond = self.get_condition()
        return cond in ("sunyi", "chaotic")

# FLOW TRACKER
class FlowTracker:
    def __init__(self, window_seconds=30, spike_threshold=1.5, sustain_seconds=15):
        self.window_seconds = window_seconds
        self.spike_threshold = spike_threshold
        self.sustain_seconds = sustain_seconds
        self.history = {}

    def _get_or_create(self, mint: str):
        if mint not in self.history:
            self.history[mint] = deque(maxlen=100)
        return self.history[mint]

    async def update(self, mint: str):
        data = await get_token_data(mint)
        if not data:
            return
        now = time.time()
        volume = data.get("volume_h24", 0)
        buys = data.get("txns_h24_buys", 0)
        sells = data.get("txns_h24_sells", 0)
        buy_ratio = buys / (buys + sells) if (buys + sells) > 0 else 0.5
        self._get_or_create(mint).append((now, volume, buy_ratio))

    def analyze(self, mint: str) -> Dict:
        hist = self._get_or_create(mint)
        if len(hist) < 3:
            return {"acceleration": 0, "is_spiking": False, "is_sustained": False, "flow_score": 0}
        now = time.time()
        window_start = now - self.window_seconds
        recent = [(t, v, r) for t, v, r in hist if t >= window_start]
        if len(recent) < 2:
            return {"acceleration": 0, "is_spiking": False, "is_sustained": False, "flow_score": 0}
        times = [p[0] for p in recent]
        vols = [p[1] for p in recent]
        slope = np.polyfit(times, vols, 1)[0] if max(times) - min(times) > 0 else 0
        acceleration = slope * 10
        median_vol = statistics.median([v for _, v, _ in recent])
        last_vol = recent[-1][1]
        is_spiking = last_vol > median_vol * self.spike_threshold if median_vol > 0 else False
        is_sustained = False
        if is_spiking and len(hist) > 1:
            sustain_start = now - self.sustain_seconds
            high_volumes = [v for t, v, _ in hist if t >= sustain_start and v > median_vol * self.spike_threshold]
            is_sustained = len(high_volumes) >= 2
        flow_score = 0
        if acceleration > 50:
            flow_score += 40
        elif acceleration > 20:
            flow_score += 20
        if is_spiking and is_sustained:
            flow_score += 60
        elif is_spiking:
            flow_score += 30
        flow_score = max(-100, min(100, flow_score))
        return {"acceleration": acceleration, "is_spiking": is_spiking, "is_sustained": is_sustained, "flow_score": flow_score}

# SMART MONEY DETECTOR
class SmartMoneyDetector:
    def __init__(self, large_tx_threshold_usd=10000):
        self.large_tx_threshold = large_tx_threshold_usd
        self.history = {}

    def _get_or_create(self, mint: str):
        if mint not in self.history:
            self.history[mint] = deque(maxlen=20)
        return self.history[mint]

    async def analyze(self, mint: str, data: Dict) -> Dict:
        volume = data.get("volume_h24", 0)
        buys = data.get("txns_h24_buys", 0)
        sells = data.get("txns_h24_sells", 0)
        total_tx = buys + sells
        if total_tx == 0 or volume == 0:
            return {"smart_money_present": False, "whale_dominance": 0, "retail_chaos": False, "signal": "neutral"}
        avg_tx_size = volume / total_tx
        self._get_or_create(mint).append((time.time(), avg_tx_size))
        whale_dominance = min(100, (avg_tx_size / self.large_tx_threshold) * 100)
        smart_money = avg_tx_size > self.large_tx_threshold
        hist = list(self._get_or_create(mint))
        retail_chaos = False
        if len(hist) >= 3:
            recent_avg = hist[-1][1]
            older_avg = hist[0][1]
            avg_increase = (recent_avg - older_avg) / max(older_avg, 1)
            retail_chaos = (total_tx > 100 and recent_avg < self.large_tx_threshold * 0.3 and avg_increase > 0.5)
        if smart_money:
            signal = "whale_accumulation"
        elif retail_chaos:
            signal = "retail_fomo"
        else:
            signal = "neutral"
        return {"smart_money_present": smart_money, "whale_dominance": whale_dominance, "retail_chaos": retail_chaos, "signal": signal, "avg_tx_size_usd": avg_tx_size}

# EXIT MANAGER
class ExitManager:
    def __init__(self, trailing_pct=3, momentum_exit_threshold=-30, buy_pressure_drop=0.15):
        self.trailing_pct = trailing_pct
        self.momentum_exit_threshold = momentum_exit_threshold
        self.buy_pressure_drop = buy_pressure_drop
        self.positions = {}
        self.peak_volumes = {}
        self.ath_prices = {}
        self.last_flow_scores = {}
        self.last_buy_ratios = {}

    def register_position(self, mint: str, pos: Dict):
        self.positions[mint] = pos
        self.ath_prices[mint] = pos.get("entry_price", 0)
        self.last_flow_scores[mint] = 0
        self.last_buy_ratios[mint] = 0.5

    def update_price(self, mint: str, price: float):
        if mint in self.ath_prices and price > self.ath_prices[mint]:
            self.ath_prices[mint] = price

    def update_flow(self, mint: str, flow_score: float, buy_ratio: float):
        self.last_flow_scores[mint] = flow_score
        self.last_buy_ratios[mint] = buy_ratio

    def update_volume(self, mint: str, volume: float):
        if mint not in self.peak_volumes or volume > self.peak_volumes[mint]:
            self.peak_volumes[mint] = volume

    def should_exit(self, mint: str, current_price: float, current_flow_score: float, current_buy_ratio: float, current_volume: float) -> Tuple[bool, str]:
        if mint not in self.positions:
            return False, ""
        pos = self.positions[mint]
        entry = pos.get("entry_price", current_price)
        profit_pct = (current_price - entry) / entry * 100
        ath = self.ath_prices.get(mint, entry)

        # 1. Take profit bertahap (3% -> exit jika momentum turun)
        if profit_pct >= 3:
            if current_flow_score < pos.get("last_flow_score", 0) - 10:
                return True, f"TP_momentum_drop_{profit_pct:.1f}%"

        # 2. Take profit utama (5%)
        if profit_pct >= 5:
            return True, f"TP_target_{profit_pct:.1f}%"

        # 3. Trailing stop lebih ketat (3% dari ATH)
        if (ath - current_price) / ath * 100 >= self.trailing_pct:
            return True, f"trailing_stop_{self.trailing_pct}pt"

        # 4. Volume collapse (turn > 50% dari peak)
        if current_volume > 0 and mint in self.peak_volumes and self.peak_volumes[mint] > 0:
            if current_volume < self.peak_volumes[mint] * 0.5:
                return True, f"volume_collapse_{current_volume/self.peak_volumes[mint]:.0%}"

        # 5. Buy pressure turun drastis (>15%)
        if (pos.get("last_buy_ratio", 0.5) - current_buy_ratio) > self.buy_pressure_drop:
            return True, f"buy_pressure_drop_{((pos['last_buy_ratio'] - current_buy_ratio)*100):.0f}%"

        # 6. Stop loss -3%
        if profit_pct <= -3:
            return True, f"SL_{profit_pct:.1f}%"

        self.update_flow(mint, current_flow_score, current_buy_ratio)
        self.update_volume(mint, current_volume)
        return False, ""

    def remove_position(self, mint: str):
        self.positions.pop(mint, None)

