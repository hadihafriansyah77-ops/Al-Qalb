class InputAbstractionLayer:
    @staticmethod
    def _detect_domain(df: pd.DataFrame, source_name: str) -> DataDomain:
        cols = [c.lower() for c in df.columns]
        if any('time' in c or 'date' in c for c in cols): return DataDomain.TIME_SERIES
        if any('metric' in c or 'cpu' in c or 'memory' in c for c in cols): return DataDomain.SYSTEM_METRIC
        return DataDomain.TABULAR

    @staticmethod
    def _enforce_real_data(df: pd.DataFrame, source_name: str):
        if df is None or len(df) == 0: raise ValueError(f"Source {source_name} is empty.")
        if len(df) < MIN_DATA_ROWS:
            log.warning(f"[Real-Data] {source_name} has only {len(df)} rows - minimum {MIN_DATA_ROWS} recommended.")
        numeric = df.select_dtypes(include=[np.number])
        if numeric.empty: raise ValueError("No numeric columns")

    def ingest(self, data, source_name="input", timestamp_col=None) -> UniversalDataFrame:
        if isinstance(data, pd.DataFrame): raw_df = data.copy()
        elif isinstance(data, (str, Path)):
            path = Path(data)
            if path.suffix == '.csv': raw_df = pd.read_csv(path)
            elif path.suffix in ['.json', '.jsonl']: raw_df = pd.read_json(path, lines=(path.suffix == '.jsonl'))
            else: raise ValueError("Unsupported format")
        elif isinstance(data, dict): raw_df = pd.DataFrame(data)
        else: raise TypeError("Unsupported type")
        timestamps = None
        if timestamp_col and timestamp_col in raw_df.columns:
            timestamps = pd.to_datetime(raw_df[timestamp_col])
            raw_df = raw_df.drop(columns=[timestamp_col])
        numeric_df = raw_df.select_dtypes(include=[np.number])
        self._enforce_real_data(numeric_df, source_name)
        minv = numeric_df.min()
        maxv = numeric_df.max()
        rng = maxv - minv
        rng[rng == 0] = 1.0
        norm = (numeric_df - minv) / rng
        domain = self._detect_domain(raw_df, source_name)
        return UniversalDataFrame(source_name, domain, norm, timestamps,
                                  {"col_min": minv.to_dict(), "col_max": maxv.to_dict()})

class BacktestingLayer:
    def __init__(self, window_size=20, step=5):
        self.window_size = window_size
        self.step = step

    def _eval_condition(self, window: pd.DataFrame, feature: str, cond: dict) -> bool:
        if feature not in window.columns: return False
        series = window[feature]
        op = cond.get("op", ">")
        value = cond.get("value", 0.0)
        if op == ">": return bool((series > value).mean() > 0.5)
        if op == "<": return bool((series < value).mean() > 0.5)
        if op == "trend":
            slope = np.polyfit(np.arange(len(series)), series.values, 1)[0]
            direction = cond.get("direction", "rising")
            return (slope > 0) if direction == "rising" else (slope < 0)
        return False

    def _antecedent_fires(self, window: pd.DataFrame, hyp: Hypothesis) -> bool:
        for feat, cond in hyp.antecedent.items():
            if isinstance(cond, dict):
                if not self._eval_condition(window, feat, cond): return False
        return True

    def _consequent_observed(self, next_window: pd.DataFrame, hyp: Hypothesis) -> bool:
        for feat, exp in hyp.consequent.items():
            if feat not in next_window.columns: continue
            series = next_window[feat]
            direction = exp.get("direction", "change")
            if direction in ("increase", "spike", "rising", "positive"): return bool(series.diff().mean() > 0)
            if direction in ("decrease", "falling", "negative"): return bool(series.diff().mean() < 0)
        return False

    def evaluate(self, hyp: Hypothesis, udf: UniversalDataFrame) -> Hypothesis:
        df = udf.df
        n = len(df)
        ws = self.window_size
        step = self.step
        n_triggers = 0
        n_correct = 0
        for start in range(0, n - ws * 2, step):
            mid = start + ws
            end = mid + ws
            if end > n: break
            window = df.iloc[start:mid]
            next_window = df.iloc[mid:end]
            if self._antecedent_fires(window, hyp):
                n_triggers += 1
                if self._consequent_observed(next_window, hyp): n_correct += 1
        confidence = n_correct / (n_triggers + 1e-9)
        error_rate = 1.0 - confidence
        risk_score = float(np.clip(1.0 - confidence + 0.3 * (1.0 / (n_triggers + 1e-9)), 0, 1))
        hyp.confidence = confidence
        hyp.error_rate = error_rate
        hyp.risk_score = risk_score
        hyp.fitness = confidence * 0.5 + (1.0 - risk_score) * 0.3 + hyp.novelty_score * 0.2
        return hyp

class UHEEEngine:
    def __init__(self, evolution_cycles=EVOLUTION_CYCLES, population_size=POPULATION_SIZE,
                 window_size=20, backtest_step=5, seed=42):
        self.evolution_cycles = evolution_cycles
        self.population_size = population_size
        self.input_layer = InputAbstractionLayer()
        self.backtester = BacktestingLayer(window_size, backtest_step)
        self.rng = random.Random(seed)
        self.population: List[Hypothesis] = []
        self.history = []
        self.cycle_count = 0

    def _generate_hypotheses(self, udf: UniversalDataFrame, generation=0) -> List[Hypothesis]:
        hyp = []
        cols = list(udf.df.columns)
        for i in range(min(5, len(cols))):
            for j in range(i+1, min(i+3, len(cols))):
                corr = udf.df[cols[i]].corr(udf.df[cols[j]])
                if abs(corr) > 0.3:
                    desc = f"Correlation between {cols[i]} and {cols[j]} (r={corr:.3f})"
                    h = Hypothesis(uid=hashlib.md5(desc.encode()).hexdigest()[:12],
                                   htype=HypothesisType.CORRELATION, description=desc,
                                   antecedent={cols[i]: {"op": ">", "value": udf.df[cols[i]].mean()}},
                                   consequent={cols[j]: {"direction": "increase" if corr > 0 else "decrease", "prob": abs(corr)}},
                                   parameters={"rho": corr}, generation=generation)
                    hyp.append(h)
        for col in cols[:5]:
            thr = udf.df[col].mean() + udf.df[col].std()
            desc = f"When {col} exceeds {thr:.4f}, system responds"
            h = Hypothesis(uid=hashlib.md5(desc.encode()).hexdigest()[:12],
                           htype=HypothesisType.THRESHOLD, description=desc,
                           antecedent={col: {"op": ">", "value": thr}},
                           consequent={col: {"direction": "increase", "prob": 0.6}},
                           parameters={"threshold": thr}, generation=generation)
            hyp.append(h)
        return hyp[:self.population_size]

    def run_cycle(self, data, source_name="dataset") -> Dict:
        udf = self.input_layer.ingest(data, source_name)
        if not self.population: self.population = self._generate_hypotheses(udf, generation=0)
        for hyp in self.population: self.backtester.evaluate(hyp, udf)
        self.population.sort(key=lambda h: h.fitness, reverse=True)
        survivors = self.population[:self.population_size//2]
        new_pop = survivors.copy()
        while len(new_pop) < self.population_size:
            parent = self.rng.choice(survivors)
            child = copy.deepcopy(parent)
            child.generation = self.cycle_count + 1
            child.uid = hashlib.md5(f"{child.description}{time.time()}{random.random()}".encode()).hexdigest()[:12]
            for k in child.parameters: child.parameters[k] *= self.rng.uniform(0.8, 1.2)
            child.novelty_score = self.rng.random()
            new_pop.append(child)
        self.population = new_pop
        self.cycle_count += 1
        fitnesses = [h.fitness for h in self.population]
        stats = {"cycle": self.cycle_count, "best": max(fitnesses), "mean": np.mean(fitnesses), "std": np.std(fitnesses)}
        self.history.append(stats)
        return {"top_hypotheses": self.population[:5], "stats": stats, "n_rows": udf.n_rows}

    async def background_evolution(self, data_source_callback, interval=3600):
        while not kill_check():
            try:
                data = await data_source_callback()
                if data is not None and len(data) >= 5:
                    result = self.run_cycle(data, "periodic_data")
                    log.info(f"U-HEE cycle {self.cycle_count}: best fitness={result['stats']['best']:.3f}")
                    if result['top_hypotheses']:
                        best = result['top_hypotheses'][0]
                        if best.confidence > 0.6 and "threshold" in best.parameters:
                            current_thr = aiw_config.get("decision.keyword_threshold", 5)
                            new_thr = int(best.parameters.get("threshold", current_thr))
                            new_thr = max(3, min(20, new_thr))
                            if new_thr != current_thr:
                                aiw_config.update_config({"decision.keyword_threshold": new_thr}, safe=True)
                                log.info(f"U-HEE adapted keyword_threshold: {current_thr} -> {new_thr}")
            except Exception as e: log.warning(f"U-HEE background error: {e}")
            await asyncio.sleep(interval)

