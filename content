    def __init__(self, config: ConfigManager, logger: logging.Logger):
        self.config = config
        self.logger = logger
        self.session: Optional[aiohttp.ClientSession] = None

    async def start(self):
        self.session = aiohttp.ClientSession(headers={'User-Agent': self.config.get("scraping.user_agent", "Mozilla/5.0")})

    async def close(self):
        if self.session: await self.session.close()

    async def collect_hackernews(self) -> List[Dict]:
        rss = self.config.get("scraping.hackernews_rss")
        try:
            async with self.session.get(rss) as resp:
                feed = feedparser.parse(await resp.text())
                return [{"title": e.title, "url": e.link, "content": e.get("summary", ""), "source": "hackernews"}
                        for e in feed.entries[:20]]
        except Exception as e:
            self.logger.error(f"HN error: {e}")
            return []

    async def collect_reddit_trending(self) -> List[Dict]:
        url = self.config.get("scraping.reddit_trending")
        try:
            async with self.session.get(url) as resp:
                data = await resp.json()
                items = []
                for child in data.get("data", {}).get("children", [])[:20]:
                    d = child.get("data", {})
                    items.append({"title": d.get("title"), "url": d.get("url"), "content": d.get("selftext", ""), "source": "reddit"})
                return items
        except: return []

    async def collect_all(self) -> Dict[str, List[Dict]]:
        hn, reddit = await asyncio.gather(self.collect_hackernews(), self.collect_reddit_trending(), return_exceptions=True)
        return {"hackernews": hn if not isinstance(hn, Exception) else [],
                "reddit": reddit if not isinstance(reddit, Exception) else []}

