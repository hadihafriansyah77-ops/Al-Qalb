    async def random_delay(delay_type: str = "click"):
        mn, mx = HumanBehavior.HUMAN_DELAYS.get(delay_type, (0.5,1.5))
        d = random.uniform(mn, mx)
        if random.random() < 0.05: d *= 0.5
        if random.random() < 0.05: d *= 1.5
        await asyncio.sleep(d)
    @staticmethod
    async def human_typing(page, selector: str, text: str):
        element = await page.query_selector(selector)
        if element:
            await element.click()
            for ch in text:
                await page.keyboard.type(ch, delay=random.uniform(50,150))
                if random.random() < 0.02: await asyncio.sleep(random.uniform(0.2,0.5))
            await HumanBehavior.random_delay("think")

