def send_sol_tx(to_addr: str, amount_sol: float) -> str:
    if not PRIVATE_KEY_BOT:
        raise RuntimeError("PRIVATE_KEY_BOT not set")
    try:
        key_bytes = json.loads(PRIVATE_KEY_BOT)
        kp = Keypair.from_bytes(bytes(key_bytes))
    except:
        kp = Keypair.from_base58_string(PRIVATE_KEY_BOT)
    dest = Pubkey.from_string(to_addr)
    lamports = int(amount_sol * 1_000_000_000)
    blockhash = sol_client.get_latest_blockhash().value.blockhash
    ix = transfer(TransferParams(from_pubkey=kp.pubkey(), to_pubkey=dest, lamports=lamports))
    msg = MessageV0.try_compile(kp.pubkey(), [ix], [], blockhash)
    tx = VersionedTransaction(msg, [kp])
    return str(sol_client.send_transaction(tx).value)

async def jupiter_swap(input_mint: str, output_mint: str, amount_lamports: int, slippage_bps: int = 100) -> Optional[str]:
    try:
        if not PRIVATE_KEY_BOT:
            return None
        try:
            key_bytes = json.loads(PRIVATE_KEY_BOT)
            kp = Keypair.from_bytes(bytes(key_bytes))
        except:
            kp = Keypair.from_base58_string(PRIVATE_KEY_BOT)
        quote_url = f"{JUPITER_API}/quote?inputMint={input_mint}&outputMint={output_mint}&amount={amount_lamports}&slippageBps={slippage_bps}"
        async with aiohttp.ClientSession() as s:
            async with s.get(quote_url) as r:
                if r.status != 200:
                    return None
                quote = await r.json()
            swap_url = f"{JUPITER_API}/swap"
            payload = {
                "quoteResponse": quote,
                "userPublicKey": str(kp.pubkey()),
                "wrapAndUnwrapSol": True,
                "dynamicComputeUnitLimit": True,
                "prioritizationFeeLamports": "auto"
            }
            async with s.post(swap_url, json=payload) as r2:
                if r2.status != 200:
                    return None
                swap_data = await r2.json()
            tx_bytes = base64.b64decode(swap_data["swapTransaction"])
            tx = VersionedTransaction.from_bytes(tx_bytes)
            tx.sign([kp])
            opts = TxOpts(skip_preflight=False, preflight_commitment=CommitmentLevel.CONFIRMED)
            sig = sol_client.send_transaction(tx, opts).value
            return str(sig)
    except Exception as e:
        log.error(f"Jupiter swap error: {e}")
        return None

# BINANCE TRADER
class BinanceTrader:
    def __init__(self, api_key: str, secret_key: str, testnet: bool = True):
        self.client = BinanceClient(api_key, secret_key, testnet=testnet)
        self.active = True
        self.logger = logging.getLogger("BinanceTrader")
        self.symbol_info_cache = {}

    def get_symbol_info(self, symbol: str):
        if symbol not in self.symbol_info_cache:
            info = self.client.get_symbol_info(symbol)
            filters = {f['filterType']: f for f in info['filters']}
            self.symbol_info_cache[symbol] = {
                'stepSize': float(filters['LOT_SIZE']['stepSize']),
                'minNotional': float(filters.get('MIN_NOTIONAL', {}).get('minNotional', 10))
            }
        return self.symbol_info_cache[symbol]

    def create_market_buy_order(self, symbol: str, quote_amount_usdt: float):
        try:
            ticker = self.client.get_symbol_ticker(symbol=symbol)
            price = float(ticker['price'])
            quantity = quote_amount_usdt / price
            symbol_info = self.get_symbol_info(symbol)
            if symbol_info:
                step_size = symbol_info['stepSize']
                precision = len(str(step_size).split('.')[1].rstrip('0'))
                quantity = round(quantity - (quantity % step_size), precision)
                min_notional = symbol_info['minNotional']
                if quantity * price < min_notional:
                    self.logger.warning(f"Order value (${quantity * price:.2f}) below min notional (${min_notional})")
                    return None
            order = self.client.order_market_buy(symbol=symbol, quantity=quantity)
            self.logger.info(f"Market BUY executed: {symbol} - {quantity} @ ~${price:.4f}")
            return order
        except BinanceAPIException as e:
            self.logger.error(f"Binance API Error: {e}")
        except BinanceOrderException as e:
            self.logger.error(f"Binance Order Error: {e}")
        except Exception as e:
            self.logger.error(f"Unexpected error: {e}")
        return None

    def create_market_sell_order(self, symbol: str, quantity: float):
        try:
            order = self.client.order_market_sell(symbol=symbol, quantity=quantity)
            self.logger.info(f"Market SELL executed: {symbol} - {quantity}")
            return order
        except Exception as e:
            self.logger.error(f"Error creating sell order: {e}")
            return None

    async def execute_buy_async(self, symbol: str, usdt_amount: float, chat_id):
        loop = asyncio.get_event_loop()
        order = await loop.run_in_executor(None, self.create_market_buy_order, symbol, usdt_amount)
        if order:
            await bot.send_message(chat_id, f"BINANCE BUY: {symbol}\nAmount: ${usdt_amount:.2f}\nOrder ID: {order['orderId']}")
            return True
        return False

    def stop(self):
        self.active = False
        self.logger.info("BinanceTrader stopped.")

