        op_health = await self.op.get_system_health()
        if op_health.get("error_rate", 0) > 0.1:
            params["limit"] = 10
        return params

    async def enhance_entry_decision(self, mint: str, base_score: int, data: Dict, intel_report: Dict) -> Tuple[int, str]:
        adjustment = 0
        reasons = []
        fin_health = self.financial.get_financial_health()
        win_rate = fin_health.get("win_rate", 0.5)
        recent_profit = fin_health.get("recent_profit", 0)
        if win_rate < 0.4:
            adjustment = -15
            reasons.append(f"low_winrate_{win_rate:.0%}")
        elif win_rate > 0.6:
            adjustment += 10
            reasons.append(f"high_winrate_{win_rate:.0%}")
        if recent_profit < -10:
            adjustment -= 20
            reasons.append(f"recent_loss_{recent_profit:.0f}")
        elif recent_profit > 20:
            adjustment += 15
            reasons.append(f"recent_profit_{recent_profit:.0f}")
        op_health = await self.op.get_system_health()
        error_rate = op_health.get("error_rate", 0)
        if error_rate > 0.15:
            adjustment -= 10
            reasons.append(f"high_error_{error_rate:.0%}")
        if self.uhee.population:
            best_hyp = self.uhee.population[0]
            if "threshold" in best_hyp.parameters and best_hyp.confidence > 0.6:
                hyp_threshold = best_hyp.parameters.get("threshold", 0)
                if hyp_threshold > 70:
                    adjustment -= 5
                    reasons.append(f"uhee_cautious_{hyp_threshold:.0f}")
                elif hyp_threshold < 50:
                    adjustment += 10
                    reasons.append(f"uhee_aggressive_{hyp_threshold:.0f}")
        self.decision_cache[mint] = {
            "base_score": base_score,
            "adjustment": adjustment,
            "timestamp": time.time(),
            "reasons": reasons
        }
        adjusted = max(0, min(100, base_score + adjustment))
        reason = f"adj={adjustment:+d}|" + "|".join(reasons[:3])
        return adjusted, reason

    async def enhance_exit_decision(self, mint: str, profit_pct: float, current_price: float, entry_price: float) -> Tuple[bool, str]:
        fin_health = self.financial.get_financial_health()
        win_rate = fin_health.get("win_rate", 0.5)
        if profit_pct >= 3 and win_rate < 0.45:
            return True, f"low_winrate_exit_{profit_pct:.1f}%"
        op_health = await self.op.get_system_health()
        error_rate = op_health.get("error_rate", 0)
        if profit_pct >= 2 and error_rate > 0.2:
            return True, f"high_error_exit_{profit_pct:.1f}%"
        return False, ""

    async def record_outcome_feedback(self, mint: str, profit_pct: float, entry_price: float, exit_price: float, duration_min: float, reason: str):
        result = "WIN" if profit_pct > 0 else "LOSS"
        await self.financial.record_outcome("crypto", {"mint": mint, "action": "trade", "reason": reason}, {"profit_usd": profit_pct, "loss_usd": profit_pct if profit_pct < 0 else 0})
        if mint in self.decision_cache:
            decision = self.decision_cache[mint]
            with sqlite3.connect(DB_FILE) as conn:
                conn.execute("""
                CREATE TABLE IF NOT EXISTS trade_outcomes (
                    id INTEGER PRIMARY KEY AUTOINCREMENT,
                    ts REAL, mint TEXT, score INTEGER, adjustment INTEGER,
                    profit REAL, result INTEGER, duration REAL
                )
                """)
                conn.execute("""
                INSERT INTO trade_outcomes (ts, mint, score, adjustment, profit, result, duration)
                VALUES (?,?,?,?,?,?,?)
                """, (time.time(), mint, decision["base_score"], decision["adjustment"], profit_pct, 1 if profit_pct > 0 else 0, duration_min))
                cur = conn.execute("SELECT COUNT(*) FROM trade_outcomes WHERE ts > ?", (time.time() - 86400,))
                count = cur.fetchone()[0]
                if count >= 20:
                    await self._trigger_uhee_learning()
            self.decision_cache.pop(mint, None)

    async def _trigger_uhee_learning(self):
        with sqlite3.connect(DB_FILE) as conn:
            df = pd.read_sql_query("SELECT score, adjustment, profit, result, duration FROM trade_outcomes ORDER BY ts DESC LIMIT 50", conn)
        if len(df) >= 20:
            result = uhee_engine.run_cycle(df, "trade_outcomes")
            log.info(f"U-HEE learned from {len(df)} outcomes: best fitness={result['stats']['best']:.3f}")
            if result['top_hypotheses']:
                best = result['top_hypotheses'][0]
                if best.confidence > 0.6:
                    await self._apply_uhee_hypothesis(best)

    async def _apply_uhee_hypothesis(self, hypothesis):
        if "threshold" in hypothesis.parameters:
            new_threshold = hypothesis.parameters["threshold"]
            meta_governor.global_config["score_threshold"] = int(new_threshold)
            log.info(f"U-HEE updated score_threshold to {new_threshold}")
        if "trade_size" in hypothesis.parameters:
            new_size = hypothesis.parameters["trade_size"]
            meta_governor.global_config["trade_size_pct"] = min(0.1, max(0.01, new_size))
            log.info(f"U-HEE updated trade_size_pct to {new_size:.2%}")

