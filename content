        with open(self.config_path, 'w') as f: json.dump(config or self.config, f, indent=2)
    def _deep_update(self, orig, updates):
        for k,v in updates.items():
            if isinstance(v, dict) and k in orig and isinstance(orig[k], dict): self._deep_update(orig[k], v)
            else: orig[k] = v
    def update_config(self, updates: Dict, safe=True) -> bool:
        if safe and self.config.get("self_update",{}).get("enabled"):
            allowed = self.config["self_update"].get("allowed_params", [])
            filtered = {}
            for k,v in updates.items():
                if k in allowed: filtered[k] = v
                else:
                    parts = k.split('.')
                    for a in allowed:
                        if a.startswith(parts[0]): filtered[k] = v; break
            updates = filtered
        self._deep_update(self.config, updates); self.save_config(); return True
    def get(self, key: str, default=None):
        keys = key.split('.'); val = self.config
        try:
            for k in keys: val = val[k]
            return val
        except: return default

