                await bot.send_message(chat_id, f"📡 Intel: {intel_report}\n\n📈 Strategy: {chosen_strategy}\nTP:{current_take_profit}x | SL:{current_stop_loss}%")
                self.last_intel_report_time = now

            signals = await scan_meme_coins()
            for sig in signals[:5]:
                mint = sig.get("mint")
                if not mint:
                    continue
                if not self.cooldown.can_check(mint):
                    continue
                if self.market_cond.no_trade_zone():
                    self.logger.info("No trade zone active (sunyi/chaotic)")
                    break
                if not self.risk_mgr.can_open_new_position(len(self.positions)):
                    self.logger.info("Max open positions reached")
                    break

                data = await get_token_data(mint)
                if not data:
                    continue
                data["market_cap"] = sig.get("market_cap", 0)
                data["name"] = sig.get("name", "")
                data["symbol"] = sig.get("symbol", "")
                self.market_cond.update(data)
                self.smart_planner.update_history(mint, data.get("price_usd", 0), data.get("volume_h24", 0),
                                                  data.get("txns_h24_buys", 0), data.get("txns_h24_sells", 0))

                entry_rules = self.knowledge.get_entry_rules()
                entry_ok, rule_violation = self._evaluate_entry_rules(data, entry_rules)
                if not entry_ok:
                    self.logger.info(f"Skip {mint}: entry rule violated: {rule_violation}")
                    continue

                buys = data.get("txns_h24_buys", 0)
                sells = data.get("txns_h24_sells", 0)
                buy_pressure = buys / (buys + sells) * 100 if (buys + sells) > 0 else 50
                self.early_confirmation.update(mint, data.get("volume_h24", 0), buy_pressure)
                confirmation = self.early_confirmation.analyze(mint)
                if not confirmation["confirmed"]:
                    self.logger.info(f"Skip {mint}: not confirmed yet (score={confirmation['score']})")
                    continue

                should_enter_micro, micro_info = await self.micro_momentum.check(mint, chat_id)
                if not should_enter_micro:
                    self.logger.info(f"Skip {mint}: micro-momentum not detected (conf={micro_info.get('confidence',0)})")
                    continue

                self.logger.info(f"🔥 MICRO-MOMENTUM DETECTED! {micro_info}")

                market_cond = self.market_cond.get_condition()
                should_enter, conf, reason = self.smart_planner.analyze_entry(mint, data, intel_report, market_cond)
                if not should_enter:
                    self.logger.info(f"Skip {mint}: {reason}")
                    continue

                valid, score, reason2, momentum_info = await self.adaptive_validator.validate(data, intel_report, mint)
                if not valid:
                    self.logger.info(f"Skip {mint}: {reason2}")
                    continue

                adjusted_score = score
                intel_reason = ""
                if self.intel_layer:
                    adjusted_score, intel_reason = await self.intel_layer.enhance_entry_decision(mint, score, data, intel_report)
                    self.logger.info(f"Intel adjusted score: {score} -> {adjusted_score} ({intel_reason})")

                brain_override = self._get_brain_override(f"entry decision for {mint}")
                if brain_override["adjustment"] != 0:
                    adjusted_score = max(0, min(100, adjusted_score + brain_override["adjustment"]))
                    self.logger.info(f"Brain override: {brain_override['reason']} -> new score {adjusted_score}")

                await self.flow_tracker.update(mint)
                flow = self.flow_tracker.analyze(mint)
                smart = await self.smart_money.analyze(mint, data)

                self.trade_logger.log_signal(mint, data.get("symbol", ""), adjusted_score, data, market_cond,
                                             momentum_info.get("momentum_score", 0), flow["flow_score"],
                                             smart["signal"], f"{reason} | {reason2} | micro_conf={micro_info.get('confidence',0)} | {intel_reason}")

                bal = get_real_balance(BOT_WALLET_ADDRESS)
                pct = 0.03 + (adjusted_score - 60) / 40 * 0.09
                pct = min(0.12, max(0.03, pct))
                total_amount = bal * pct * trade_size_multiplier
                total_amount = min(0.5, max(0.01, total_amount))
                first_amt = self.split_mgr.first_entry(mint, total_amount, data.get("price_usd", 0))
                if first_amt <= 0:
                    continue
                success = await self.execute_buy_solana(mint, first_amt, chat_id)
                if success:
                    self.positions[mint]["entry_price"] = data.get("price_usd", 0)
                    self.exit_manager.register_position(mint, self.positions[mint])
                    asyncio.create_task(self._monitor_position(mint, chat_id))
            await asyncio.sleep(2)

    def stop(self):
        self.active = False
        binance_trader.stop()
        self.logger.info("AutoTrader stopped.")

