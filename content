class BinanceTrader:
    def __init__(self, api_key: str, secret_key: str, testnet: bool = True):
        self.client = BinanceClient(api_key, secret_key, testnet=testnet)
        self.testnet = testnet
        self.active = False
        self.positions = {}
        self.logger = logging.getLogger("BINANCE_TRADER")
        try:
            server_time = self.client.get_server_time()
            self.logger.info(f"✅ Binance {'Testnet' if testnet else 'Live'} connected. Server time: {server_time}")
        except Exception as e:
            self.logger.error(f"❌ Failed to connect to Binance: {e}")

    def get_account_balance(self, asset: str = 'USDT') -> float:
        try:
            balance = self.client.get_asset_balance(asset=asset)
            return float(balance['free']) if balance else 0.0
        except BinanceAPIException as e:
            self.logger.error(f"Error fetching balance: {e}")
            return 0.0

    def get_symbol_info(self, symbol: str):
        try:
            info = self.client.get_symbol_info(symbol)
            filters = {f['filterType']: f for f in info['filters']}
            return {
                'baseAsset': info['baseAsset'],
                'quoteAsset': info['quoteAsset'],
                'minQty': float(filters['LOT_SIZE']['minQty']),
                'maxQty': float(filters['LOT_SIZE']['maxQty']),
                'stepSize': float(filters['LOT_SIZE']['stepSize']),
                'minNotional': float(filters.get('MIN_NOTIONAL', {}).get('minNotional', 10.0))
            }
        except Exception as e:
            self.logger.error(f"Error fetching symbol info: {e}")
            return None

    def create_market_buy_order(self, symbol: str, quote_amount_usdt: float):
        try:
            ticker = self.client.get_symbol_ticker(symbol=symbol)
            price = float(ticker['price'])
            quantity = quote_amount_usdt / price
            symbol_info = self.get_symbol_info(symbol)
            if symbol_info:
                step_size = symbol_info['stepSize']
                precision = len(str(step_size).split('.')[-1].rstrip('0'))
                quantity = round(quantity - (quantity % step_size), precision)
                min_notional = symbol_info['minNotional']
                if quantity * price < min_notional:
                    self.logger.warning(f"Order value (${quantity * price:.2f}) below min notional (${min_notional})")
                    return None
            order = self.client.order_market_buy(symbol=symbol, quantity=quantity)
            self.logger.info(f"✅ Market BUY executed: {symbol} - {quantity} @ ~${price:.4f}")
            return order
        except BinanceAPIException as e:
            self.logger.error(f"Binance API Error: {e}")
        except BinanceOrderException as e:
            self.logger.error(f"Binance Order Error: {e}")
        except Exception as e:
            self.logger.error(f"Unexpected error: {e}")
        return None

    def create_market_sell_order(self, symbol: str, quantity: float):
        try:
            order = self.client.order_market_sell(symbol=symbol, quantity=quantity)
            self.logger.info(f"✅ Market SELL executed: {symbol} - {quantity}")
            return order
        except Exception as e:
            self.logger.error(f"Error creating sell order: {e}")
            return None

    async def execute_buy_async(self, symbol: str, usdt_amount: float, chat_id):
        loop = asyncio.get_event_loop()
        order = await loop.run_in_executor(None, self.create_market_buy_order, symbol, usdt_amount)
        if order:
            await bot.send_message(chat_id, f"🟢 BINANCE BUY: {symbol}\nAmount: ${usdt_amount:.2f}\nOrder ID: {order['orderId']}")
            return True
        return False

    def stop(self):
        self.active = False
        self.logger.info("BinanceTrader stopped.")

