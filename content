    await bot.send_message(m.chat.id, f"📚 Memproses topik: **{topic}**\nMembangun knowledge graph... (30-60 detik)", parse_mode="Markdown")
    system_prompt = f"""BUAT KNOWLEDGE BASE TERSTRUKTUR UNTUK TOPIK: {topic}
TUJUAN: Knowledge ini akan menjadi "otak" dari AI assistant. Harus ACTIONABLE.
OUTPUT: JSON VALID SAJA (tanpa teks tambahan, tanpa markdown)
SCHEMA WAJIB:
{{
  "id": "unique-id",
  "topic": "{topic}",
  "subtopic": "string",
  "statement": "max 2 kalimat, padat, actionable, berisi cara/langkah/aturan",
  "epistemic_type": "fact | heuristic | decision_rule | failure_mode | procedural | causal",
  "confidence_score": 0.0-1.0,
  "update_policy": "static",
  "utility_class": "execution | decision_making | problem_solving | risk_control",
  "tags": ["keyword1", "keyword2"],
