        threshold = self.global_config["min_confidence_for_codegen"]
        if self.state["mode"] == "cautious":
            threshold += 0.1
        elif self.state["mode"] == "aggressive":
            threshold -= 0.05
        if len(code_gen.loaded_strategies) > 10:
            threshold += 0.1
        return hypothesis.confidence > threshold

    async def run(self):
        await asyncio.sleep(300)
        while not kill_check():
            await self.evaluate_and_adapt()
            await asyncio.sleep(600)

