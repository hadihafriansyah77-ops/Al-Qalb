# EARLY CONFIRMATION DETECTOR
class EarlyConfirmationDetector:
    def __init__(self):
        self.history = {}

    def update(self, mint: str, volume: float, buy_pressure: float):
        if mint not in self.history:
            self.history[mint] = {"volumes": deque(maxlen=20), "buy_pressures": deque(maxlen=20), "timestamps": deque(maxlen=20)}
        self.history[mint]["volumes"].append(volume)
        self.history[mint]["buy_pressures"].append(buy_pressure)
        self.history[mint]["timestamps"].append(time.time())

    def analyze(self, mint: str) -> Dict:
        if mint not in self.history:
            return {"confirmed": False, "score": 0, "reasons": []}
        hist = self.history[mint]
        if len(hist["volumes"]) < 6:
            return {"confirmed": False, "score": 0, "reasons": ["insufficient_data"]}
        score = 0
        reasons = []
        recent_vols = list(hist["volumes"])[-6:]
        if recent_vols[-1] > recent_vols[0] * 2:
            score += 30
            reasons.append(f"volume_2x_{recent_vols[-1]/recent_vols[0]:.1f}x")
        elif recent_vols[-1] > recent_vols[0] * 1.5:
            score += 15
            reasons.append("volume_1.5x")
        recent_pressures = list(hist["buy_pressures"])[-6:]
        if recent_pressures[-1] > recent_pressures[0] + 20:
            score += 30
            reasons.append(f"pressure_spike_{recent_pressures[-1]-recent_pressures[0]:.0f}%")
        elif recent_pressures[-1] > recent_pressures[0] + 10:
            score += 15
            reasons.append(f"pressure_up_{recent_pressures[-1]-recent_pressures[0]:.0f}%")
        if all(recent_vols[i] < recent_vols[i+1] for i in range(len(recent_vols)-1)):
            score += 20
            reasons.append("volume_consecutive_up")
        if recent_pressures[-1] > 60:
            score += 20
            reasons.append(f"buy_pressure_{recent_pressures[-1]:.0f}%")
        confirmed = score >= 60
        return {"confirmed": confirmed, "score": score, "reasons": reasons}

