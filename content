# CORE ENGINE (AIW)
# ==============================================================
class CoreEngine:
    def __init__(self, config_manager: ConfigManager, memory_store: MemoryStore, logger: logging.Logger):
        self.config_manager = config_manager
        self.memory_store = memory_store
        self.logger = logger
        self.data_collector = DataCollector(config_manager, logger)
        self.decision_engine = DecisionEngine(config_manager, logger)
        self.executor = Executor(config_manager, logger, memory_store)
        self.task_manager = TaskManager(config_manager, logger)
        self.running = False
        self.loop_interval = config_manager.get("loop_interval", 5)

    async def initialize(self):
        self.logger.info("Initializing AIW Core Engine...")
        await self.memory_store.initialize()
        await self.data_collector.start()
        await self.executor.start()
        self._seed_initial_tasks()

    def _seed_initial_tasks(self):
        self.task_manager.add_task("collect_all_data", {"sources": ["hackernews", "reddit"]}, priority=1)

    async def close(self):
        self.running = False
        await self.data_collector.close()
        await self.executor.close()
        await self.memory_store.close()
        self.logger.info("AIW Core Engine closed.")

    async def run(self):
        await self.initialize()
        self.running = True
        self.logger.info("AIW main loop started.")
        while self.running:
            task = await self.task_manager.get_next_task()
            if task:
                asyncio.create_task(self._execute_task(task))
            await self._control_loop()
            await asyncio.sleep(self.loop_interval)

    async def _execute_task(self, task: Dict):
        task_id = task["id"]
        ttype = task["type"]
        result = error = None
        try:
            if ttype == "collect_all_data":
                collected = await self.data_collector.collect_all()
                await self.memory_store.save_scraped_data("hackernews", collected["hackernews"])
                await self.memory_store.save_scraped_data("reddit", collected["reddit"])
                self.task_manager.add_task("analyze_data", {"collected": collected}, priority=2)
                result = {"collected_hackernews": len(collected["hackernews"]), "collected_reddit": len(collected["reddit"])}
            elif ttype == "analyze_data":
                analysis = await self.decision_engine.analyze_collected_data(task["params"]["collected"])
                await self.memory_store.set_learning_value("last_analysis", analysis)
                new_tasks = self.decision_engine.decide_next_tasks(analysis)
                for nt in new_tasks:
                    self.task_manager.add_task(nt["type"], nt["params"], nt.get("priority", 5))
                result = analysis
            else:
                exec_result = await self.executor.execute(task)
                if exec_result.get("status") == "error":
                    error = exec_result.get("error")
                else:
                    result = exec_result.get("output")
        except Exception as e:
            error = str(e)
            self.logger.error(f"Task {task_id} error: {e}")
        finally:
            self.task_manager.complete_task(task_id, result, error)

    async def _control_loop(self):
        stats = self.task_manager.get_stats()
        self.logger.debug(f"Task stats: {stats}")
        if stats["pending"] > 20 and self.config_manager.get("max_concurrent_tasks") < 5:
            self.config_manager.update_config({"max_concurrent_tasks": 5}, safe=True)
            self.task_manager.max_concurrent = 5
        elif stats["pending"] < 5 and self.config_manager.get("max_concurrent_tasks") > 2:
            self.config_manager.update_config({"max_concurrent_tasks": 3}, safe=True)
            self.task_manager.max_concurrent = 3

