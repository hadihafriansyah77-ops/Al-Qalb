    def get_market_conditions(self) -> Dict:
        with sqlite3.connect(self.db_path) as conn:
            cur = conn.execute("SELECT content FROM trading_knowledge WHERE category='market_conditions' ORDER BY priority DESC LIMIT 1")
            row = cur.fetchone()
            if row:
                content = row[0]
                good, bad = [], []
                current = None
                for line in content.split('\n'):
                    line_lower = line.lower()
                    if 'bagus' in line_lower or 'good' in line_lower:
                        current = "good"
                    elif 'hindari' in line_lower or 'bad' in line_lower or 'avoid' in line_lower:
                        current = "bad"
                    elif line.strip() and (line[0].isdigit() or line.startswith('-')) and current:
                        clean_line = line.strip('0123456789.- ').strip()
                        if current == "good":
                            good.append(clean_line)
                        else:
                            bad.append(clean_line)
                return {"good": good, "bad": bad}
        return {"good": [], "bad": []}

    def get_indicators(self) -> List[str]:
        with sqlite3.connect(self.db_path) as conn:
            cur = conn.execute("SELECT content FROM trading_knowledge WHERE category='indicators' ORDER BY priority DESC LIMIT 1")
            row = cur.fetchone()
            if row:
                try:
                    content = row[0]
                    parsed = json.loads(content)
                    if isinstance(parsed, list):
                        return parsed
                except:
                    pass
                indicators = [line.strip() for line in content.split('\n') if line.strip() and (line[0].isdigit() or line.startswith('-'))]
                return indicators
        return []

