# ENHANCED TECHNICAL INDICATORS (MEME COIN SPECIFIC)
class MemeTechIndicators:
    @staticmethod
    def calculate_volume_spike(volumes: List[float], window=5) -> float:
        if len(volumes) < window + 1:
            return 0
        recent = volumes[-window:]
        mean = np.mean(recent)
        std = np.std(recent)
        if std == 0:
            return 0
        return (volumes[-1] - mean) / std

    @staticmethod
    def calculate_buy_pressure(buys: List[int], sells: List[int], window=5) -> float:
        if len(buys) < window or len(sells) < window:
            return 50
        total_buys = sum(buys[-window:])
        total_sells = sum(sells[-window:])
        if total_buys + total_sells == 0:
            return 50
        return (total_buys / (total_buys + total_sells)) * 100

    @staticmethod
    def calculate_rsi(prices: List[float], period=14) -> float:
        if len(prices) < period + 1:
            return 50
        deltas = np.diff(prices[-period - 1:])
        gains = deltas[deltas > 0].sum() / period
        losses = -deltas[deltas < 0].sum() / period
        if losses == 0:
            return 100
        rs = gains / losses
        return 100 - (100 / (1 + rs))

    @staticmethod
    def calculate_momentum_score(prices: List[float], volumes: List[float], period=5) -> float:
        if len(prices) < period + 1 or len(volumes) < period + 1:
            return 0
        price_mom = (prices[-1] - prices[-period]) / max(prices[-period], 1e-8) * 100
        vol_mom = (volumes[-1] - volumes[-period]) / max(volumes[-period], 1e-8) * 100
        return (price_mom * 0.6) + (vol_mom * 0.4)

    @staticmethod
    def social_score(name: str, symbol: str) -> int:
        score = 0
        keywords = ["moon", "gem", "100x", "soon", "launch", "presale", "airdrop"]
        text = (name + " " + symbol).lower()
        for kw in keywords:
            if kw in text:
                score += 10
        return min(score, 100)

