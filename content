            reasons.append(f"volume_2x_{recent_vol/previous_vol:.1f}")
        if recent_pressure > previous_pressure + 20:
            confidence += 40
            reasons.append(f"pressure_surge_{recent_pressure - previous_pressure:.0f}%")
        elif recent_pressure > previous_pressure + 10:
