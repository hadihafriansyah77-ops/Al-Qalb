    def _is_research_trigger(self, text: str) -> bool:
        triggers = ["pelajari", "riset", "apa itu", "jelaskan tentang", "saya ingin tahu", "research", "tolong jelaskan"]
        return any(t in text.lower() for t in triggers)

    def _extract_topic(self, text: str) -> Optional[str]:
        for t in ["pelajari", "riset", "tentang"]:
            if t in text.lower():
                parts = text.lower().split(t, 1)
                if len(parts) > 1: return parts[1].strip().strip("?.,!")
        words = text.split()
        return " ".join(words[:2]) if len(words) >= 2 else text[:30]

    async def _auto_research(self, topic: str, chat_id: int = None):
        try:
            prompt = f"""Buatkan knowledge graph tentang "{topic}" dalam format JSON array.
Schema: id (unik), topic, subtopic, statement (faktual/aksi), epistemic_type (fact/heuristic/decision_rule/failure_mode/procedural/causal), confidence_score (0-1), utility_class (execution/decision_making/problem_solving/risk_control/decision_support/inference_only), tags (array string).
Fokus pada pengetahuan yang actionable dan mendalam. Output HANYA JSON array tanpa teks lain."""
            response = await ai_hybrid(prompt)
            clean = re.sub(r'```json\s*|\s*```', '', response).strip()
            nodes = json.loads(clean)
            if not isinstance(nodes, list): nodes = [nodes]
            valid_nodes = []
            for node in nodes:
                if "statement" in node:
                    node.setdefault("topic", topic)
                    node.setdefault("id", f"auto_{topic}_{int(time.time())}_{random.randint(1000,9999)}")
                    valid_nodes.append(node)
            if valid_nodes:
                self.local_brain.add_knowledge(valid_nodes)
                self.logger.info(f"Auto-research: added {len(valid_nodes)} nodes for '{topic}'")
                await self.consolidate_memory(topic)
            if chat_id:
                await bot.send_message(chat_id, f"✅ Riset '{topic}' selesai. {len(valid_nodes)} node ditambahkan ke Local Brain.")
        except Exception as e:
            self.logger.error(f"Auto-research error: {e}")
            if chat_id: await bot.send_message(chat_id, f"❌ Gagal riset: {e}")

    async def consolidate_memory(self, topic: str = None):
        nodes = self.local_brain.knowledge_nodes
        if topic: nodes = [n for n in nodes if n.get('topic') == topic]
        if len(nodes) < 3: return
        recent = nodes[-5:]
        old = random.sample(nodes[:-5], min(3, len(nodes)-5)) if len(nodes) > 5 else []
        combined = recent + old
        if not combined: return
        prompt = f"""Gabungkan pengetahuan berikut menjadi satu pemahaman yang koheren dan lebih dalam.
Node-node:
