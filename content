            conn.execute("""
                CREATE TABLE IF NOT EXISTS trade_signals_v2 (
                    ts REAL, mint TEXT, symbol TEXT, score INTEGER,
                    liquidity REAL, volume REAL, buy_sell_ratio REAL, price_change REAL,
                    market_condition TEXT, momentum_score REAL, flow_score REAL,
                    smart_money_signal TEXT, reason TEXT, simulated BOOLEAN,
                    entry_price REAL, exit_price REAL, profit_percent REAL, result TEXT,
