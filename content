class MemoryStore:
    def __init__(self, db_path: str = "./data/aiw_data.db"):
        self.db_path = Path(db_path)
        self.db_path.parent.mkdir(exist_ok=True)
        self.conn: Optional[aiosqlite.Connection] = None

    async def initialize(self):
        self.conn = await aiosqlite.connect(str(self.db_path))
        await self.conn.execute("PRAGMA foreign_keys = ON")
        await self.conn.executescript("""
        CREATE TABLE IF NOT EXISTS scraped_data (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            source TEXT, url TEXT, title TEXT, content TEXT,
            metadata TEXT, scraped_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
        );
        CREATE TABLE IF NOT EXISTS task_history (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            task_id TEXT, task_type TEXT, status TEXT, result TEXT, error TEXT,
            started_at TIMESTAMP, finished_at TIMESTAMP
        );
        CREATE TABLE IF NOT EXISTS learning (
            key TEXT PRIMARY KEY, value TEXT, updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
        );
        CREATE TABLE IF NOT EXISTS uhee_hypotheses (
            ts REAL, cycle INTEGER, uid TEXT, description TEXT,
            confidence REAL, fitness REAL, parameters TEXT
        );
        """)
        await self.conn.commit()

    async def close(self):
        if self.conn:
            await self.conn.close()

    async def save_scraped_data(self, source: str, data: List[Dict]):
        if not self.conn:
            return
        for item in data:
            await self.conn.execute(
                "INSERT INTO scraped_data (source, url, title, content, metadata) VALUES (?,?,?,?,?)",
                (source, item.get('url', ''), item.get('title', ''), item.get('content', ''), json.dumps(item.get('metadata', {})))
            )
        await self.conn.commit()

    async def set_learning_value(self, key: str, value: Any):
        if not self.conn:
            return
        await self.conn.execute(
            "INSERT OR REPLACE INTO learning (key, value, updated_at) VALUES (?,?,CURRENT_TIMESTAMP)",
            (key, json.dumps(value))
        )
        await self.conn.commit()

    async def get_learning_value(self, key: str) -> Optional[Any]:
        if not self.conn:
            return None
        cursor = await self.conn.execute("SELECT value FROM learning WHERE key=?", (key,))
        row = await cursor.fetchone()
        return json.loads(row[0]) if row else None

    async def save_hypothesis(self, cycle: int, hyp):
        await self.conn.execute(
            "INSERT INTO uhee_hypotheses VALUES (?,?,?,?,?,?,?)",
            (time.time(), cycle, hyp.uid, hyp.description, hyp.confidence, hyp.fitness, json.dumps(hyp.parameters))
        )
        await self.conn.commit()

