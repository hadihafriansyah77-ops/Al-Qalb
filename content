class EnhancedRiskManager:
    def __init__(self, max_open_positions=3, daily_loss_limit_pct=8, consec_loss_limit=4):
        self.max_open_positions = max_open_positions
        self.daily_loss_limit = daily_loss_limit_pct
        self.consecutive_loss_limit = consec_loss_limit
        self.daily_loss = 0.0
        self.consecutive_losses = 0

    def _get_today(self): return datetime.now().strftime("%Y-%m-%d")

    def is_kill_switch_active(self) -> bool:
        today = self._get_today()
        with sqlite3.connect(DB_FILE) as conn:
            cur = conn.execute("SELECT value FROM risk_state WHERE key='daily_loss' AND date=?", (today,))
            daily_loss = (cur.fetchone() or (0,))[0]
            cur = conn.execute("SELECT value FROM risk_state WHERE key='consecutive_loss'")
            consec_loss = (cur.fetchone() or (0,))[0]
        return (daily_loss <= -self.daily_loss_limit) or (consec_loss >= self.consecutive_loss_limit)

    def record_loss(self, loss_pct: float):
        if loss_pct < 0:
            self.consecutive_losses += 1
            self.daily_loss += loss_pct
        else: self.consecutive_losses = 0
        today = self._get_today()
        with sqlite3.connect(DB_FILE) as conn:
            conn.execute("INSERT OR REPLACE INTO risk_state VALUES (?,?,?)", ('daily_loss', self.daily_loss, today))
            conn.execute("INSERT OR REPLACE INTO risk_state VALUES (?,?,?)", ('consecutive_loss', self.consecutive_losses, None))

    def can_open_new_position(self, current_positions: int) -> bool:
        return current_positions < self.max_open_positions

class MarketConditionAnalyzer:
    def __init__(self):
        self.volumes = deque(maxlen=100)
        self.price_changes = deque(maxlen=100)

    def update(self, data: Dict):
        vol = data.get("volume_h24", 0)
        change = abs(data.get("price_change_h24", 0))
        if vol > 0: self.volumes.append(vol)
        self.price_changes.append(change)

    def get_condition(self) -> str:
        if len(self.volumes) < 10: return "unknown"
        median_vol = statistics.median(self.volumes)
        median_change = statistics.median(self.price_changes)
        latest_vol = self.volumes[-1] if self.volumes else 0
        latest_change = self.price_changes[-1] if self.price_changes else 0
        if latest_vol < median_vol * 0.5: return "sunyi"
        elif latest_change > median_change * 3: return "chaotic"
        elif latest_vol > median_vol * 1.5 and latest_change < median_change * 1.2: return "bullish"
        else: return "normal"

    def no_trade_zone(self) -> bool:
        cond = self.get_condition()
        return cond in ("sunyi", "chaotic")

