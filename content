# ------------------------- 5. POSITION SIZING + SPLIT ENTRY -------------------------
class SplitEntryManager:
    def __init__(self, split_ratio=0.7, confirmation_pct=1.0, confirmation_seconds=60):
        self.split_ratio = split_ratio
        self.confirmation_pct = confirmation_pct
        self.confirmation_seconds = confirmation_seconds
        self.pending = {}
    def first_entry(self, mint: str, total_amount: float, entry_price: float):
        first_amt = total_amount * self.split_ratio
        remaining = total_amount - first_amt
        self.pending[mint] = {"first_entry_price": entry_price, "remaining_amount": remaining, "timestamp": time.time()}
        return first_amt
    async def check_second_entry(self, mint: str, current_price: float) -> float:
        if mint not in self.pending: return 0.0
        pending = self.pending[mint]
        elapsed = time.time() - pending["timestamp"]
        if elapsed > self.confirmation_seconds:
            del self.pending[mint]
            return 0.0
        gain_pct = (current_price - pending["first_entry_price"]) / pending["first_entry_price"] * 100
        if gain_pct >= self.confirmation_pct:
            amount = pending["remaining_amount"]
            del self.pending[mint]
            return amount
        return 0.0


# ------------------------- 6. MARKET CONDITION ANALYZER (no trade zone) -------------------------
class MarketConditionAnalyzer:
    def __init__(self, lookback=20):
        self.volumes = deque(maxlen=lookback)
        self.price_changes = deque(maxlen=lookback)
    def update(self, data: Dict):
        vol = data.get("volume_h24", 0)
