            self.global_config["uhee_evolution_interval"] = 1800
            self.global_config["max_concurrent_tasks"] = 5
        else:
            self.global_config["min_confidence_for_codegen"] = 0.75
            self.global_config["uhee_evolution_interval"] = 3600
        aiw_config.update_config({"max_concurrent_tasks": self.global_config["max_concurrent_tasks"]}, safe=True)
        self.decision_history.append({
            "ts": time.time(), "mode": self.state["mode"],
            "fin_health": fin_health, "op_health": op_health,
            "uhee_status": uhee_status
        })
