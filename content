        self.history[mint]["volumes"].append(volume)
        self.history[mint]["buys"].append(buys)
        self.history[mint]["sells"].append(sells)

    def analyze_entry(self, mint: str, data: Dict, intel_report: Dict, market_cond: str = "normal") -> Tuple[bool, int, str]:
        if mint not in self.history:
            return False, 0, "No history"
        hist = self.history[mint]
        prices = list(hist["prices"])
        volumes = list(hist["volumes"])
        buys = list(hist["buys"])
        sells = list(hist["sells"])
        if len(prices) < 10:
            return False, 0, "Insufficient data"
        score = 0
        reasons = []
        spike = self.indicators.calculate_volume_spike(volumes, window=5)
        if spike > 2:
            score += 15
            reasons.append(f"volume_spike_{spike:.1f}")
        elif spike > 1:
            score += 8
        pressure = self.indicators.calculate_buy_pressure(buys, sells, window=5)
        if pressure > 75:
            score += 20
            reasons.append(f"buy_pressure_{pressure:.0f}%")
        elif pressure > 65:
            score += 10
        elif pressure > 55:
            score += 5
            reasons.append(f"early_pressure_{pressure:.0f}%")
        rsi = self.indicators.calculate_rsi(prices, period=10)
        if 40 <= rsi <= 60:
            score += 15
            reasons.append(f"rsi_{rsi:.0f}")
        elif 30 <= rsi <= 70:
            score += 8
        if data.get("liquidity_usd", 0) > 30000:
            score += 5
            reasons.append("high_liq")
        change = abs(data.get("price_change_h24", 0))
        if change < 20:
            score += 5
            reasons.append("stable_price")
        if market_cond == "bullish":
            threshold = 60
            reasons.append("bullish_market")
        elif market_cond == "normal":
            threshold = 70
        elif market_cond == "chaotic":
            threshold = 80
            reasons.append("chaotic_market_cautious")
        else:
            threshold = 999
            reasons.append("sunyi_market_no_trade")
        confidence = min(100, score)
        should_enter = confidence >= threshold
        reason = f"conf={confidence}% (thresh={threshold}) | " + " ".join(reasons[:5])
        return should_enter, confidence, reason

    def analyze_exit(self, mint: str, current_price: float, entry_price: float, current_volume: float = 0) -> Tuple[bool, int, str]:
        if mint not in self.history:
            return False, 0, "No history"
        hist = self.history[mint]
        prices = list(hist["prices"])
        if len(prices) < 5:
            return False, 0, "Insufficient data"
        profit_pct = (current_price - entry_price) / entry_price * 100
        score = 0
        reasons = []
        if profit_pct >= 5:
            score += 50
            reasons.append(f"profit_{profit_pct:.1f}%")
        elif profit_pct >= 3:
            score += 30
        if current_volume > 0 and mint in self.history:
            vols = list(hist["volumes"])
            if len(vols) >= 5:
                recent_vol_avg = sum(vols[-3:]) / 3
                older_vol_avg = sum(vols[-6:-3]) / 3 if len(vols) >= 6 else recent_vol_avg
                if recent_vol_avg < older_vol_avg * 0.7:
                    score += 30
                    reasons.append("volume_drop")
        rsi = self.indicators.calculate_rsi(prices, period=10)
        if rsi > 70:
            score += 20
            reasons.append(f"rsi_overbought_{rsi:.0f}")
        should_exit = score >= 60
        return should_exit, score, " | ".join(reasons)

