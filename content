class MetaGovernor:
    def __init__(self, al_qalb: AlQalb):
        self.al_qalb = al_qalb
        self.logger = logging.getLogger("META_GOVERNOR")
        self.state = {"mode": "exploration", "consciousness_level": 0.5, "last_idea_timestamp": time.time(),
                      "current_focus": None, "long_term_goals": [], "completed_projects": [], "failed_attempts": []}
        self.idea_history = deque(maxlen=50)
        self.global_config = {"max_concurrent_tasks": 3, "uhee_evolution_interval": 3600,
                              "min_confidence_for_codegen": 0.7, "idea_generation_interval": 1800, "exploration_rate": 0.7}

    async def analyze_brain_state(self) -> Dict:
        nodes = self.al_qalb.local_brain.knowledge_nodes
        if not nodes:
            return {"status": "empty", "needs_learning": True, "knowledge_gaps": ["execution_knowledge", "decision_framework", "procedural_knowledge"],
                    "dominant_topic": None, "richness_score": 0}
        topics = defaultdict(int)
        epistemic_types = defaultdict(int)
        utility_classes = defaultdict(int)
        for node in nodes:
            topics[node.get('topic', 'general')] += 1
            epistemic_types[node.get('epistemic_type', 'fact')] += 1
            utility_classes[node.get('utility_class', 'inference_only')] += 1
        dominant_topic = max(topics, key=topics.get) if topics else "general"
        has_exec = utility_classes.get('execution', 0) > 0
        has_decision = epistemic_types.get('decision_rule', 0) > 0
        has_proc = epistemic_types.get('procedural', 0) > 0
        gaps = []
        if not has_exec: gaps.append("execution_knowledge")
        if not has_decision: gaps.append("decision_framework")
        if not has_proc: gaps.append("procedural_knowledge")
        richness = len(topics) * (len(nodes) / 100)
        return {"status": "analyzed", "total_nodes": len(nodes), "dominant_topic": dominant_topic,
                "topic_distribution": dict(topics), "knowledge_gaps": gaps, "needs_learning": len(gaps) > 0,
                "richness_score": richness}

    async def generate_ideas(self, brain_analysis: Dict) -> List[Dict]:
        ideas = []
        for gap in brain_analysis.get("knowledge_gaps", []):
            if gap == "execution_knowledge":
                ideas.append({"type": "learning", "priority": 9, "title": "Belajar Eksekusi Praktis", "topic": "eksekusi proyek", "action": "learn"})
            elif gap == "decision_framework":
                ideas.append({"type": "learning", "priority": 8, "title": "Framework Keputusan", "topic": "pengambilan keputusan strategis", "action": "learn"})
        dominant = brain_analysis.get("dominant_topic")
        if dominant and random.random() < 0.3:
            ideas.append({"type": "expansion", "priority": 7, "title": f"Ekspansi dari {dominant}", "topic": f"{dominant} lanjutan", "action": "learn"})
        creative_topics = ["inovasi disruptif", "teknologi masa depan", "passive income", "design thinking"]
        if random.random() < self.state["consciousness_level"]:
            topic = random.choice(creative_topics)
            ideas.append({"type": "creative", "priority": 6, "title": f"Eksplorasi: {topic}", "topic": topic, "action": "learn"})
        if self.state["failed_attempts"]:
            fail = self.state["failed_attempts"][-1]
            ideas.append({"type": "improvement", "priority": 10, "title": f"Perbaiki: {fail}", "topic": fail, "action": "learn"})
        ideas.sort(key=lambda x: x["priority"], reverse=True)
        return ideas[:3]

    async def select_best_idea(self, ideas: List[Dict]) -> Optional[Dict]:
        if not ideas: return None
        new_ideas = [i for i in ideas if i["title"] not in [h.get("title") for h in self.idea_history]]
        if not new_ideas: new_ideas = ideas
        if random.random() < self.global_config["exploration_rate"]: return random.choice(new_ideas)
        return new_ideas[0]

    async def execute_idea(self, idea: Dict):
        thought = Thought(topic=idea.get("topic", "general"), action=idea.get("action", "learn"), depth=0, params=idea)
        await self.al_qalb.thought_queue.put(thought)
        self.idea_history.append({"timestamp": time.time(), "idea": idea})
        self.logger.info(f"💡 Idea queued: {idea['title']}")

    async def think(self):
        while not kill_check():
            try:
                brain_state = await self.analyze_brain_state()
                ideas = await self.generate_ideas(brain_state)
                if ideas:
                    selected = await self.select_best_idea(ideas)
                    if selected: await self.execute_idea(selected)
                if brain_state["richness_score"] > 10:
                    self.state["consciousness_level"] = min(1.0, self.state["consciousness_level"] + 0.05)
                    self.state["mode"] = "exploration"
                elif brain_state["needs_learning"]:
                    self.state["mode"] = "focused"
                    self.state["consciousness_level"] = 0.8
                else: self.state["mode"] = "resting"
                interval = self.global_config["idea_generation_interval"]
                if self.state["mode"] == "focused": interval = interval // 2
                await asyncio.sleep(interval)
            except Exception as e:
                self.logger.error(f"Think error: {e}")
                await asyncio.sleep(60)

    async def run(self):
        await asyncio.sleep(10)
        await self.think()

