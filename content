class CodeGenerator:
    def __init__(self, strategies_dir: Path = Path("strategies"), backup_dir: Path = Path("backups")):
        self.strategies_dir = strategies_dir
        self.backup_dir = backup_dir
        self.strategies_dir.mkdir(exist_ok=True)
        self.backup_dir.mkdir(exist_ok=True)
        self.loaded_strategies = {}
        self.logger = logging.getLogger("CodeGenerator")
        self.evolution_version = 0

    def _backup_main(self):
        main_file = Path(__file__).resolve()
        backup_name = f"main_{datetime.now().strftime('%Y%m%d_%H%M%S')}.py"
        shutil.copy2(main_file, self.backup_dir / backup_name)
        self.logger.info(f"Main file backed up to {backup_name}")
        return backup_name

    def validate_generated_code(self, code: str) -> bool:
        forbidden = ["__import__", "eval", "exec", "open", "os.", "subprocess", "sys.", "shutil", "importlib"]
        for word in forbidden:
            if word in code:
                self.logger.warning(f"Forbidden keyword '{word}' found in generated code")
                return False
        try:
            ast.parse(code)
            return True
        except SyntaxError as e:
            self.logger.error(f"Syntax error in generated code: {e}")
            return False

    def generate_strategy_from_hypothesis(self, hypothesis: Hypothesis, strategy_name: str) -> Optional[Path]:
        ant_keys = list(hypothesis.antecedent.keys())
        cons_keys = list(hypothesis.consequent.keys())
        feature = ant_keys[0] if ant_keys else "feature"
        target = cons_keys[0] if cons_keys else "target"
        threshold = hypothesis.parameters.get("threshold", 0.5)
        direction = hypothesis.consequent.get(target, {}).get("direction", "increase") if cons_keys else "increase"

        template = f"""# Auto-generated strategy: {strategy_name}
# Generated at: {datetime.now().isoformat()}
# Hypothesis: {hypothesis.description} (confidence: {hypothesis.confidence:.3f})
# Version: {self.evolution_version + 1}

from strategies.base import BaseStrategy
from typing import Dict, Any
import logging

class {strategy_name}(BaseStrategy):
    \"\"\"Strategy evolved from U-HEE hypothesis.\"\"\"

    def __init__(self, config: Dict[str, Any] = None):
        super().__init__(config or {{}})
        self.threshold = {threshold}
        self.direction = "{direction}"
        self.feature = "{feature}"
        self.confidence = {hypothesis.confidence}
        self.logger = logging.getLogger("{strategy_name}")

    def should_buy(self, data: Dict[str, Any]) -> bool:
        value = data.get(self.feature, 0)
        if self.direction == "increase":
            return value > self.threshold
        else:
            return value < self.threshold

    def should_sell(self, data: Dict[str, Any]) -> bool:
        value = data.get(self.feature, 0)
        return value < self.threshold * 0.5

    def execute(self, data: Dict[str, Any]) -> str:
        self.logger.debug(f"Executing with data: {{data}}")
        return super().execute(data)
"""
        if not self.validate_generated_code(template):
            self.logger.error(f"Generated code validation failed for {strategy_name}")
            return None
        file_path = self.strategies_dir / f"generated_{strategy_name}.py"
        file_path.write_text(template, encoding='utf-8')
        self.logger.info(f"Generated strategy file: {file_path}")
        with sqlite3.connect(DB_FILE) as conn:
            conn.execute("INSERT INTO code_evolution VALUES (?,?,?,?,?)",
                         (time.time(), self.evolution_version + 1, str(file_path), template, hypothesis.description))
        self.evolution_version += 1
        return file_path

    def load_strategy(self, strategy_name: str):
        module_name = f"strategies.generated_{strategy_name}"
        try:
            if module_name in sys.modules:
                del sys.modules[module_name]
            spec = importlib.util.spec_from_file_location(module_name, self.strategies_dir / f"generated_{strategy_name}.py")
            if spec is None or spec.loader is None:
                return None
            module = importlib.util.module_from_spec(spec)
            spec.loader.exec_module(module)
            strategy_class = getattr(module, strategy_name)
            self.loaded_strategies[strategy_name] = strategy_class
            self.logger.info(f"Strategy '{strategy_name}' loaded dynamically")
            return strategy_class
        except Exception as e:
            self.logger.error(f"Failed to load strategy {strategy_name}: {e}")
            return None

    def inject_import_to_main(self, strategy_name: str) -> bool:
        self._backup_main()
        main_file = Path(__file__).resolve()
        content = main_file.read_text(encoding='utf-8')
        marker = "# AUTO-INJECTION-POINT"
        if marker not in content:
            self.logger.warning(f"Marker '{marker}' not found in main.py")
            return False
        import_line = f"from strategies.generated_{strategy_name} import {strategy_name}"
        if import_line in content:
            return True
        new_content = content.replace(marker, marker + "\n" + import_line)
        main_file.write_text(new_content, encoding='utf-8')
        self.logger.info(f"Injected import for {strategy_name} into main.py")
        return True

    async def evolve_strategies(self, uhee_result: Dict):
        if not uhee_result.get('top_hypotheses'):
            return
        best_hyp = uhee_result['top_hypotheses'][0]
        if meta_governor.should_generate_code(best_hyp):
            strategy_name = f"EvolvedStrategy_{uhee_engine.cycle_count}"
            file_path = self.generate_strategy_from_hypothesis(best_hyp, strategy_name)
            if file_path:
                self.load_strategy(strategy_name)
                self.inject_import_to_main(strategy_name)
                self.logger.info(f"META GOVERNOR approved code generation for {strategy_name}")
        else:
            self.logger.info(f"META GOVERNOR deferred code generation (confidence {best_hyp.confidence:.2f} below threshold)")

