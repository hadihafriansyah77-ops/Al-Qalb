def find_all_old_brain_files() -> List[Path]:
    patterns = ["knowledge*.json", "brain*.json", "*.brain.json", "data/knowledge*.json"]
    files = []
    for pattern in patterns: files.extend(Path(".").glob(pattern))
    return list(set(files))

def auto_migrate_old_knowledge():
    log.info("AUTO-MIGRASI: Mencari file knowledge lama...")
    total = 0
    for file_path in find_all_old_brain_files():
        try:
            with open(file_path, 'r', encoding='utf-8') as f:
                content = f.read().strip()
                if not content: file_path.unlink(); continue
                old_nodes = json.loads(content)
                if not isinstance(old_nodes, list): old_nodes = [old_nodes]
                valid_nodes = []
                for node in old_nodes:
                    if isinstance(node, dict) and "id" in node and "statement" in node:
                        node["_migrated_from"] = str(file_path)
                        node["_migrated_at"] = time.time()
                        valid_nodes.append(node)
                if valid_nodes:
                    local_brain.add_knowledge(valid_nodes)
                    total += len(valid_nodes)
                    log.info(f"📁 {file_path.name}: {len(valid_nodes)} node")
                file_path.unlink()
        except Exception as e: log.warning(f"⚠️ {file_path.name}: {e}")
    if total > 0: log.info(f"✅ AUTO-MIGRASI SELESAI! {total} node ditambahkan.")

def migrate_knowledge_from_database():
    log.info("MIGRASI DATABASE: Mencari knowledge di database...")
    try:
        with sqlite3.connect(DB_FILE) as conn:
            cur = conn.execute("SELECT name FROM sqlite_master WHERE type='table' AND name='knowledge'")
            if not cur.fetchone(): return
            cur = conn.execute("SELECT rowid, topic, content, ts FROM knowledge ORDER BY ts DESC")
            rows = cur.fetchall()
            if not rows: return
            nodes_to_add = []
            for rowid, topic, content, ts in rows:
                if not content or len(content.strip()) < 10: continue
                node = {"id": f"migrated_{rowid}_{int(ts)}", "topic": topic or "general",
                        "statement": content[:300], "epistemic_type": "fact"}
                nodes_to_add.append(node)
            if nodes_to_add:
                local_brain.add_knowledge(nodes_to_add)
                log.info(f"✅ MIGRASI DATABASE: {len(nodes_to_add)} knowledge ditambahkan.")
    except Exception as e: log.warning(f"Migrasi database error: {e}")

