        self.uhee = uhee_engine
        self.decision_cache = {}
        self.last_feedback_time = 0

    async def adjust_scan_params(self, market_cond: str) -> Dict:
        params = {"min_market_cap": 5000, "max_market_cap": 50000, "limit": 20}
        fin_health = self.financial.get_financial_health()
