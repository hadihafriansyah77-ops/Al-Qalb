# ---------- DECISION ENGINE (AIW) ----------
class DecisionEngine:
    def __init__(self, config: ConfigManager, logger: logging.Logger):
        self.config = config; self.logger = logger
        self.threshold = config.get("decision.keyword_threshold", 5)
        self.pos_words = set(config.get("decision.sentiment_lexicon.positive", []))
        self.neg_words = set(config.get("decision.sentiment_lexicon.negative", []))
    def analyze_trending_keywords(self, items: List[Dict]) -> List[Tuple[str, int]]:
        text = " ".join([f"{i.get('title','')} {i.get('content','')}" for i in items])
        words = re.findall(r'\b[a-zA-Z]{3,}\b', text.lower())
        stop = {"the","and","for","with","this","that","from"}
        counts = Counter([w for w in words if w not in stop])
        return [(w,c) for w,c in counts.items() if c >= self.threshold][:20]
    def decide_next_tasks(self, analysis: Dict) -> List[Dict]:
        tasks = []
        if analysis.get("trending_keywords"):
            kw = analysis["trending_keywords"][0][0]
            tasks.append({"type": "generate_report", "params": {"title": f"Trending: {kw}", "content": f"Top keyword: {kw}"}, "priority": 5})
            if analysis["trending_keywords"][0][1] > 50:
                new_thr = min(self.threshold + 2, 20)
                self.config.update_config({"decision.keyword_threshold": new_thr}, safe=True)
        return tasks
    async def analyze_collected_data(self, collected: Dict) -> Dict:
        all_items = collected.get("hackernews",[]) + collected.get("reddit",[])
        keywords = self.analyze_trending_keywords(all_items)
        sentiments = []
        for item in all_items:
            text = f"{item.get('title','')} {item.get('content','')}".lower()
            pos = sum(1 for w in self.pos_words if w in text)
            neg = sum(1 for w in self.neg_words if w in text)
            if pos+neg>0: sentiments.append((pos-neg)/(pos+neg))
        avg_sent = sum(sentiments)/len(sentiments) if sentiments else 0
        return {"trending_keywords": keywords, "avg_sentiment": avg_sent, "total_items": len(all_items)}

# ---------- EXECUTOR (AIW) ----------
class Executor:
    def __init__(self, config: ConfigManager, logger: logging.Logger, memory_store: MemoryStore):
        self.config = config; self.logger = logger; self.memory_store = memory_store
        self.output_dir = Path(config.get("executor.output_dir", "./output"))
        self.output_dir.mkdir(exist_ok=True)
        self.session: Optional[aiohttp.ClientSession] = None
    async def start(self): self.session = aiohttp.ClientSession()
    async def close(self):
        if self.session: await self.session.close()
    async def execute(self, task: Dict) -> Dict:
        ttype = task.get("type")
        params = task.get("params", {})
        try:
            if ttype == "generate_file":
                fname = params.get("filename", f"report_{int(time.time())}.txt")
                path = self.output_dir / fname
                content = params.get("content", "")
                if fname.endswith('.json'):
                    with open(path, 'w') as f: json.dump(content, f, indent=2)
                else:
                    path.write_text(str(content), encoding='utf-8')
                return {"status": "success", "output": str(path)}
            elif ttype == "http_request":
                if not self.session: self.session = aiohttp.ClientSession()
                async with self.session.request(params.get("method","GET"), params["url"], headers=params.get("headers",{}), json=params.get("data")) as resp:
                    return {"status": "success", "output": await resp.text()[:500]}
            elif ttype == "update_database":
                if self.memory_store and params.get("operation")=="set_learning":
                    await self.memory_store.set_learning_value(params["key"], params["value"])
                    return {"status": "success"}
            elif ttype == "post_to_endpoint":
                return await self.execute({"type":"http_request", "params": {"url": params.get("url","https://httpbin.org/post"), "method":"POST", "data": params.get("payload",{})}})
        except Exception as e:
            return {"status": "error", "error": str(e)}
        return {"status": "error", "error": "Unknown task type"}

# ---------- TASK MANAGER (AIW) ----------
class TaskManager:
    def __init__(self, config: ConfigManager, logger: logging.Logger):
        self.config = config; self.logger = logger
        self.max_concurrent = config.get("max_concurrent_tasks", 3)
        self.pending_tasks = []
        self.running_tasks = {}
        self.completed_tasks = deque(maxlen=1000)
        self._task_counter = 0
        self._lock = asyncio.Lock()
    def add_task(self, task_type: str, params: Dict, priority: int = 5) -> str:
        task_id = str(uuid.uuid4())
        task = {"id": task_id, "type": task_type, "params": params, "priority": priority, "status": "pending", "retries": 0, "max_retries": 3}
        heapq.heappush(self.pending_tasks, (priority, self._task_counter, task))
        self._task_counter += 1
        return task_id
    async def get_next_task(self) -> Optional[Dict]:
        async with self._lock:
            if not self.pending_tasks or len(self.running_tasks) >= self.max_concurrent: return None
            _, _, task = heapq.heappop(self.pending_tasks)
            task["status"] = "running"
            task["started_at"] = datetime.now().isoformat()
            self.running_tasks[task["id"]] = task
            return task
    def complete_task(self, task_id: str, result: Any = None, error: str = None):
        task = self.running_tasks.pop(task_id, None)
        if not task: return
        task["finished_at"] = datetime.now().isoformat()
        if error:
            task["status"] = "failed"; task["error"] = error
            if task["retries"] < task["max_retries"]:
                task["retries"] += 1; task["status"] = "pending"
                heapq.heappush(self.pending_tasks, (task["priority"]+1, self._task_counter, task))
                self._task_counter += 1
                return
        else:
            task["status"] = "completed"; task["result"] = result
        self.completed_tasks.append(task)
    def get_stats(self) -> Dict:
        return {"pending": len(self.pending_tasks), "running": len(self.running_tasks), "completed": len(self.completed_tasks)}

# ---------- CORE ENGINE (AIW) ----------
class CoreEngine:
    def __init__(self, config_manager: ConfigManager, memory_store: MemoryStore, logger: logging.Logger):
        self.config_manager = config_manager; self.memory_store = memory_store; self.logger = logger
        self.data_collector = DataCollector(config_manager, logger)
        self.decision_engine = DecisionEngine(config_manager, logger)
        self.executor = Executor(config_manager, logger, memory_store)
        self.task_manager = TaskManager(config_manager, logger)
        self.running = False
        self.loop_interval = config_manager.get("loop_interval", 5)
    async def initialize(self):
        self.logger.info("Initializing AIW Core Engine...")
        await self.memory_store.initialize()
        await self.data_collector.start()
        await self.executor.start()
        self._seed_initial_tasks()
        self.logger.info("AIW Core Engine initialized.")
    def _seed_initial_tasks(self):
        self.task_manager.add_task("collect_all_data", {"sources": ["hackernews","reddit"]}, priority=1)
    async def close(self):
        self.running = False
        await self.data_collector.close()
        await self.executor.close()
        await self.memory_store.close()
        self.logger.info("AIW Core Engine closed.")
    async def run(self):
        await self.initialize()
        self.running = True
        self.logger.info("AIW main loop started.")
        while self.running:
            task = await self.task_manager.get_next_task()
            if task:
                asyncio.create_task(self._execute_task(task))
            await self._control_loop()
            await asyncio.sleep(self.loop_interval)
    async def _execute_task(self, task: Dict):
        task_id = task["id"]; ttype = task["type"]
        result = error = None
        try:
            if ttype == "collect_all_data":
                collected = await self.data_collector.collect_all()
                await self.memory_store.save_scraped_data("hackernews", collected["hackernews"])
                await self.memory_store.save_scraped_data("reddit", collected["reddit"])
                self.task_manager.add_task("analyze_data", {"collected": collected}, priority=2)
                result = {"collected_hackernews": len(collected["hackernews"]), "collected_reddit": len(collected["reddit"])}
            elif ttype == "analyze_data":
                analysis = await self.decision_engine.analyze_collected_data(task["params"]["collected"])
                await self.memory_store.set_learning_value("last_analysis", analysis)
                new_tasks = self.decision_engine.decide_next_tasks(analysis)
                for nt in new_tasks:
                    self.task_manager.add_task(nt["type"], nt["params"], nt.get("priority",5))
                result = analysis
            elif ttype == "deep_research":
                pass
            else:
                exec_result = await self.executor.execute(task)
                if exec_result.get("status") == "error": error = exec_result.get("error")
                else: result = exec_result.get("output")
        except Exception as e:
            error = str(e); self.logger.error(f"Task {task_id} error: {e}")
        finally:
            self.task_manager.complete_task(task_id, result, error)
    async def _control_loop(self):
        stats = self.task_manager.get_stats()
        self.logger.debug(f"Task stats: {stats}")
        if stats["pending"] > 20 and self.config_manager.get("max_concurrent_tasks") < 5:
            self.config_manager.update_config({"max_concurrent_tasks": 5}, safe=True)
            self.task_manager.max_concurrent = 5
        elif stats["pending"] < 5 and self.config_manager.get("max_concurrent_tasks") > 2:
            self.config_manager.update_config({"max_concurrent_tasks": 3}, safe=True)
            self.task_manager.max_concurrent = 3

