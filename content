def parse_cookies(cookie_str: str, domain: str) -> List[Dict]:
    cookies = []
    for item in cookie_str.split(';'):
        if '=' in item:
            name, value = item.strip().split('=',1)
            cookies.append({"name": name, "value": value, "domain": domain, "path": "/"})
    return cookies

