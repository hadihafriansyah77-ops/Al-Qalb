# ENHANCED RISK MANAGER
class EnhancedRiskManager:
    def __init__(self, db_path=DB_FILE, daily_loss_limit=-5.0, consecutive_loss_limit=3, max_open_positions=3):
        self.db_path = db_path
        self.daily_loss_limit = daily_loss_limit
        self.consecutive_loss_limit = consecutive_loss_limit
        self.max_open_positions = max_open_positions
        self._init_table()

    def _init_table(self):
        with sqlite3.connect(self.db_path) as conn:
            conn.execute("CREATE TABLE IF NOT EXISTS risk_state (key TEXT PRIMARY KEY, value REAL, date TEXT)")

    def _get_today(self):
        return datetime.now().strftime("%Y-%m-%d")

    def record_loss(self, profit_percent: float):
        today = self._get_today()
        with sqlite3.connect(self.db_path) as conn:
            cur = conn.execute("SELECT value FROM risk_state WHERE key='daily_loss' AND date=?", (today,))
            daily = (cur.fetchone() or (0,))[0] + profit_percent
            conn.execute("INSERT OR REPLACE INTO risk_state VALUES (?,?,?)", ("daily_loss", daily, today))
            cur = conn.execute("SELECT value FROM risk_state WHERE key='consecutive_loss'")
            consec = (cur.fetchone() or (0,))[0] + 1 if profit_percent < 0 else 0
            conn.execute("INSERT OR REPLACE INTO risk_state VALUES (?,?,?)", ("consecutive_loss", consec, today))

    def is_kill_switch_active(self) -> bool:
        today = self._get_today()
        with sqlite3.connect(self.db_path) as conn:
            cur = conn.execute("SELECT value FROM risk_state WHERE key='daily_loss' AND date=?", (today,))
            daily_loss = (cur.fetchone() or (0,))[0]
            cur = conn.execute("SELECT value FROM risk_state WHERE key='consecutive_loss'")
            consec_loss = (cur.fetchone() or (0,))[0]
            return (daily_loss <= self.daily_loss_limit) or (consec_loss >= self.consecutive_loss_limit)

    def can_open_new_position(self, current_positions: int) -> bool:
        return current_positions < self.max_open_positions

