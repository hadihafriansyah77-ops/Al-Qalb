def _score_memecoin(mc: float, vol: float) -> int:
    score = 0
    if 5000 < mc < 50000: score += 40
    elif 50000 <= mc < 100000: score += 20
    if vol > 10000: score += 30
    elif vol > 5000: score += 15
    return min(100, score)

